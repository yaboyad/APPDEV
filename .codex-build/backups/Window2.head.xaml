<Window x:Class="Label_CRM_demo.Window2"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Label_CRM_demo"
        Title="Titan Dashboard"
        MinHeight="760"
        MinWidth="1180"
        WindowState="Maximized"
        Background="#07131F"
        FontFamily="Segoe UI"
        Loaded="Window_Loaded"
        Icon="Assets/Titan.ico">
    <Window.Resources>
        <LinearGradientBrush x:Key="ShellBackground" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#07131F" Offset="0"/>
            <GradientStop Color="#0D1A29" Offset="0.45"/>
            <GradientStop Color="#173746" Offset="1"/>
        </LinearGradientBrush>
    </Window.Resources>

    <Grid Background="{StaticResource ShellBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="18,18,18,0" Padding="18,14" Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Titan" Foreground="#F6FBFD" FontSize="28" FontWeight="Bold"/>
                    <Border Width="1" Height="20" Margin="16,0,16,0" Background="#315164"/>
                    <TextBlock Text="Artist CRM workspace" Foreground="#8CCFC7" FontWeight="SemiBold"/>
                    <Border Width="1" Height="20" Margin="16,0,16,0" Background="#315164"/>
                    <TextBlock Text="Central dashboard" Foreground="#9FD8CF" FontWeight="SemiBold"/>
                    <Border Width="1" Height="20" Margin="16,0,16,0" Background="#315164"/>
                    <TextBlock x:Name="ClockText" Foreground="#D7E5EC" FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel Margin="0,0,14,0">
                        <TextBlock Text="Signed in" Foreground="#8CCFC7" FontSize="12" HorizontalAlignment="Right"/>
                        <TextBlock x:Name="UserNameText" Foreground="#F6FBFD" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                    </StackPanel>
                    <Button x:Name="LogoutButton" Content="Log Out" Click="Logout_Click" Style="{StaticResource AccentNavButtonStyle}" Margin="0"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border x:Name="SidebarPanel" Grid.Column="0" Margin="0,0,18,0" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Workspace hub" Foreground="#F6FBFD" FontSize="22" FontWeight="Bold"/>
                    <TextBlock Margin="0,8,0,18" Text="Keep your overview anchored while focused windows, contact management, contracts, and support stay one click away." Foreground="#AFC4CF" TextWrapping="Wrap"/>
                    <Button x:Name="OverviewButton" Click="Nav_Overview_Click" Style="{StaticResource NavButtonStyle}" Content="Overview"/>
                    <Button x:Name="AccountButton" Click="Nav_Account_Click" Style="{StaticResource NavButtonStyle}" Content="Account workspace"/>
                    <Button x:Name="PaymentsButton" Click="Nav_Payments_Click" Style="{StaticResource NavButtonStyle}" Content="Payments workspace"/>
                    <Button x:Name="ContractsButton" Click="Nav_Contracts_Click" Style="{StaticResource NavButtonStyle}" Content="Contracts"/>
                    <Button x:Name="CalendarButton" Click="Nav_Calendar_Click" Style="{StaticResource NavButtonStyle}" Content="Calendar"/>
                    <Button x:Name="SmsButton" Click="Nav_SMSManager_Click" Style="{StaticResource NavButtonStyle}" Content="Contacts"/>
                    <Button x:Name="EmailButton" Click="Nav_EmailManager_Click" Style="{StaticResource NavButtonStyle}" Content="Email manager"/>
                    <Button x:Name="SupportButton" Click="Nav_Support_Click" Style="{StaticResource NavButtonStyle}" Content="Support center"/>
                    <Border x:Name="StoreCard" Margin="0,16,0,0" Padding="16" CornerRadius="18" Background="#101A23" BorderBrush="#315063" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Local workspace stores" Foreground="#F0B862" FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock x:Name="StorageText" Margin="0,10,0,0" Foreground="#A8BFCA" FontSize="12" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <ScrollViewer Grid.Column="1" x:Name="DashboardScrollViewer" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.25*"/>
                            <ColumnDefinition Width="0.85*"/>
                        </Grid.ColumnDefinitions>
                        <Border x:Name="HeroCard" Margin="0,0,18,0" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Live control center" Foreground="#8CCFC7" FontWeight="SemiBold"/>
                                <TextBlock x:Name="WelcomeText" Margin="0,18,0,0" Foreground="#F6FBFD" FontSize="36" FontWeight="Bold" TextWrapping="Wrap"/>
                                <TextBlock Margin="0,14,0,0" Foreground="#BAD0DA" TextWrapping="Wrap" LineHeight="24"
                                           Text="Track the day from here, manage contacts and contracts locally, and let follow-up dates feed the calendar while support stays close by."/>
                            </StackPanel>
                        </Border>
                        <Border x:Name="LaunchCard" Grid.Column="1" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Quick launch" Foreground="#F6FBFD" FontSize="22" FontWeight="Bold"/>
                                <TextBlock Margin="0,8,0,16" Foreground="#AFC4CF" TextWrapping="Wrap"
                                           Text="Jump into the spaces you use most, then return here without losing context or your local CRM state."/>
                                <Button x:Name="OpenPaymentsButton" Content="Launch payments" Click="AddPayment_Click" Style="{StaticResource AccentActionButtonStyle}"/>
                                <Button x:Name="OpenContractsButton" Margin="0,10,0,0" Content="Open contracts" Click="CreateContract_Click" Style="{StaticResource ActionButtonStyle}"/>
                                <Button x:Name="OpenSmsButton" Margin="0,10,0,0" Content="Open contacts" Click="NewContact_Click" Style="{StaticResource ActionButtonStyle}"/>
                                <Button x:Name="OpenSupportButton" Margin="0,10,0,0" Content="Open support center" Click="OpenSupportCenter_Click" Style="{StaticResource ActionButtonStyle}"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <UniformGrid Margin="0,18,0,0" Columns="4">
                        <Border x:Name="AccountCard" Margin="0,0,14,14" Style="{StaticResource CardStyle}"><StackPanel><TextBlock Text="Account status" Foreground="#9FB7C3" FontWeight="SemiBold"/><TextBlock x:Name="AccountStatusText" Margin="0,10,0,0" Foreground="#F6FBFD" FontSize="28" FontWeight="Bold"/></StackPanel></Border>
                        <Border x:Name="PaymentMetricCard" Margin="0,0,14,14" Style="{StaticResource CardStyle}"><StackPanel><TextBlock Text="Next payment" Foreground="#9FB7C3" FontWeight="SemiBold"/><TextBlock x:Name="NextPaymentText" Margin="0,10,0,0" Foreground="#F6FBFD" FontSize="28" FontWeight="Bold"/><TextBlock x:Name="NextPaymentDateText" Margin="0,10,0,0" Foreground="#AFC4CF"/></StackPanel></Border>
                        <Border x:Name="RevenueCard" Margin="0,0,14,14" Style="{StaticResource CardStyle}"><StackPanel><TextBlock Text="Active contracts" Foreground="#9FB7C3" FontWeight="SemiBold"/><TextBlock x:Name="RevenueText" Margin="0,10,0,0" Foreground="#F6FBFD" FontSize="28" FontWeight="Bold"/></StackPanel></Border>
                        <Border x:Name="TasksCard" Margin="0,0,0,14" Style="{StaticResource CardStyle}"><StackPanel><TextBlock Text="Follow-ups this week" Foreground="#9FB7C3" FontWeight="SemiBold"/><TextBlock x:Name="TasksText" Margin="0,10,0,0" Foreground="#F6FBFD" FontSize="28" FontWeight="Bold"/></StackPanel></Border>
                    </UniformGrid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border x:Name="PaymentsSection" Grid.Column="0" Margin="0,0,14,0" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Recent payments" Foreground="#F6FBFD" FontSize="22" FontWeight="Bold"/>
                                <TextBlock Margin="0,8,0,14" Text="Your latest charge history, ready at a glance." Foreground="#AFC4CF"/>
                                <DataGrid x:Name="PaymentsGrid" Style="{StaticResource TitanDashboardDarkDataGridStyle}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Date" Binding="{Binding Date}" Width="*"/>
                                        <DataGridTextColumn Header="Amount" Binding="{Binding Amount}" Width="*"/>
                                        <DataGridTextColumn Header="Method" Binding="{Binding Method}" Width="*"/>
                                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>
                        <Border x:Name="CalendarSection" Grid.Column="1" Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="24" Height="4" Margin="0,0,10,0" CornerRadius="2" Background="#70E1D1" VerticalAlignment="Center"/>
                                            <TextBlock Text="Calendar overview" Style="{StaticResource TitanEyebrowTextStyle}"/>
                                        </StackPanel>
                                        <TextBlock Margin="0,14,0,0"
                                                   Text="Upcoming calendar"
                                                   Foreground="#F6FBFD"
                                                   FontSize="24"
                                                   FontWeight="Bold"/>
                                        <TextBlock Margin="0,8,0,0"
                                                   Text="Contact follow-ups, contract reminders, and synced appointments now read like a real agenda instead of a plain table."
                                                   Foreground="#AFC4CF"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                        <Border Padding="14,8"
                                                CornerRadius="12"
                                                Background="#10202B"
                                                BorderBrush="#315063"
                                                BorderThickness="1">
                                            <TextBlock Text="{Binding ElementName=CalendarGrid, Path=Items.Count, StringFormat={}{0} upcoming}"
                                                       Foreground="#EAF4F8"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"/>
                                        </Border>
                                        <Button Margin="0,12,0,0"
                                                Padding="18,10"
                                                Content="Open sync center"
                                                Click="Nav_Calendar_Click"
                                                Style="{StaticResource TitanPrimaryButtonStyle}"/>
                                    </StackPanel>
                                </Grid>

                                <Border Grid.Row="1"
                                        MinHeight="320"
                                        Margin="0,20,0,0"
                                        Padding="14"
                                        CornerRadius="20"
                                        Background="#F8FBFD"
                                        BorderBrush="#D7E2EA"
                                        BorderThickness="1">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  local:WheelScrollAssist.IsEnabled="True">
                                        <ItemsControl x:Name="CalendarGrid">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,12"
                                                            Padding="18"
                                                            Background="#FFFFFF"
                                                            BorderBrush="#D9E5EC"
                                                            BorderThickness="1"
                                                            CornerRadius="18">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="86"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <Border Width="72"
                                                                    Padding="8,10"
                                                                    CornerRadius="16"
                                                                    Background="#0E2530">
                                                                <StackPanel HorizontalAlignment="Center">
                                                                    <TextBlock Text="{Binding Start, StringFormat={}{0:MMM}}"
                                                                               Foreground="#87E2D7"
                                                                               FontSize="12"
                                                                               FontWeight="SemiBold"
                                                                               HorizontalAlignment="Center"/>
                                                                    <TextBlock Margin="0,4,0,0"
                                                                               Text="{Binding Start, StringFormat={}{0:dd}}"
                                                                               Foreground="#F6FBFD"
                                                                               FontSize="28"
                                                                               FontWeight="Bold"
                                                                               HorizontalAlignment="Center"/>
                                                                    <TextBlock Margin="0,2,0,0"
                                                                               Text="{Binding Start, StringFormat={}{0:ddd}}"
                                                                               Foreground="#BBD3DB"
                                                                               FontSize="12"
                                                                               HorizontalAlignment="Center"/>
                                                                </StackPanel>
                                                            </Border>

                                                            <StackPanel Grid.Column="1"
                                                                        Margin="16,0,18,0"
                                                                        VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding Title}"
                                                                           Foreground="#0F1720"
                                                                           FontSize="17"
                                                                           FontWeight="Bold"
                                                                           TextTrimming="CharacterEllipsis"/>
                                                                <TextBlock Margin="0,6,0,0"
                                                                           Foreground="#4F6673">
                                                                    <Run Text="{Binding Start, StringFormat={}{0:dddd, MMM d}}"/>
                                                                    <Run Text=" at "/>
                                                                    <Run Text="{Binding Start, StringFormat={}{0:h:mm tt}}"/>
                                                                </TextBlock>
                                                                <TextBlock Margin="0,4,0,0"
                                                                           Text="{Binding Source, StringFormat=Source: {0}}"
                                                                           Foreground="#7A8F9C"
                                                                           TextTrimming="CharacterEllipsis"/>
                                                            </StackPanel>

                                                            <StackPanel Grid.Column="2"
                                                                        VerticalAlignment="Center">
                                                                <Border Padding="12,6"
                                                                        CornerRadius="12"
                                                                        Background="#E9F7F4"
                                                                        BorderBrush="#CBEAE3"
                                                                        BorderThickness="1">
                                                                    <TextBlock Text="{Binding Category}"
                                                                               Foreground="#0D6156"
                                                                               FontSize="12"
                                                                               FontWeight="SemiBold"/>
                                                                </Border>
                                                                <Border Margin="0,10,0,0"
                                                                        Padding="12,6"
                                                                        CornerRadius="12"
                                                                        Background="#F2F5F8"
                                                                        BorderBrush="#DCE4EA"
                                                                        BorderThickness="1">
                                                                    <TextBlock Text="{Binding SyncTargetsDisplay}"
                                                                               Foreground="#5D7280"
                                                                               FontSize="12"
                                                                               FontWeight="SemiBold"/>
                                                                </Border>
                                                                <Border Margin="0,10,0,0"
                                                                        Padding="12,8"
                                                                        CornerRadius="14"
                                                                        Background="#F8FBFD"
                                                                        BorderBrush="#E3EAF0"
                                                                        BorderThickness="1">
                                                                    <StackPanel>
                                                                        <TextBlock Text="Ends"
                                                                                   Foreground="#7D93A0"
                                                                                   FontSize="11"
                                                                                   FontWeight="SemiBold"
                                                                                   HorizontalAlignment="Center"/>
                                                                        <TextBlock Margin="0,2,0,0"
                                                                                   Text="{Binding End, StringFormat={}{0:h:mm tt}}"
                                                                                   Foreground="#0F1720"
                                                                                   FontWeight="Bold"
                                                                                   HorizontalAlignment="Center"/>
                                                                    </StackPanel>
                                                                </Border>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>

                    <Grid Margin="0,18,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border x:Name="ContactsSection" Margin="0,0,0,18" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Contacts" Foreground="#F6FBFD" FontSize="22" FontWeight="Bold"/>
                                <TextBlock Margin="0,8,0,10" Foreground="#AFC4CF" TextWrapping="Wrap"
                                           Text="Add and edit contacts here, then use the follow-up date to feed the local calendar automatically."/>
                                <TextBlock x:Name="ContactStatusText" Foreground="#A9C0CA" TextWrapping="Wrap"/>
                                <Grid Margin="0,16,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Margin="0,0,10,0">
                                        <TextBlock Text="Full name" Foreground="#9FB7C3" FontWeight="SemiBold"/>
                                        <TextBox x:Name="ContactNameBox" Style="{StaticResource CrmReadableInputBoxStyle}" Margin="0,8,0,0"/>
                                        <TextBlock Margin="0,16,0,0" Text="Company" Foreground="#9FB7C3" FontWeight="SemiBold"/>
                                        <TextBox x:Name="ContactCompanyBox" Style="{StaticResource CrmReadableInputBoxStyle}" Margin="0,8,0,0"/>
                                        <TextBlock Margin="0,16,0,0" Text="Phone number" Foreground="#9FB7C3" FontWeight="SemiBold"/>
                                        <TextBox x:Name="ContactPhoneBox" Style="{StaticResource CrmReadableInputBoxStyle}" Margin="0,8,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                        <TextBlock Text="Email" Foreground="#9FB7C3" FontWeight="SemiBold"/>
                                        <TextBox x:Name="ContactEmailBox" Style="{StaticResource CrmReadableInputBoxStyle}" Margin="0,8,0,0"/>
                                        <TextBlock Margin="0,16,0,0" Text="Next follow-up" Foreground="#9FB7C3" FontWeight="SemiBold"/>
                                        <DatePicker x:Name="ContactFollowUpPicker" Style="{StaticResource CrmReadableDatePickerStyle}" Margin="0,8,0,0">
                                            <DatePicker.Resources>
                                                <Style TargetType="DatePickerTextBox" BasedOn="{StaticResource CrmReadableDatePickerTextBoxStyle}"/>
                                            </DatePicker.Resources>
                                        </DatePicker>
                                        <TextBlock Margin="0,16,0,0" Text="Notes" Foreground="#9FB7C3" FontWeight="SemiBold"/>
                                        <TextBox x:Name="ContactNotesBox" Height="92" AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top" VerticalScrollBarVisibility="Auto" Style="{StaticResource CrmReadableInputBoxStyle}" Margin="0,8,0,0"/>
                                    </StackPanel>
                                </Grid>
                                <StackPanel Margin="0,16,0,0" Orientation="Horizontal">
                                    <Button x:Name="SaveContactButton" Width="138" Content="Save contact" Click="SaveContact_Click" Style="{StaticResource AccentActionButtonStyle}"/>
                                    <Button x:Name="ResetContactButton" Width="116" Margin="10,0,0,0" Content="Clear" Click="ResetContact_Click" Style="{StaticResource ActionButtonStyle}"/>
                                </StackPanel>
                                <TextBlock Margin="0,18,0,14" Text="Select an existing contact below to edit it." Foreground="#AFC4CF"/>
                                <DataGrid x:Name="ContactsGrid"
                                          Height="240"
                                          SelectionChanged="ContactsGrid_SelectionChanged"
                                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                                          Style="{StaticResource CrmReadableDataGridStyle}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Name" Binding="{Binding FullName}" Width="1.2*"/>
                                        <DataGridTextColumn Header="Company" Binding="{Binding Company}" Width="*"/>
                                        <DataGridTextColumn Header="Phone" Binding="{Binding PhoneNumber}" Width="*"/>
                                        <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="1.2*"/>
                                        <DataGridTextColumn Header="Follow-up" Binding="{Binding FollowUpDate, StringFormat={}{0:MMM dd, yyyy}}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>
                        <Border x:Name="ContractsManagerSection" Grid.Row="1" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Contracts" Foreground="#F6FBFD" FontSize="22" FontWeight="Bold"/>
                                <TextBlock Margin="0,8,0,10" Foreground="#AFC4CF" TextWrapping="Wrap"
                                           Text="Store agreements locally, edit them in place, and send start dates and reminders into the calendar system."/>
                                <TextBlock x:Name="ContractStatusText" Foreground="#A9C0CA" TextWrapping="Wrap"/>
                                <Grid Margin="0,16,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Margin="0,0,10,0">
                                        <TextBlock Text="Contract title" Foreground="#9FB7C3" FontWeight="SemiBold"/>
                                        <TextBox x:Name="ContractTitleBox" Style="{StaticResource CrmReadableInputBoxStyle}" Margin="0,8,0,0"/>
                                        <TextBlock Margin="0,16,0,0" Text="Client" Foreground="#9FB7C3" FontWeight="SemiBold"/>
                                        <TextBox x:Name="ContractClientBox" Style="{StaticResource CrmReadableInputBoxStyle}" Margin="0,8,0,0"/>
                                        <TextBlock Margin="0,16,0,0" Text="Contract type" Foreground="#9FB7C3" FontWeight="SemiBold"/>
                                        <ComboBox x:Name="ContractTypeBox" Style="{StaticResource CrmReadableComboBoxStyle}" Margin="0,8,0,0" SelectedIndex="0">
                                            <ComboBoxItem Content="Management"/>
                                            <ComboBoxItem Content="Distribution"/>
                                            <ComboBoxItem Content="Release"/>
                                            <ComboBoxItem Content="Split Sheet"/>
                                            <ComboBoxItem Content="Service Agreement"/>
                                            <ComboBoxItem Content="Other"/>
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                        <TextBlock Text="Status" Foreground="#9FB7C3" FontWeight="SemiBold"/>
                                        <ComboBox x:Name="ContractStateBox" Style="{StaticResource CrmReadableComboBoxStyle}" Margin="0,8,0,0" SelectedIndex="0">
                                            <ComboBoxItem Content="Draft"/>
                                            <ComboBoxItem Content="Pending"/>
                                            <ComboBoxItem Content="Active"/>
                                            <ComboBoxItem Content="Expiring"/>
                                            <ComboBoxItem Content="Closed"/>
                                        </ComboBox>
                                        <TextBlock Margin="0,16,0,0" Text="Start date" Foreground="#9FB7C3" FontWeight="SemiBold"/>
                                        <DatePicker x:Name="ContractStartPicker" Style="{StaticResource CrmReadableDatePickerStyle}" Margin="0,8,0,0">
                                            <DatePicker.Resources>
                                                <Style TargetType="DatePickerTextBox" BasedOn="{StaticResource CrmReadableDatePickerTextBoxStyle}"/>
                                            </DatePicker.Resources>
                                        </DatePicker>
                                        <TextBlock Margin="0,16,0,0" Text="Reminder date" Foreground="#9FB7C3" FontWeight="SemiBold"/>
                                        <DatePicker x:Name="ContractReminderPicker" Style="{StaticResource CrmReadableDatePickerStyle}" Margin="0,8,0,0">
                                            <DatePicker.Resources>
                                                <Style TargetType="DatePickerTextBox" BasedOn="{StaticResource CrmReadableDatePickerTextBoxStyle}"/>
                                            </DatePicker.Resources>
                                        </DatePicker>
                                        <TextBlock Margin="0,16,0,0" Text="Notes" Foreground="#9FB7C3" FontWeight="SemiBold"/>
                                        <TextBox x:Name="ContractNotesBox" Height="92" AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top" VerticalScrollBarVisibility="Auto" Style="{StaticResource CrmReadableInputBoxStyle}" Margin="0,8,0,0"/>
                                    </StackPanel>
                                </Grid>
                                <StackPanel Margin="0,16,0,0" Orientation="Horizontal">
                                    <Button x:Name="SaveContractButton" Width="138" Content="Save contract" Click="SaveContract_Click" Style="{StaticResource AccentActionButtonStyle}"/>
                                    <Button x:Name="ResetContractButton" Width="116" Margin="10,0,0,0" Content="Clear" Click="ResetContract_Click" Style="{StaticResource ActionButtonStyle}"/>
                                </StackPanel>
                                <TextBlock Margin="0,18,0,14" Text="Select an existing contract below to edit it." Foreground="#AFC4CF"/>
                                <DataGrid x:Name="ContractsGrid"
                                          Height="240"
                                          SelectionChanged="ContractsGrid_SelectionChanged"
                                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                                          Style="{StaticResource CrmReadableDataGridStyle}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="1.25*"/>
                                        <DataGridTextColumn Header="Client" Binding="{Binding ClientName}" Width="*"/>
                                        <DataGridTextColumn Header="Type" Binding="{Binding ContractType}" Width="*"/>
                                        <DataGridTextColumn Header="Start" Binding="{Binding StartDate, StringFormat={}{0:MMM dd, yyyy}}" Width="*"/>
                                        <DataGridTextColumn Header="Reminder" Binding="{Binding ReminderDate, StringFormat={}{0:MMM dd, yyyy}}" Width="*"/>
                                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>
                    </Grid>
                                        <Grid Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*"/>
                            <ColumnDefinition Width="0.8*"/>
                        </Grid.ColumnDefinitions>
                        <Border x:Name="SupportSection" Margin="0,0,14,0" Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Support center" Foreground="#F6FBFD" FontSize="22" FontWeight="Bold"/>
                                    <TextBlock x:Name="SupportIntroText" Margin="0,8,0,0" Foreground="#AFC4CF" TextWrapping="Wrap"
                                               Text="Send support requests or review the full inbox depending on your account tier."/>
                                </StackPanel>

                                <StackPanel x:Name="UserSupportFormPanel" Grid.Row="1" Margin="0,18,0,0">
                                    <Border Padding="16" CornerRadius="18" Background="#101A23" BorderBrush="#315063" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="User submission access" Foreground="#F0B862" FontWeight="SemiBold"/>
                                            <TextBlock Margin="0,10,0,0" Foreground="#D8E7ED" TextWrapping="Wrap"
                                                       Text="User accounts can only submit support requests. Saved submissions are reviewed from the master account inbox."/>
                                        </StackPanel>
                                    </Border>
                                    <Border x:Name="SupportComposerCard" Margin="0,14,0,0" Padding="18" CornerRadius="18" Background="#101A23" BorderBrush="#315063" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="Send a message" Foreground="#F0B862" FontWeight="SemiBold"/>
                                            <TextBox x:Name="SupportComposerTextBox" Margin="0,14,0,0" Height="120" AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top" VerticalScrollBarVisibility="Auto" Style="{StaticResource InputBoxStyle}"/>
                                            <StackPanel Margin="0,14,0,0" Orientation="Horizontal">
                                                <Button x:Name="SendSupportButton" Width="150" Content="Send message" Click="SendSupportMessage_Click" Style="{StaticResource AccentActionButtonStyle}"/>
                                                <Button x:Name="ClearSupportButton" Width="110" Margin="12,0,0,0" Content="Clear" Click="ClearSupportMessage_Click" Style="{StaticResource ActionButtonStyle}"/>
                                            </StackPanel>
                                            <TextBlock x:Name="SupportStatusText" Margin="0,14,0,0" Foreground="#A9C0CA" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <StackPanel x:Name="MasterSupportInboxPanel" Grid.Row="1" Margin="0,18,0,0" Visibility="Collapsed">
                                    <Border Padding="16" CornerRadius="18" Background="#101A23" BorderBrush="#315063" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="Master inbox" Foreground="#F0B862" FontWeight="SemiBold"/>
                                            <TextBlock Margin="0,10,0,0" Foreground="#D8E7ED" TextWrapping="Wrap"
                                                       Text="Every support submission from every account is saved here for master review."/>
                                        </StackPanel>
                                    </Border>
                                    <DataGrid x:Name="SupportSubmissionsGrid" Margin="0,14,0,0" Height="250" SelectionChanged="SupportSubmissionsGrid_SelectionChanged" Style="{StaticResource TitanDashboardDarkDataGridStyle}">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Account" Binding="{Binding SubmittedByLabel}" Width="2*"/>
                                            <DataGridTextColumn Header="Tier" Binding="{Binding TierLabel}" Width="*"/>
                                            <DataGridTextColumn Header="Lane" Binding="{Binding Channel}" Width="*"/>
                                            <DataGridTextColumn Header="Priority" Binding="{Binding PriorityLabel}" Width="*"/>
                                            <DataGridTextColumn Header="Received" Binding="{Binding CreatedAt, StringFormat={}{0:MMM dd, h:mm tt}}" Width="1.2*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                    <Border Margin="0,14,0,0" Padding="18" CornerRadius="18" Background="#101A23" BorderBrush="#315063" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="Selected request" Foreground="#F0B862" FontWeight="SemiBold"/>
                                            <TextBlock x:Name="SelectedSupportSubmissionMetaText" Margin="0,10,0,0" Foreground="#F6FBFD" FontSize="16" FontWeight="Bold" TextWrapping="Wrap"/>
                                            <TextBlock x:Name="SelectedSupportSubmissionBodyText" Margin="0,12,0,0" Foreground="#D8E7ED" TextWrapping="Wrap" LineHeight="22"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border x:Name="SupportSummaryCard" Grid.Column="1" Style="{StaticResource CardStyle}">
                            <Grid>
                                <StackPanel x:Name="UserSupportSidebarPanel">
                                    <TextBlock Text="Submission helpers" Foreground="#F6FBFD" FontSize="22" FontWeight="Bold"/>
                                    <TextBlock Margin="0,8,0,16" Foreground="#AFC4CF" TextWrapping="Wrap"
                                               Text="Pick a quick prompt or write your own note. Every request routes to the master support inbox."/>
                                    <Border Margin="0,0,0,18" Padding="16" CornerRadius="18" Background="#101A23" BorderBrush="#315063" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="Support visibility" Foreground="#F0B862" FontWeight="SemiBold"/>
                                            <TextBlock Margin="0,10,0,0" Foreground="#F6FBFD" FontSize="18" FontWeight="Bold" Text="Submission form only"/>
                                            <TextBlock Margin="0,10,0,0" Foreground="#9FB7C3" TextWrapping="Wrap"
                                                       Text="Users can send requests, but only the master account can review saved submissions."/>
                                        </StackPanel>
                                    </Border>
                                    <TextBlock Margin="0,0,0,12" Text="Quick prompts" Foreground="#F6FBFD" FontSize="20" FontWeight="Bold"/>
                                    <Button x:Name="BillingPromptButton" Margin="0,0,0,10" Content="Need billing help" Tag="I need help with billing, invoices, or a recent payment." Click="SupportQuickPrompt_Click" Style="{StaticResource ActionButtonStyle}"/>
                                    <Button x:Name="AccessPromptButton" Margin="0,0,0,10" Content="Access issue" Tag="I cannot sign in or access the right account on this device." Click="SupportQuickPrompt_Click" Style="{StaticResource ActionButtonStyle}"/>
                                    <Button x:Name="CalendarPromptButton" Margin="0,0,0,10" Content="Calendar conflict" Tag="I need help with a scheduled task, reminder, or calendar conflict." Click="SupportQuickPrompt_Click" Style="{StaticResource ActionButtonStyle}"/>
                                    <Button x:Name="ContractsPromptButton" Margin="0,0,0,10" Content="Contract question" Tag="I need support with a contract, agreement, or split setup." Click="SupportQuickPrompt_Click" Style="{StaticResource ActionButtonStyle}"/>
                                    <Button x:Name="LaunchPromptButton" Content="Urgent launch help" Tag="Urgent: I need help with a launch, post, or release workflow right now." Click="SupportQuickPrompt_Click" Style="{StaticResource AccentActionButtonStyle}"/>
                                </StackPanel>

                                <StackPanel x:Name="MasterSupportSidebarPanel" Visibility="Collapsed">
                                    <TextBlock Text="Master support status" Foreground="#F6FBFD" FontSize="22" FontWeight="Bold"/>
                                    <TextBlock Margin="0,8,0,16" Foreground="#AFC4CF" TextWrapping="Wrap"
                                               Text="Review every saved support request from one inbox and keep routing visible at a glance."/>
                                    <UniformGrid Columns="2">
                                        <Border Margin="0,0,10,10" Padding="14" CornerRadius="16" Background="#101A23" BorderBrush="#315063" BorderThickness="1"><StackPanel><TextBlock Text="Coverage" Foreground="#9FB7C3" FontWeight="SemiBold"/><TextBlock x:Name="SupportCoverageText" Margin="0,10,0,0" Foreground="#F6FBFD" FontSize="18" FontWeight="Bold" TextWrapping="Wrap"/></StackPanel></Border>
                                        <Border Margin="0,0,0,10" Padding="14" CornerRadius="16" Background="#101A23" BorderBrush="#315063" BorderThickness="1"><StackPanel><TextBlock Text="Inbox state" Foreground="#9FB7C3" FontWeight="SemiBold"/><TextBlock x:Name="SupportThreadStateText" Margin="0,10,0,0" Foreground="#F6FBFD" FontSize="18" FontWeight="Bold" TextWrapping="Wrap"/></StackPanel></Border>
                                        <Border Margin="0,0,10,0" Padding="14" CornerRadius="16" Background="#101A23" BorderBrush="#315063" BorderThickness="1"><StackPanel><TextBlock Text="Last submission" Foreground="#9FB7C3" FontWeight="SemiBold"/><TextBlock x:Name="SupportLastReplyText" Margin="0,10,0,0" Foreground="#F6FBFD" FontSize="18" FontWeight="Bold" TextWrapping="Wrap"/></StackPanel></Border>
                                        <Border Padding="14" CornerRadius="16" Background="#101A23" BorderBrush="#315063" BorderThickness="1"><StackPanel><TextBlock Text="Routing lane" Foreground="#9FB7C3" FontWeight="SemiBold"/><TextBlock x:Name="SupportRoutingText" Margin="0,10,0,0" Foreground="#F6FBFD" FontSize="18" FontWeight="Bold" TextWrapping="Wrap"/></StackPanel></Border>
                                    </UniformGrid>
                                    <Border Margin="0,18,0,0" Padding="16" CornerRadius="18" Background="#101A23" BorderBrush="#315063" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="Saved inbox" Foreground="#F0B862" FontWeight="SemiBold"/>
                                            <TextBlock x:Name="SupportMessageCountText" Margin="0,10,0,0" Foreground="#F6FBFD" FontSize="18" FontWeight="Bold"/>
                                            <TextBlock x:Name="SupportStoragePathText" Margin="0,10,0,0" Foreground="#9FB7C3" FontSize="12" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <Border x:Name="ActivitySection" Margin="0,18,0,0" Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Recent activity" Foreground="#F6FBFD" FontSize="22" FontWeight="Bold"/>
                            <TextBlock Margin="0,8,0,14" Text="A clean pulse of what moved across the CRM workspaces and support lane." Foreground="#AFC4CF"/>
                            <DataGrid x:Name="ActivityGrid" Style="{StaticResource TitanDashboardDarkDataGridStyle}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Workspace" Binding="{Binding Workspace}" Width="*"/>
                                    <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="2*"/>
                                    <DataGridTextColumn Header="Owner" Binding="{Binding Owner}" Width="*"/>
                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Border Grid.Row="2" Margin="18,0,18,18" Padding="14,12" Style="{StaticResource CardStyle}">
            <TextBlock Text="Titan keeps your overview anchored while contacts, contracts, calendar follow-ups, and the support inbox stay available beside it."
                       Foreground="#92AAB8" HorizontalAlignment="Center"/>
        </Border>
    </Grid>
</Window>










