<Window x:Class="Label_CRM_demo.Window2"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Label_CRM_demo"
        Title="Titan Dashboard"
        MinHeight="760"
        MinWidth="1180"
        WindowState="Maximized"
        Background="{StaticResource TitanWindowFallbackBrush}"
        FontFamily="Segoe UI"
        Loaded="Window_Loaded"
        Icon="Assets/Titan.ico">

    <Grid Background="{StaticResource TitanShellBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="18,18,18,0" Padding="18,14" Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <WrapPanel VerticalAlignment="Center">
                    <TextBlock Text="Titan" Foreground="{StaticResource TitanTextPrimaryBrush}" FontSize="28" FontWeight="Bold"/>
                    <Border Width="1" Height="20" Margin="16,0,16,0" Background="{StaticResource TitanPanelBorderBrush}"/>
                    <TextBlock Text="Artist CRM workspace" Foreground="{StaticResource TitanAccentBrush}" FontWeight="SemiBold"/>
                    <Border Width="1" Height="20" Margin="16,0,16,0" Background="{StaticResource TitanPanelBorderBrush}"/>
                    <TextBlock Text="Central dashboard" Foreground="{StaticResource TitanTextSecondaryBrush}" FontWeight="SemiBold"/>
                    <Border Width="1" Height="20" Margin="16,0,16,0" Background="{StaticResource TitanPanelBorderBrush}"/>
                    <TextBlock x:Name="CurrentDateText" Foreground="{StaticResource TitanTextSecondaryBrush}" FontWeight="SemiBold"/>
                    <Border Width="1" Height="20" Margin="16,0,16,0" Background="{StaticResource TitanPanelBorderBrush}"/>
                    <TextBlock x:Name="ClockText" Foreground="{StaticResource TitanTextPrimaryBrush}" FontWeight="SemiBold"/>
                </WrapPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="ThemeToggleButton"
                            Content="Theme"
                            Click="ThemeToggle_Click"
                            Style="{StaticResource ThemeToggleButtonStyle}"
                            Margin="0,0,14,0"/>
                    <StackPanel Margin="0,0,14,0" MaxWidth="260">
                        <TextBlock Text="Signed in" Foreground="#8CCFC7" FontSize="12" HorizontalAlignment="Right"/>
                        <TextBlock x:Name="UserNameText" Foreground="#F6FBFD" FontWeight="SemiBold" HorizontalAlignment="Right" TextAlignment="Right" TextWrapping="Wrap"/>
                    </StackPanel>
                    <Button x:Name="LogoutButton" Content="Log Out" Click="Logout_Click" Style="{StaticResource AccentNavButtonStyle}" Margin="0"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border x:Name="SidebarPanel" Grid.Column="0" Margin="0,0,18,0" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Workspace hub" Foreground="#F6FBFD" FontSize="22" FontWeight="Bold"/>
                    <TextBlock Margin="0,8,0,18"
                               Text="Keep your overview anchored while focused windows, contact management, contracts, support, and platform data stay one click away."
                               Foreground="#AFC4CF"
                               TextWrapping="Wrap"/>
                    <Button x:Name="OverviewButton" Click="Nav_Overview_Click" Style="{StaticResource NavButtonStyle}" Content="Overview"/>
                    <Button x:Name="AccountButton" Click="Nav_Account_Click" Style="{StaticResource NavButtonStyle}" Content="Account workspace"/>
                    <Button x:Name="AccountsAdminButton" Click="Nav_AccountsAdmin_Click" Style="{StaticResource NavButtonStyle}" Content="Accounts admin" Visibility="Collapsed"/>
                    <Button x:Name="PaymentsButton" Click="Nav_Payments_Click" Style="{StaticResource NavButtonStyle}" Content="Payments workspace"/>
                    <Button x:Name="ContractsButton" Click="Nav_Contracts_Click" Style="{StaticResource NavButtonStyle}" Content="Contracts"/>
                    <Button x:Name="CalendarButton" Click="Nav_Calendar_Click" Style="{StaticResource NavButtonStyle}" Content="Calendar"/>
                    <Button x:Name="SmsButton" Click="Nav_SMSManager_Click" Style="{StaticResource NavButtonStyle}" Content="Contacts"/>
                    <Button x:Name="EmailButton" Click="Nav_EmailManager_Click" Style="{StaticResource NavButtonStyle}" Content="Email manager"/>
                    <Button x:Name="DataButton" Click="Nav_Data_Click" Style="{StaticResource NavButtonStyle}" Content="Data watch"/>
                    <Button x:Name="SupportButton" Click="Nav_Support_Click" Style="{StaticResource NavButtonStyle}" Content="Support center"/>
                    <Border x:Name="StoreCard" Margin="0,16,0,0" Padding="16" CornerRadius="18" Background="{StaticResource TitanPanelBrush}" BorderBrush="{StaticResource TitanPanelBorderBrush}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Local workspace stores" Foreground="{StaticResource TitanAccentWarmBrush}" FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock x:Name="StorageText" Margin="0,10,0,0" Foreground="{StaticResource TitanTextSecondaryBrush}" FontSize="12" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <ScrollViewer Grid.Column="1" x:Name="DashboardScrollViewer" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.25*"/>
                            <ColumnDefinition Width="0.85*"/>
                        </Grid.ColumnDefinitions>
                        <Border x:Name="HeroCard" Margin="0,0,18,0" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Live control center" Foreground="{StaticResource TitanAccentBrush}" FontWeight="SemiBold"/>
                                <TextBlock x:Name="WelcomeText" Margin="0,18,0,0" Foreground="{StaticResource TitanTextPrimaryBrush}" FontSize="36" FontWeight="Bold" TextWrapping="Wrap"/>
                                <TextBlock Margin="0,14,0,0"
                                           Foreground="{StaticResource TitanTextSecondaryBrush}"
                                           TextWrapping="Wrap"
                                           LineHeight="24"
                                           Text="Track the day from here, manage contacts and contracts locally, let follow-up dates feed the calendar, and keep support and account moderation close by."/>
                            </StackPanel>
                        </Border>
                        <Border x:Name="LaunchCard" Grid.Column="1" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Quick launch" Foreground="{StaticResource TitanTextPrimaryBrush}" FontSize="22" FontWeight="Bold"/>
                                <TextBlock Margin="0,8,0,16" Foreground="{StaticResource TitanTextSecondaryBrush}" TextWrapping="Wrap"
                                           Text="Jump into the spaces you use most, then return here without losing context or your local CRM state."/>
                                <Button x:Name="OpenPaymentsButton" Content="Launch payments" Click="AddPayment_Click" Style="{StaticResource AccentActionButtonStyle}"/>
                                <Button x:Name="OpenContractsButton" Margin="0,10,0,0" Content="Open contracts" Click="CreateContract_Click" Style="{StaticResource ActionButtonStyle}"/>
                                <Button x:Name="OpenSmsButton" Margin="0,10,0,0" Content="Open contacts" Click="NewContact_Click" Style="{StaticResource ActionButtonStyle}"/>
                                <Button x:Name="OpenDataButton" Margin="0,10,0,0" Content="Open data watch" Click="OpenDataWatch_Click" Style="{StaticResource ActionButtonStyle}"/>
                                <Button x:Name="OpenSupportButton" Margin="0,10,0,0" Content="Open support center" Click="OpenSupportCenter_Click" Style="{StaticResource ActionButtonStyle}"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <UniformGrid Margin="0,18,0,0" Columns="4">
                        <Border x:Name="AccountCard" Margin="0,0,14,14" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Account status" Foreground="#9FB7C3" FontWeight="SemiBold"/>
                                <TextBlock x:Name="AccountStatusText" Margin="0,10,0,0" Foreground="#F6FBFD" FontSize="28" FontWeight="Bold" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        <Border x:Name="PaymentMetricCard" Margin="0,0,14,14" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Next payment" Foreground="#9FB7C3" FontWeight="SemiBold"/>
                                <TextBlock x:Name="NextPaymentText" Margin="0,10,0,0" Foreground="#F6FBFD" FontSize="28" FontWeight="Bold" TextWrapping="Wrap"/>
                                <TextBlock x:Name="NextPaymentDateText" Margin="0,10,0,0" Foreground="#AFC4CF" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        <Border x:Name="RevenueCard" Margin="0,0,14,14" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Active contracts" Foreground="#9FB7C3" FontWeight="SemiBold"/>
                                <TextBlock x:Name="RevenueText" Margin="0,10,0,0" Foreground="#F6FBFD" FontSize="28" FontWeight="Bold" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        <Border x:Name="TasksCard" Margin="0,0,0,14" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Follow-ups this week" Foreground="#9FB7C3" FontWeight="SemiBold"/>
                                <TextBlock x:Name="TasksText" Margin="0,10,0,0" Foreground="#F6FBFD" FontSize="28" FontWeight="Bold" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <Grid x:Name="AccountsManagementHost" Margin="0,4,0,18" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*"/>
                            <ColumnDefinition Width="0.8*"/>
                        </Grid.ColumnDefinitions>

                        <Border x:Name="AccountsManagementSection" Margin="0,0,14,0" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Account management" Foreground="#F6FBFD" FontSize="22" FontWeight="Bold"/>
                                <TextBlock Margin="0,8,0,10" Foreground="#AFC4CF" TextWrapping="Wrap"
                                           Text="Review every local account from one place and ban or restore sign-in access without leaving the dashboard."/>
                                <TextBlock x:Name="AccountsStatusText" Foreground="#A9C0CA" TextWrapping="Wrap"/>

                                <Grid Margin="0,16,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.35*"/>
                                        <ColumnDefinition Width="0.95*"/>
                                    </Grid.ColumnDefinitions>

                                    <DataGrid x:Name="AccountsGrid"
                                              Height="270"
                                              SelectionChanged="AccountsGrid_SelectionChanged"
                                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                                              Style="{StaticResource TitanDashboardDarkDataGridStyle}">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Name" Binding="{Binding DisplayName}" Width="1.4*"/>
                                            <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="1.1*"/>
                                            <DataGridTextColumn Header="Contact" Binding="{Binding ContactLabel}" Width="1.5*"/>
                                            <DataGridTextColumn Header="Tier" Binding="{Binding TierLabel}" Width="*"/>
                                            <DataGridTextColumn Header="Access" Binding="{Binding AccessStatus}" Width="*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>

                                    <Border Grid.Column="1" Margin="14,0,0,0" Padding="18" CornerRadius="18" Background="#101A23" BorderBrush="#315063" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="Selected account" Foreground="#F0B862" FontWeight="SemiBold"/>
                                            <TextBlock x:Name="SelectedAccountNameText" Margin="0,12,0,0" Foreground="#F6FBFD" FontSize="20" FontWeight="Bold" TextWrapping="Wrap"/>
                                            <TextBlock x:Name="SelectedAccountMetaText" Margin="0,10,0,0" Foreground="#D8E7ED" TextWrapping="Wrap"/>
                                            <TextBlock x:Name="SelectedAccountAccessText" Margin="0,12,0,0" Foreground="#8EE7AF" FontSize="16" FontWeight="Bold" TextWrapping="Wrap"/>
                                            <TextBlock x:Name="SelectedAccountNotesText" Margin="0,10,0,0" Foreground="#9FB7C3" TextWrapping="Wrap" LineHeight="22"/>
                                            <StackPanel Margin="0,18,0,0" Orientation="Horizontal">
                                                <Button x:Name="BanAccountButton" Width="118" Content="Ban account" Click="BanAccount_Click" Style="{StaticResource AccentActionButtonStyle}"/>
                                                <Button x:Name="RestoreAccountButton" Width="126" Margin="10,0,0,0" Content="Restore access" Click="RestoreAccount_Click" Style="{StaticResource ActionButtonStyle}"/>
                                            </StackPanel>
                                            <Button x:Name="RefreshAccountsButton" Margin="0,12,0,0" Content="Refresh accounts" Click="RefreshAccounts_Click" Style="{StaticResource ActionButtonStyle}"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border x:Name="AccountsSummaryCard" Grid.Column="1" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Moderation snapshot" Foreground="#F6FBFD" FontSize="22" FontWeight="Bold"/>
                                <TextBlock Margin="0,8,0,16" Foreground="#AFC4CF" TextWrapping="Wrap"
                                           Text="Protected master accounts stay available, while user accounts can be disabled and restored from this panel."/>
                                <UniformGrid Columns="2">
                                    <Border Margin="0,0,10,10" Padding="14" CornerRadius="16" Background="#101A23" BorderBrush="#315063" BorderThickness="1"><StackPanel><TextBlock Text="Total accounts" Foreground="#9FB7C3" FontWeight="SemiBold"/><TextBlock x:Name="ManagedAccountsCountText" Margin="0,10,0,0" Foreground="#F6FBFD" FontSize="18" FontWeight="Bold" TextWrapping="Wrap"/></StackPanel></Border>
                                    <Border Margin="0,0,0,10" Padding="14" CornerRadius="16" Background="#101A23" BorderBrush="#315063" BorderThickness="1"><StackPanel><TextBlock Text="Active access" Foreground="#9FB7C3" FontWeight="SemiBold"/><TextBlock x:Name="ActiveAccountsCountText" Margin="0,10,0,0" Foreground="#F6FBFD" FontSize="18" FontWeight="Bold" TextWrapping="Wrap"/></StackPanel></Border>
                                    <Border Margin="0,0,10,0" Padding="14" CornerRadius="16" Background="#101A23" BorderBrush="#315063" BorderThickness="1"><StackPanel><TextBlock Text="Banned" Foreground="#9FB7C3" FontWeight="SemiBold"/><TextBlock x:Name="BannedAccountsCountText" Margin="0,10,0,0" Foreground="#F6FBFD" FontSize="18" FontWeight="Bold" TextWrapping="Wrap"/></StackPanel></Border>
                                    <Border Padding="14" CornerRadius="16" Background="#101A23" BorderBrush="#315063" BorderThickness="1"><StackPanel><TextBlock Text="Protected" Foreground="#9FB7C3" FontWeight="SemiBold"/><TextBlock x:Name="ProtectedAccountsCountText" Margin="0,10,0,0" Foreground="#F6FBFD" FontSize="18" FontWeight="Bold" TextWrapping="Wrap"/></StackPanel></Border>
                                </UniformGrid>
                                <Border Margin="0,18,0,0" Padding="16" CornerRadius="18" Background="#101A23" BorderBrush="#315063" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="Encrypted store" Foreground="#F0B862" FontWeight="SemiBold"/>
                                        <TextBlock x:Name="AccountsStorePathText" Margin="0,10,0,0" Foreground="#9FB7C3" FontSize="12" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border x:Name="PaymentsSection" Grid.Column="0" Margin="0,0,14,0" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Recent payments" Foreground="{StaticResource TitanTextPrimaryBrush}" FontSize="22" FontWeight="Bold"/>
                                <TextBlock Margin="0,8,0,14" Text="Your latest charge history, ready at a glance." Foreground="{StaticResource TitanTextSecondaryBrush}" TextWrapping="Wrap"/>
                                <DataGrid x:Name="PaymentsGrid" Style="{StaticResource TitanDashboardDarkDataGridStyle}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Date" Binding="{Binding Date}" Width="*"/>
                                        <DataGridTextColumn Header="Amount" Binding="{Binding Amount}" Width="*"/>
                                        <DataGridTextColumn Header="Method" Binding="{Binding Method}" Width="*"/>
                                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>
                        <Border x:Name="CalendarSection" Grid.Column="1" Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="24" Height="4" Margin="0,0,10,0" CornerRadius="2" Background="#70E1D1" VerticalAlignment="Center"/>
                                            <TextBlock Text="Calendar overview" Style="{StaticResource TitanEyebrowTextStyle}"/>
                                        </StackPanel>
                                        <TextBlock Margin="0,14,0,0"
                                                   Text="Upcoming calendar"
                                                   Foreground="#F6FBFD"
                                                   FontSize="24"
                                                   FontWeight="Bold"/>
                                        <TextBlock Margin="0,8,0,0"
                                                   Text="Contact follow-ups, contract reminders, and synced appointments now read like a real agenda instead of a plain table."
                                                   Foreground="#AFC4CF"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                        <Border Padding="14,8"
                                                CornerRadius="12"
                                                Background="#10202B"
                                                BorderBrush="#315063"
                                                BorderThickness="1">
                                            <TextBlock Text="{Binding ElementName=CalendarGrid, Path=Items.Count, StringFormat={}{0} upcoming}"
                                                       Foreground="#EAF4F8"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"/>
                                        </Border>
                                        <Button Margin="0,12,0,0"
                                                Padding="18,10"
                                                Content="Open sync center"
                                                Click="Nav_Calendar_Click"
                                                Style="{StaticResource TitanPrimaryButtonStyle}"/>
                                    </StackPanel>
                                </Grid>

                                <Border Grid.Row="1"
                                        MinHeight="320"
                                        Margin="0,20,0,0"
                                        Padding="14"
                                        CornerRadius="20"
                                        Background="#F8FBFD"
                                        BorderBrush="#D7E2EA"
                                        BorderThickness="1">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  local:WheelScrollAssist.IsEnabled="True">
                                        <ItemsControl x:Name="CalendarGrid">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,12"
                                                            Padding="18"
                                                            Background="#FFFFFF"
                                                            BorderBrush="#D9E5EC"
                                                            BorderThickness="1"
                                                            CornerRadius="18">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="86"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <Border Width="72"
                                                                    Padding="8,10"
                                                                    CornerRadius="16"
                                                                    Background="#0E2530">
                                                                <StackPanel HorizontalAlignment="Center">
                                                                    <TextBlock Text="{Binding Start, StringFormat={}{0:MMM}}"
                                                                               Foreground="#87E2D7"
                                                                               FontSize="12"
                                                                               FontWeight="SemiBold"
                                                                               HorizontalAlignment="Center"/>
                                                                    <TextBlock Margin="0,4,0,0"
                                                                               Text="{Binding Start, StringFormat={}{0:dd}}"
                                                                               Foreground="#F6FBFD"
                                                                               FontSize="28"
                                                                               FontWeight="Bold"
                                                                               HorizontalAlignment="Center"/>
                                                                    <TextBlock Margin="0,2,0,0"
                                                                               Text="{Binding Start, StringFormat={}{0:ddd}}"
                                                                               Foreground="#BBD3DB"
                                                                               FontSize="12"
                                                                               HorizontalAlignment="Center"/>
                                                                </StackPanel>
                                                            </Border>

                                                            <StackPanel Grid.Column="1"
                                                                        Margin="16,0,18,0"
                                                                        VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding Title}"
                                                                           Foreground="#0F1720"
                                                                           FontSize="17"
                                                                           FontWeight="Bold"
                                                                           TextWrapping="Wrap"/>
                                                                <TextBlock Margin="0,6,0,0"
                                                                           Foreground="#4F6673"
                                                                           TextWrapping="Wrap">
                                                                    <Run Text="{Binding Start, StringFormat={}{0:dddd, MMM d}}"/>
                                                                    <Run Text=" at "/>
                                                                    <Run Text="{Binding Start, StringFormat={}{0:h:mm tt}}"/>
                                                                </TextBlock>
                                                                <TextBlock Margin="0,4,0,0"
                                                                           Text="{Binding Source, StringFormat=Source: {0}}"
                                                                           Foreground="#7A8F9C"
                                                                           TextWrapping="Wrap"/>
                                                            </StackPanel>

                                                            <StackPanel Grid.Column="2"
                                                                        VerticalAlignment="Center">
                                                                <Border Padding="12,6"
                                                                        CornerRadius="12"
                                                                        Background="#E9F7F4"
                                                                        BorderBrush="#CBEAE3"
                                                                        BorderThickness="1">
                                                                    <TextBlock Text="{Binding Category}"
                                                                               Foreground="#0D6156"
                                                                               FontSize="12"
                                                                               FontWeight="SemiBold"
                                                                               MaxWidth="104"
                                                                               TextAlignment="Center"
                                                                               TextWrapping="Wrap"/>
                                                                </Border>
                                                                <Border Margin="0,10,0,0"
                                                                        Padding="12,6"
                                                                        CornerRadius="12"
                                                                        Background="#F2F5F8"
                                                                        BorderBrush="#DCE4EA"
                                                                        BorderThickness="1">
                                                                    <TextBlock Text="{Binding SyncTargetsDisplay}"
                                                                               Foreground="#5D7280"
                                                                               FontSize="12"
                                                                               FontWeight="SemiBold"
                                                                               MaxWidth="104"
                                                                               TextAlignment="Center"
                                                                               TextWrapping="Wrap"/>
                                                                </Border>
                                                                <Border Margin="0,10,0,0"
                                                                        Padding="12,8"
                                                                        CornerRadius="14"
                                                                        Background="#F8FBFD"
                                                                        BorderBrush="#E3EAF0"
                                                                        BorderThickness="1">
                                                                    <StackPanel>
                                                                        <TextBlock Text="Ends"
                                                                                   Foreground="#7D93A0"
                                                                                   FontSize="11"
                                                                                   FontWeight="SemiBold"
                                                                                   HorizontalAlignment="Center"/>
                                                                        <TextBlock Margin="0,2,0,0"
                                                                                   Text="{Binding End, StringFormat={}{0:h:mm tt}}"
                                                                                   Foreground="#0F1720"
                                                                                   FontWeight="Bold"
                                                                                   HorizontalAlignment="Center"/>
                                                                    </StackPanel>
                                                                </Border>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>

                    <Grid Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*"/>
                            <ColumnDefinition Width="0.8*"/>
                        </Grid.ColumnDefinitions>
                        <Border x:Name="DataSection" Margin="0,0,14,0" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Data watch" Foreground="#F6FBFD" FontSize="22" FontWeight="Bold"/>
                                <TextBlock Margin="0,8,0,14" Foreground="#AFC4CF" TextWrapping="Wrap"
                                           Text="Keep the most important social and audience APIs in one watchlist so campaign and release checks are always nearby."/>
                                <DataGrid x:Name="DataWatchGrid"
                                          Height="250"
                                          IsReadOnly="True"
                                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                                          Style="{StaticResource TitanDashboardDarkDataGridStyle}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="API" Binding="{Binding Platform}" Width="1.35*"/>
                                        <DataGridTextColumn Header="Audience" Binding="{Binding Audience}" Width="1.15*"/>
                                        <DataGridTextColumn Header="Reach" Binding="{Binding Reach}" Width="1.15*"/>
                                        <DataGridTextColumn Header="Cadence" Binding="{Binding LastUpdate}" Width="*"/>
                        <Border x:Name="DataInsightCard" Grid.Column="1" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="What to watch" Foreground="#F6FBFD" FontSize="22" FontWeight="Bold"/>
                                <TextBlock Margin="0,8,0,16" Foreground="#AFC4CF" TextWrapping="Wrap"
                                           Text="This keeps the launch-side signals close: audience health, video momentum, and mention spikes across the channels that move fastest."/>
                                <Border Margin="0,0,0,12" Padding="16" CornerRadius="18" Background="#101A23" BorderBrush="#315063" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="Audience health" Foreground="#F0B862" FontWeight="SemiBold"/>
                                        <TextBlock Margin="0,10,0,0" Foreground="#D8E7ED" TextWrapping="Wrap"
                                                   Text="Follower growth, saves, subscribers, and repeat viewers show whether the core fan base is actually moving."/>
                                    </StackPanel>
                                </Border>
                                <Border Margin="0,0,0,12" Padding="16" CornerRadius="18" Background="#101A23" BorderBrush="#315063" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="Momentum shifts" Foreground="#F0B862" FontWeight="SemiBold"/>
                                        <TextBlock Margin="0,10,0,0" Foreground="#D8E7ED" TextWrapping="Wrap"
                                                   Text="Reels reach, shorts watch depth, repost velocity, and profile clicks help you catch a spike before it cools off."/>
                                    </StackPanel>
                                </Border>
