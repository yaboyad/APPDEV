<Window x:Class="Label_CRM_demo.Window2"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Label_CRM_demo"
        Title="Titan Dashboard"
        MinHeight="760"
        MinWidth="1180"
        WindowState="Maximized"
        Background="{StaticResource TitanWindowFallbackBrush}"
        FontFamily="Segoe UI"
        Loaded="Window_Loaded"
        Icon="Assets/Titan.ico">
    <Grid Background="{StaticResource TitanShellBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="18,18,18,0" Padding="18,14" Style="{StaticResource CardStyle}">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <TextBlock Text="Titan" Foreground="#F6FBFD" FontSize="28" FontWeight="Bold"/>
                    <TextBlock Margin="16,0,0,0" Text="Artist CRM workspace" Foreground="#8CCFC7"/>
                    <TextBlock Margin="16,0,0,0" Text="Central dashboard" Foreground="#AFC4CF"/>
                    <TextBlock x:Name="CurrentDateText" Margin="16,0,0,0" Foreground="#AFC4CF"/>
                    <TextBlock x:Name="ClockText" Margin="16,0,0,0" Foreground="#F6FBFD"/>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button x:Name="ThemeToggleButton" Content="Theme" Click="ThemeToggle_Click" Style="{StaticResource ThemeToggleButtonStyle}" Margin="0,0,14,0"/>
                    <StackPanel Margin="0,0,14,0">
                        <TextBlock Text="Signed in" Foreground="#8CCFC7" FontSize="12" HorizontalAlignment="Right"/>
                        <TextBlock x:Name="UserNameText" Foreground="#F6FBFD" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                    </StackPanel>
                    <Button x:Name="LogoutButton" Content="Log Out" Click="Logout_Click" Style="{StaticResource AccentNavButtonStyle}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" Margin="18">
            <Grid.ColumnDefinitions><ColumnDefinition Width="280"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <Border x:Name="SidebarPanel" Grid.Column="0" Margin="0,0,18,0" Style="{StaticResource CardStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Workspace hub" Foreground="#F6FBFD" FontSize="22" FontWeight="Bold"/>
                        <Button x:Name="OverviewButton" Click="Nav_Overview_Click" Style="{StaticResource NavButtonStyle}" Content="Overview"/>
                        <Button x:Name="AccountButton" Click="Nav_Account_Click" Style="{StaticResource NavButtonStyle}" Content="Account workspace"/>
                        <Button x:Name="AccountsAdminButton" Click="Nav_AccountsAdmin_Click" Style="{StaticResource NavButtonStyle}" Content="Accounts admin" Visibility="Collapsed"/>
                        <Button x:Name="PaymentsButton" Click="Nav_Payments_Click" Style="{StaticResource NavButtonStyle}" Content="Payments workspace"/>
                        <Button x:Name="ContactsButton" Click="Nav_Contacts_Click" Style="{StaticResource NavButtonStyle}" Content="Contacts"/>
                        <Button x:Name="ContractsButton" Click="Nav_Contracts_Click" Style="{StaticResource NavButtonStyle}" Content="Contracts"/>
                        <Button x:Name="CalendarButton" Click="Nav_Calendar_Click" Style="{StaticResource NavButtonStyle}" Content="Calendar"/>
                        <Button x:Name="SmsButton" Click="Nav_TextCampaigns_Click" Style="{StaticResource NavButtonStyle}" Content="Text campaigns"/>
                        <Button x:Name="EmailButton" Click="Nav_EmailCampaigns_Click" Style="{StaticResource NavButtonStyle}" Content="Email campaigns"/>
                        <Button x:Name="DataButton" Click="Nav_Data_Click" Style="{StaticResource NavButtonStyle}" Content="Data watch"/>
                        <Button x:Name="OutreachButton" Click="Nav_Outreach_Click" Style="{StaticResource NavButtonStyle}" Content="Outreach tracker"/>
                        <Button x:Name="SupportButton" Click="Nav_Support_Click" Style="{StaticResource NavButtonStyle}" Content="Support center"/>
                        <Border x:Name="StoreCard" Margin="0,16,0,0" Padding="12" CornerRadius="14" Background="#101A23" BorderBrush="#315063" BorderThickness="1"><TextBlock x:Name="StorageText" Foreground="#A8BFCA" TextWrapping="Wrap"/></Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
            <ScrollViewer Grid.Column="1" x:Name="DashboardScrollViewer" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="1.2*"/><ColumnDefinition Width="0.8*"/></Grid.ColumnDefinitions><Border x:Name="HeroCard" Margin="0,0,18,0" Style="{StaticResource CardStyle}"><StackPanel><TextBlock Text="Live control center" Foreground="#8CCFC7" FontWeight="SemiBold"/><TextBlock x:Name="WelcomeText" Margin="0,18,0,0" Foreground="#F6FBFD" FontSize="36" FontWeight="Bold" TextWrapping="Wrap"/><TextBlock Margin="0,14,0,0" Foreground="#AFC4CF" TextWrapping="Wrap" Text="Track contacts, contracts, text campaigns, email campaigns, the calendar, and outreach in one place."/></StackPanel></Border><Border x:Name="LaunchCard" Grid.Column="1" Style="{StaticResource CardStyle}"><StackPanel><TextBlock Text="Quick launch" Foreground="#F6FBFD" FontSize="22" FontWeight="Bold"/><Button x:Name="OpenPaymentsButton" Content="Launch payments" Click="AddPayment_Click" Style="{StaticResource AccentActionButtonStyle}"/><Button x:Name="OpenContractsButton" Margin="0,10,0,0" Content="Open contracts" Click="CreateContract_Click" Style="{StaticResource ActionButtonStyle}"/><Button x:Name="OpenContactsButton" Margin="0,10,0,0" Content="Open contacts" Click="OpenContactsDashboard_Click" Style="{StaticResource ActionButtonStyle}"/><Button x:Name="OpenSmsButton" Margin="0,10,0,0" Content="Open text campaigns" Click="OpenTextCampaigns_Click" Style="{StaticResource ActionButtonStyle}"/><Button x:Name="OpenEmailButton" Margin="0,10,0,0" Content="Open email campaigns" Click="OpenEmailCampaigns_Click" Style="{StaticResource ActionButtonStyle}"/><Button x:Name="OpenDataButton" Margin="0,10,0,0" Content="Open data watch" Click="OpenDataWatch_Click" Style="{StaticResource ActionButtonStyle}"/><Button x:Name="OpenSupportButton" Margin="0,10,0,0" Content="Open support center" Click="OpenSupportCenter_Click" Style="{StaticResource ActionButtonStyle}"/></StackPanel></Border></Grid>
                    <UniformGrid Margin="0,18,0,0" Columns="4"><Border x:Name="AccountCard" Margin="0,0,14,14" Style="{StaticResource CardStyle}"><StackPanel><TextBlock Text="Account status" Foreground="#9FB7C3"/><TextBlock x:Name="AccountStatusText" Margin="0,10,0,0" Foreground="#F6FBFD" FontSize="28" FontWeight="Bold"/></StackPanel></Border><Border x:Name="PaymentMetricCard" Margin="0,0,14,14" Style="{StaticResource CardStyle}"><StackPanel><TextBlock Text="Next payment" Foreground="#9FB7C3"/><TextBlock x:Name="NextPaymentText" Margin="0,10,0,0" Foreground="#F6FBFD" FontSize="28" FontWeight="Bold"/><TextBlock x:Name="NextPaymentDateText" Margin="0,10,0,0" Foreground="#AFC4CF"/></StackPanel></Border><Border x:Name="RevenueCard" Margin="0,0,14,14" Style="{StaticResource CardStyle}"><StackPanel><TextBlock Text="Active contracts" Foreground="#9FB7C3"/><TextBlock x:Name="RevenueText" Margin="0,10,0,0" Foreground="#F6FBFD" FontSize="28" FontWeight="Bold"/></StackPanel></Border><Border x:Name="TasksCard" Margin="0,0,0,14" Style="{StaticResource CardStyle}"><StackPanel><TextBlock Text="Outreach this week" Foreground="#9FB7C3"/><TextBlock x:Name="TasksText" Margin="0,10,0,0" Foreground="#F6FBFD" FontSize="28" FontWeight="Bold"/></StackPanel></Border></UniformGrid>
