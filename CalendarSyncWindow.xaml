<local:SnapWindow x:Class="Label_CRM_demo.CalendarSyncWindow"
                  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                  xmlns:local="clr-namespace:Label_CRM_demo"
                  Title="Calendar Sync Center"
                  Height="900"
                  Width="1340"
                  MinHeight="820"
                  MinWidth="1160"
                  Background="#07131F"
                  Icon="Assets/Titan.ico">
    <local:SnapWindow.Resources>
        <LinearGradientBrush x:Key="WindowBackground" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#07131F" Offset="0.0"/>
            <GradientStop Color="#0B1A26" Offset="0.46"/>
            <GradientStop Color="#163445" Offset="1.0"/>
        </LinearGradientBrush>



        <DataTemplate x:Key="DayEventChipTemplate">
            <Border Margin="0,0,0,6"
                    Padding="8,5"
                    Background="{Binding BackgroundBrush}"
                    CornerRadius="10">
                <TextBlock Text="{Binding Label}"
                           Foreground="{Binding ForegroundBrush}"
                           FontSize="11"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis"/>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="AgendaCardTemplate">
            <Button x:Name="AgendaButton"
                    Margin="0,0,0,12"
                    Tag="{Binding Id}"
                    Click="AgendaEvent_Click"
                    Style="{StaticResource FlatCardButtonStyle}">
                <Border x:Name="AgendaChrome"
                        Padding="16"
                        Background="{Binding SurfaceBrush}"
                        BorderBrush="{Binding BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="72"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Width="58"
                                Padding="8,10"
                                CornerRadius="16"
                                Background="{Binding AccentBrush}">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding MonthLabel}"
                                           Foreground="#F6FBFD"
                                           FontSize="10"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Margin="0,3,0,0"
                                           Text="{Binding DayNumber}"
                                           Foreground="#F6FBFD"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <StackPanel Grid.Column="1"
                                    Margin="14,0,16,0"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{Binding Title}"
                                       Foreground="#0F1720"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       TextWrapping="Wrap"/>
                            <TextBlock Margin="0,6,0,0"
                                       Text="{Binding TimeLabel}"
                                       Foreground="#4A6170" TextWrapping="Wrap"/>
                            <TextBlock Margin="0,5,0,0"
                                       Text="{Binding DetailText}"
                                       Foreground="#5F7481"
                                       TextWrapping="Wrap"
                                       Visibility="{Binding DetailVisibility}"/>
                            <TextBlock Margin="0,5,0,0"
                                       Text="{Binding DescriptionPreview}"
                                       Foreground="#728795"
                                       TextWrapping="Wrap"
                                       TextTrimming="CharacterEllipsis"
                                       MaxHeight="36"
                                       Visibility="{Binding DescriptionVisibility}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2"
                                    VerticalAlignment="Center">
                            <Border Padding="12,6"
                                    CornerRadius="999"
                                    Background="{Binding AccentSoftBrush}">
                                <TextBlock Text="{Binding Category}"
                                           Foreground="{Binding AccentForegroundBrush}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           MaxWidth="116"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"/>
                            </Border>
                            <Border Margin="0,10,0,0"
                                    Padding="12,6"
                                    CornerRadius="999"
                                    Background="#F4F8FB"
                                    BorderBrush="#DCE5EB"
                                    BorderThickness="1">
                                <TextBlock Text="{Binding SyncTargets}"
                                           Foreground="#5A7180"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           MaxWidth="116"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>
            </Button>
            <DataTemplate.Triggers>
                <Trigger SourceName="AgendaButton" Property="IsMouseOver" Value="True">
                    <Setter TargetName="AgendaChrome" Property="BorderBrush" Value="#7BB8C9"/>
                </Trigger>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter TargetName="AgendaChrome" Property="BorderBrush" Value="#1184A7"/>
                    <Setter TargetName="AgendaChrome" Property="BorderThickness" Value="2"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <Style x:Key="MonthDayButtonStyle" TargetType="Button" BasedOn="{StaticResource FlatCardButtonStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="DayChrome"
                                Margin="5"
                                MinHeight="118"
                                Padding="12"
                                Background="{Binding SurfaceBrush}"
                                BorderBrush="#D8E5EC"
                                BorderThickness="1"
                                CornerRadius="20">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                    <StackPanel Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <TextBlock x:Name="DayNumberText"
                                                   Text="{Binding DayNumber}"
                                                   Foreground="#0F1720"
                                                   FontSize="18"
                                                   FontWeight="Bold"/>
                                        <Border Margin="8,0,0,0"
                                                Padding="8,3"
                                                Background="#EFF5F8"
                                                CornerRadius="999"
                                                Visibility="{Binding MonthLabelVisibility}">
                                            <TextBlock Text="{Binding MonthLabel}"
                                                       Foreground="#58717F"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"/>
                                        </Border>
                                    </StackPanel>

                                    <Border x:Name="TodayBadge"
                                            Grid.Column="1"
                                            Padding="8,3"
                                            Background="#E9F7F4"
                                            CornerRadius="999"
                                            Visibility="Collapsed">
                                        <TextBlock Text="Today"
                                                   Foreground="#0D6156"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>

                                <ItemsControl Grid.Row="1"
                                              Margin="0,12,0,0"
                                              ItemsSource="{Binding VisibleEvents}"
                                              ItemTemplate="{StaticResource DayEventChipTemplate}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>

                                <TextBlock Grid.Row="2"
                                           Margin="0,8,0,0"
                                           Text="{Binding OverflowLabel}"
                                           Foreground="#6D8592"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Visibility="{Binding OverflowVisibility}"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="DayChrome" Property="BorderBrush" Value="#75B2C4"/>
                                <Setter TargetName="DayChrome" Property="Background" Value="#F7FBFD"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding IsCurrentMonth}" Value="False">
                                <Setter TargetName="DayChrome" Property="Opacity" Value="0.62"/>
                                <Setter TargetName="DayChrome" Property="Background" Value="#F4F7FA"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsToday}" Value="True">
                                <Setter TargetName="TodayBadge" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="DayChrome" Property="BorderBrush" Value="#70CABC"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter TargetName="DayChrome" Property="Background" Value="#0E2431"/>
                                <Setter TargetName="DayChrome" Property="BorderBrush" Value="#70E1D1"/>
                                <Setter TargetName="DayNumberText" Property="Foreground" Value="#F5FBFD"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </local:SnapWindow.Resources>

    <Grid Background="{StaticResource WindowBackground}">
        <Canvas IsHitTestVisible="False">
            <Border Width="470" Height="220" CornerRadius="48" Opacity="0.2">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                        <GradientStop Color="#4FD1C5" Offset="0.0"/>
                        <GradientStop Color="#004FD1C5" Offset="1.0"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Effect>
                    <BlurEffect Radius="120"/>
                </Border.Effect>
                <Border.RenderTransform>
                    <TranslateTransform X="-140" Y="90"/>
                </Border.RenderTransform>
            </Border>

            <Border Width="380" Height="190" CornerRadius="42" Opacity="0.16">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                        <GradientStop Color="#F59E0B" Offset="0.0"/>
                        <GradientStop Color="#00F59E0B" Offset="1.0"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Effect>
                    <BlurEffect Radius="110"/>
                </Border.Effect>
                <Border.RenderTransform>
                    <TranslateTransform X="980" Y="580"/>
                </Border.RenderTransform>
            </Border>
        </Canvas>

        <ScrollViewer x:Name="ContentScroller" VerticalScrollBarVisibility="Auto">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border x:Name="HeaderCard" Style="{StaticResource GlassCard}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="320"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Border Width="28" Height="4" Margin="0,0,12,0" CornerRadius="2" Background="#70E1D1" VerticalAlignment="Center"/>
                                <TextBlock Text="Calendar sync center"
                                           Style="{StaticResource TitanEyebrowTextStyle}"/>
                            </StackPanel>

                            <TextBlock Margin="0,18,0,0"
                                       Foreground="#F6FBFD"
                                       FontSize="34"
                                       FontWeight="Bold" TextWrapping="Wrap"
                                       Text="Manage local CRM events and sync them with Google Calendar and Apple Calendar."/>
                            <TextBlock Margin="0,10,0,0"
                                       Foreground="#B9CED8"
                                       FontSize="15"
                                       TextWrapping="Wrap"
                                       Text="Google uses an OAuth desktop app client ID. Apple uses your iCloud email and an app-specific password over CalDAV. Every import merges into the same local calendar store first, so the dashboard preview stays in one place."/>
                        </StackPanel>

                        <Border Grid.Column="1"
                                Margin="22,0,0,0"
                                Padding="18"
                                CornerRadius="18"
                                Background="#101A23"
                                BorderBrush="#315266"
                                BorderThickness="1">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="24" Height="4" Margin="0,0,10,0" CornerRadius="2" Background="#F0B862" VerticalAlignment="Center"/>
                                    <TextBlock Text="Local store"
                                               Style="{StaticResource TitanEyebrowTextStyle}"/>
                                </StackPanel>
                                <TextBlock x:Name="LocalSummaryText"
                                           Margin="0,12,0,0"
                                           Foreground="#DDEBF1"
                                           TextWrapping="Wrap"
                                           LineHeight="22"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Grid Grid.Row="1" Margin="0,18,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border x:Name="GoogleCard" Style="{StaticResource GlassCard}" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="Google Calendar"
                                       Style="{StaticResource TitanSectionTitleTextStyle}"/>
                            <TextBlock Margin="0,8,0,16"
                                       Text="Connect a Google OAuth desktop app and import or export events against the calendar ID you choose. Most people can leave the calendar ID as primary."
                                       Style="{StaticResource TitanMutedBodyTextStyle}"/>

                            <TextBlock Text="Google Client ID"
                                       Style="{StaticResource TitanFieldLabelTextStyle}"/>
                            <TextBox x:Name="GoogleClientIdBox"
                                     Margin="0,8,0,14"
                                     Style="{StaticResource CalendarReadableTextBoxStyle}"/>

                            <TextBlock Text="Calendar ID"
                                       Style="{StaticResource TitanFieldLabelTextStyle}"/>
                            <TextBox x:Name="GoogleCalendarIdBox"
                                     Margin="0,8,0,14"
                                     Style="{StaticResource CalendarReadableTextBoxStyle}"
                                     Text="primary"/>

                            <TextBlock x:Name="GoogleSummaryText"
                                       Foreground="#DDEBF1"
                                       TextWrapping="Wrap"
                                       LineHeight="22"/>

                            <UniformGrid Margin="0,18,0,0" Columns="3">
                                <Button x:Name="ConnectGoogleButton"
                                        Margin="0,0,12,0"
                                        Content="Connect"
                                        Click="ConnectGoogle_Click"
                                        Style="{StaticResource TitanPrimaryButtonStyle}"/>
                                <Button x:Name="PullGoogleButton"
                                        Margin="0,0,12,0"
                                        Content="Import"
                                        Click="PullGoogle_Click"
                                        Style="{StaticResource SecondaryButtonStyle}"/>
                                <Button x:Name="PushGoogleButton"
                                        Content="Export"
                                        Click="PushGoogle_Click"
                                        Style="{StaticResource SecondaryButtonStyle}"/>
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <Border x:Name="AppleCard" Grid.Column="1" Style="{StaticResource GlassCard}" Margin="12,0,0,0">
                        <StackPanel>
                            <TextBlock Text="Apple Calendar"
                                       Style="{StaticResource TitanSectionTitleTextStyle}"/>
                            <TextBlock Margin="0,8,0,16"
                                       Text="Connect your iCloud calendar with your Apple ID email and an app-specific password. The app discovers your calendar collection over CalDAV, then you can import or export CRM events."
                                       Style="{StaticResource TitanMutedBodyTextStyle}"/>

                            <TextBlock Text="Apple ID Email"
                                       Style="{StaticResource TitanFieldLabelTextStyle}"/>
                            <TextBox x:Name="AppleIdBox"
                                     Margin="0,8,0,14"
                                     Style="{StaticResource CalendarReadableTextBoxStyle}"/>

                            <TextBlock Text="App-Specific Password"
                                       Style="{StaticResource TitanFieldLabelTextStyle}"/>
                            <PasswordBox x:Name="ApplePasswordBox"
                                         Margin="0,8,0,14"
                                         Style="{StaticResource CalendarReadablePasswordBoxStyle}"/>

                            <TextBlock x:Name="AppleSummaryText"
                                       Foreground="#DDEBF1"
                                       TextWrapping="Wrap"
                                       LineHeight="22"/>

                            <UniformGrid Margin="0,18,0,0" Columns="3">
                                <Button x:Name="ConnectAppleButton"
                                        Margin="0,0,12,0"
                                        Content="Connect"
                                        Click="ConnectApple_Click"
                                        Style="{StaticResource TitanPrimaryButtonStyle}"/>
                                <Button x:Name="PullAppleButton"
                                        Margin="0,0,12,0"
                                        Content="Import"
                                        Click="PullApple_Click"
                                        Style="{StaticResource SecondaryButtonStyle}"/>
                                <Button x:Name="PushAppleButton"
                                        Content="Export"
                                        Click="PushApple_Click"
                                        Style="{StaticResource SecondaryButtonStyle}"/>
                            </UniformGrid>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border x:Name="ComposerCard" Grid.Row="2" Margin="0,18,0,0" Style="{StaticResource GlassCard}">
                    <StackPanel>
                        <TextBlock Text="Event editor"
                                   Style="{StaticResource TitanSectionTitleTextStyle}"/>
                        <TextBlock Margin="0,8,0,18"
                                   Text="Add a new event or click a date or agenda card below to update an existing one before syncing back out. Date and time values use your local machine time zone."
                                   Style="{StaticResource TitanMutedBodyTextStyle}"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="Title"
                                           Style="{StaticResource TitanFieldLabelTextStyle}"/>
                                <TextBox x:Name="EventTitleBox"
                                         Margin="0,8,12,0"
                                         Style="{StaticResource CalendarReadableTextBoxStyle}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Category"
                                           Style="{StaticResource TitanFieldLabelTextStyle}"/>
                                <TextBox x:Name="EventCategoryBox"
                                         Margin="0,8,12,0"
                                         Style="{StaticResource CalendarReadableTextBoxStyle}"
                                         Text="Task"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Location"
                                           Style="{StaticResource TitanFieldLabelTextStyle}"/>
                                <TextBox x:Name="EventLocationBox"
                                         Margin="0,8,0,0"
                                         Style="{StaticResource CalendarReadableTextBoxStyle}"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="Start (example: 3/14/2026 2:00 PM)"
                                           Style="{StaticResource TitanFieldLabelTextStyle}" TextWrapping="Wrap"/>
                                <TextBox x:Name="EventStartBox"
                                         Margin="0,8,12,0"
                                         Style="{StaticResource CalendarReadableTextBoxStyle}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="End (example: 3/14/2026 3:00 PM)"
                                           Style="{StaticResource TitanFieldLabelTextStyle}" TextWrapping="Wrap"/>
                                <TextBox x:Name="EventEndBox"
                                         Margin="0,8,0,0"
                                         Style="{StaticResource CalendarReadableTextBoxStyle}"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Margin="0,16,0,0"
                                   Text="Description"
                                   Style="{StaticResource TitanFieldLabelTextStyle}"/>
                        <TextBox x:Name="EventDescriptionBox"
                                 Margin="0,8,0,0"
                                 Style="{StaticResource LargeTextBoxStyle}"/>

                        <UniformGrid Margin="0,18,0,0" Columns="4">
                            <Button x:Name="SaveEventButton"
                                    Margin="0,0,12,0"
                                    Content="Save event"
                                    Click="SaveEvent_Click"
                                    Style="{StaticResource TitanPrimaryButtonStyle}"/>
                            <Button x:Name="NewDraftButton"
                                    Margin="0,0,12,0"
                                    Content="New draft"
                                    Click="NewDraft_Click"
                                    Style="{StaticResource GhostButtonStyle}"/>
                            <Button x:Name="RefreshEventsButton"
                                    Margin="0,0,12,0"
                                    Content="Refresh board"
                                    Click="RefreshEvents_Click"
                                    Style="{StaticResource SecondaryButtonStyle}"/>
                            <Button x:Name="DeleteEventButton"
                                    Content="Delete selected"
                                    Click="DeleteEvent_Click"
                                    Style="{StaticResource DangerButtonStyle}"/>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <Border x:Name="EventsCard" Grid.Row="3" Margin="0,18,0,0" Style="{StaticResource GlassCard}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="Calendar board"
                                           Style="{StaticResource TitanSectionTitleTextStyle}"/>
                                <TextBlock Margin="0,8,0,0"
                                           Text="The sync center now uses a proper month layout, a selected-day agenda, and the same upcoming feed that powers the dashboard overview."
                                           Style="{StaticResource TitanMutedBodyTextStyle}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Top">
                                <Button x:Name="PreviousMonthButton"
                                        Margin="0,0,10,0"
                                        Content="Previous"
                                        Click="PreviousMonth_Click"
                                        Style="{StaticResource CalendarNavButtonStyle}"/>
                                <Button x:Name="TodayMonthButton"
                                        Margin="0,0,10,0"
                                        Content="Today"
                                        Click="TodayMonth_Click"
                                        Style="{StaticResource TitanPrimaryButtonStyle}"/>
                                <Button x:Name="NextMonthButton"
                                        Content="Next"
                                        Click="NextMonth_Click"
                                        Style="{StaticResource CalendarNavButtonStyle}"/>
                            </StackPanel>
                        </Grid>

                        <UniformGrid Grid.Row="1" Margin="0,20,0,0" Columns="4">
                            <Border Margin="0,0,12,0"
                                    Padding="16,14"
                                    Background="#101A23"
                                    BorderBrush="#2E5065"
                                    BorderThickness="1"
                                    CornerRadius="20">
                                <StackPanel>
                                    <TextBlock Text="Visible month"
                                               Foreground="#8FB0BE"
                                               FontSize="12"
                                               FontWeight="SemiBold"/>
                                    <TextBlock x:Name="VisibleMonthLabelText"
                                               Margin="0,8,0,0"
                                               Foreground="#F6FBFD"
                                               FontSize="18"
                                               FontWeight="Bold" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <Border Margin="12,0"
                                    Padding="16,14"
                                    Background="#101A23"
                                    BorderBrush="#2E5065"
                                    BorderThickness="1"
                                    CornerRadius="20">
                                <StackPanel>
                                    <TextBlock Text="Scheduled"
                                               Foreground="#8FB0BE"
                                               FontSize="12"
                                               FontWeight="SemiBold"/>
                                    <TextBlock x:Name="VisibleMonthSummaryText"
                                               Margin="0,8,0,0"
                                               Foreground="#F6FBFD"
                                               FontSize="18"
                                               FontWeight="Bold" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <Border Margin="12,0"
                                    Padding="16,14"
                                    Background="#101A23"
                                    BorderBrush="#2E5065"
                                    BorderThickness="1"
                                    CornerRadius="20">
                                <StackPanel>
                                    <TextBlock Text="Synced out"
                                               Foreground="#8FB0BE"
                                               FontSize="12"
                                               FontWeight="SemiBold"/>
                                    <TextBlock x:Name="VisibleMonthSyncText"
                                               Margin="0,8,0,0"
                                               Foreground="#F6FBFD"
                                               FontSize="18"
                                               FontWeight="Bold" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <Border Margin="12,0,0,0"
                                    Padding="16,14"
                                    Background="#101A23"
                                    BorderBrush="#2E5065"
                                    BorderThickness="1"
                                    CornerRadius="20">
                                <StackPanel>
                                    <TextBlock Text="Selected day"
                                               Foreground="#8FB0BE"
                                               FontSize="12"
                                               FontWeight="SemiBold"/>
                                    <TextBlock x:Name="SelectedDaySummaryText"
                                               Margin="0,8,0,0"
                                               Foreground="#F6FBFD"
                                               FontSize="18"
                                               FontWeight="Bold" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <Grid Grid.Row="2" Margin="0,22,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.85*"/>
                                <ColumnDefinition Width="1.1*"/>
                            </Grid.ColumnDefinitions>

                            <Border Padding="18"
                                    Background="#F8FBFD"
                                    BorderBrush="#D7E2EA"
                                    BorderThickness="1"
                                    CornerRadius="22">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="Month view"
                                               Foreground="#0F1720"
                                               FontSize="20"
                                               FontWeight="Bold"/>
                                    <TextBlock Grid.Row="1"
                                               Margin="0,8,0,0"
                                               Text="Browse the full month, then click any day to drill into its agenda."
                                               Foreground="#617A88" TextWrapping="Wrap"/>

                                    <Grid Grid.Row="2" Margin="0,18,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <UniformGrid Columns="7">
                                            <Border Margin="5" Padding="10,8" Background="#EFF5F8" CornerRadius="14"><TextBlock Text="Sun" Foreground="#58707E" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center"/></Border>
                                            <Border Margin="5" Padding="10,8" Background="#EFF5F8" CornerRadius="14"><TextBlock Text="Mon" Foreground="#58707E" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center"/></Border>
                                            <Border Margin="5" Padding="10,8" Background="#EFF5F8" CornerRadius="14"><TextBlock Text="Tue" Foreground="#58707E" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center"/></Border>
                                            <Border Margin="5" Padding="10,8" Background="#EFF5F8" CornerRadius="14"><TextBlock Text="Wed" Foreground="#58707E" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center"/></Border>
                                            <Border Margin="5" Padding="10,8" Background="#EFF5F8" CornerRadius="14"><TextBlock Text="Thu" Foreground="#58707E" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center"/></Border>
                                            <Border Margin="5" Padding="10,8" Background="#EFF5F8" CornerRadius="14"><TextBlock Text="Fri" Foreground="#58707E" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center"/></Border>
                                            <Border Margin="5" Padding="10,8" Background="#EFF5F8" CornerRadius="14"><TextBlock Text="Sat" Foreground="#58707E" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center"/></Border>
                                        </UniformGrid>

                                        <ItemsControl x:Name="MonthDaysItemsControl"
                                                      Grid.Row="1"
                                                      Margin="-5,10,-5,0">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <UniformGrid Columns="7"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Tag="{Binding Date}"
                                                            Click="MonthDay_Click"
                                                            Style="{StaticResource MonthDayButtonStyle}"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </Grid>
                            </Border>

                            <Grid Grid.Column="1" Margin="18,0,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Padding="18"
                                        Background="#F8FBFD"
                                        BorderBrush="#D7E2EA"
                                        BorderThickness="1"
                                        CornerRadius="22">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                            <StackPanel>
                                                <TextBlock x:Name="SelectedDayTitleText"
                                                           Foreground="#0F1720"
                                                           FontSize="20"
                                                           FontWeight="Bold" TextWrapping="Wrap"/>
                                                <TextBlock x:Name="SelectedDaySubtitleText"
                                                           Margin="0,8,0,0"
                                                           Foreground="#617A88"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>

                                            <Border Grid.Column="1"
                                                    Padding="12,7"
                                                    Background="#EFF5F8"
                                                    BorderBrush="#D7E2EA"
                                                    BorderThickness="1"
                                                    CornerRadius="999">
                                                <TextBlock x:Name="SelectedDayCountText"
                                                           Foreground="#49616E"
                                                           FontWeight="SemiBold" TextWrapping="Wrap"/>
                                            </Border>
                                        </Grid>

                                        <TextBlock Grid.Row="1"
                                                   Margin="0,14,0,0"
                                                   Text="Click an event card to load it into the editor above."
                                                   Foreground="#6D8592" TextWrapping="Wrap"/>

                                        <Grid Grid.Row="2" Margin="0,18,0,0">
                                            <TextBlock x:Name="SelectedDayEmptyText"
                                                       Text="No events scheduled for this day yet."
                                                       Foreground="#7B92A0"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       TextWrapping="Wrap"/>
                                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                          HorizontalScrollBarVisibility="Disabled"
                                                          local:WheelScrollAssist.IsEnabled="True">
                                                <ItemsControl x:Name="SelectedDayEventsItemsControl"
                                                              ItemTemplate="{StaticResource AgendaCardTemplate}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </Grid>
                                    </Grid>
                                </Border>

                                <Border Grid.Row="1"
                                        Margin="0,18,0,0"
                                        Padding="18"
                                        Background="#F8FBFD"
                                        BorderBrush="#D7E2EA"
                                        BorderThickness="1"
                                        CornerRadius="22">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                            <StackPanel>
                                                <TextBlock Text="Upcoming feed"
                                                           Foreground="#0F1720"
                                                           FontSize="20"
                                                           FontWeight="Bold"/>
                                                <TextBlock Margin="0,8,0,0"
                                                           Text="This is the same shared upcoming stream used by the dashboard overview card."
                                                           Foreground="#617A88"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>

                                            <Border Grid.Column="1"
                                                    Padding="12,7"
                                                    Background="#EFF5F8"
                                                    BorderBrush="#D7E2EA"
                                                    BorderThickness="1"
                                                    CornerRadius="999">
                                                <TextBlock x:Name="UpcomingTimelineCountText"
                                                           Foreground="#49616E"
                                                           FontWeight="SemiBold" TextWrapping="Wrap"/>
                                            </Border>
                                        </Grid>

                                        <TextBlock Grid.Row="1"
                                                   Margin="0,14,0,0"
                                                   Text="Any save, import, export, or delete here refreshes the dashboard feed automatically."
                                                   Foreground="#6D8592"
                                                   TextWrapping="Wrap"/>

                                        <Grid Grid.Row="2" Margin="0,18,0,0">
                                            <TextBlock x:Name="UpcomingTimelineEmptyText"
                                                       Text="No upcoming events are scheduled yet."
                                                       Foreground="#7B92A0"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       TextWrapping="Wrap"/>
                                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                          HorizontalScrollBarVisibility="Disabled"
                                                          local:WheelScrollAssist.IsEnabled="True">
                                                <ItemsControl x:Name="UpcomingTimelineItemsControl"
                                                              ItemTemplate="{StaticResource AgendaCardTemplate}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel/>
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>

                <Border x:Name="FooterBand"
                        Grid.Row="4"
                        Margin="0,18,0,0"
                        Padding="14,12"
                        CornerRadius="18"
                        Background="#880C1822"
                        BorderBrush="#2B4A61"
                        BorderThickness="1">
                    <TextBlock x:Name="StatusText"
                               Foreground="#93AAB8"
                               TextWrapping="Wrap"/>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</local:SnapWindow>












