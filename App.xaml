<Application x:Class="Label_CRM_demo.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Label_CRM_demo"
             xmlns:po="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options"
             ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <FontFamily x:Key="TitanShellFontFamily">Segoe UI</FontFamily>

        <BitmapImage x:Key="TitanWindowIcon"
                     UriSource="pack://application:,,,/Assets/Titan.ico"
                     po:Freeze="True"/>

        <SolidColorBrush x:Key="TitanTextPrimaryBrush" Color="#F6FBFD" po:Freeze="True"/>
        <SolidColorBrush x:Key="TitanTextSecondaryBrush" Color="#C7D7E0" po:Freeze="True"/>
        <SolidColorBrush x:Key="TitanTextMutedBrush" Color="#8EA8B7" po:Freeze="True"/>
        <SolidColorBrush x:Key="TitanAccentBrush" Color="#70E1D1" po:Freeze="True"/>
        <SolidColorBrush x:Key="TitanAccentWarmBrush" Color="#F0B862" po:Freeze="True"/>
        <SolidColorBrush x:Key="TitanFieldBackgroundBrush" Color="#0B1320" po:Freeze="True"/>
        <SolidColorBrush x:Key="TitanFieldBorderBrush" Color="#2D4659" po:Freeze="True"/>
        <SolidColorBrush x:Key="TitanFieldFocusBrush" Color="#70E1D1" po:Freeze="True"/>
        <SolidColorBrush x:Key="TitanPrimaryButtonBrush" Color="#F0B862" po:Freeze="True"/>
        <SolidColorBrush x:Key="TitanPrimaryButtonHoverBrush" Color="#F4C678" po:Freeze="True"/>
        <SolidColorBrush x:Key="TitanPrimaryButtonPressedBrush" Color="#E8AF54" po:Freeze="True"/>
        <SolidColorBrush x:Key="TitanPrimaryButtonBorderBrush" Color="#FFD166" po:Freeze="True"/>

        <Style x:Key="TitanEyebrowTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource TitanTextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="TitanMutedBodyTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource TitanTextMutedBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="LineHeight" Value="22"/>
        </Style>

        <Style x:Key="TitanSectionTitleTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource TitanTextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="19"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style x:Key="TitanMetricLabelTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="#8FA9B7"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="TitanFieldLabelTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource TitanTextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style TargetType="{x:Type TextBox}">
            <Setter Property="SelectionBrush" Value="{StaticResource TitanAccentBrush}"/>
            <Setter Property="SelectionOpacity" Value="0.35"/>
        </Style>

        <Style TargetType="{x:Type PasswordBox}">
            <Setter Property="SelectionBrush" Value="{StaticResource TitanAccentBrush}"/>
            <Setter Property="SelectionOpacity" Value="0.35"/>
        </Style>

        <Style TargetType="{x:Type DatePickerTextBox}">
            <Setter Property="SelectionBrush" Value="{StaticResource TitanAccentBrush}"/>
            <Setter Property="SelectionOpacity" Value="0.35"/>
        </Style>

        <Style x:Key="TitanInputTextBoxStyle" TargetType="{x:Type TextBox}">
            <Setter Property="Height" Value="46"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Background" Value="{StaticResource TitanFieldBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TitanTextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource TitanFieldBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush" Value="{StaticResource TitanTextPrimaryBrush}"/>
            <Setter Property="SelectionBrush" Value="{StaticResource TitanAccentBrush}"/>
            <Setter Property="SelectionOpacity" Value="0.35"/>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="Background" Value="#0F1926"/>
                    <Setter Property="BorderBrush" Value="{StaticResource TitanFieldFocusBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TitanInputPasswordBoxStyle" TargetType="{x:Type PasswordBox}">
            <Setter Property="Height" Value="46"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Background" Value="{StaticResource TitanFieldBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TitanTextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource TitanFieldBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush" Value="{StaticResource TitanTextPrimaryBrush}"/>
            <Setter Property="SelectionBrush" Value="{StaticResource TitanAccentBrush}"/>
            <Setter Property="SelectionOpacity" Value="0.35"/>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="Background" Value="#0F1926"/>
                    <Setter Property="BorderBrush" Value="{StaticResource TitanFieldFocusBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TitanPrimaryButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="48"/>
            <Setter Property="Padding" Value="18,12"/>
            <Setter Property="Background" Value="{StaticResource TitanPrimaryButtonBrush}"/>
            <Setter Property="Foreground" Value="#07131F"/>
            <Setter Property="BorderBrush" Value="{StaticResource TitanPrimaryButtonBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                CornerRadius="14"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource TitanPrimaryButtonHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource TitanPrimaryButtonPressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TitanGlassCardStyle" TargetType="{x:Type Border}">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#D9172531" Offset="0.0"/>
                        <GradientStop Color="#C90E1821" Offset="1.0"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush" Value="#294960"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="22"/>
            <Setter Property="Padding" Value="22"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="28" ShadowDepth="0" Color="#77000000" Opacity="0.32"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GlassCard" TargetType="{x:Type Border}" BasedOn="{StaticResource TitanGlassCardStyle}"/>
        <Style x:Key="ModuleCard" TargetType="{x:Type Border}" BasedOn="{StaticResource TitanGlassCardStyle}"/>

        <Style x:Key="CardStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="#D9141F2A"/>
            <Setter Property="BorderBrush" Value="#2F5165"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="22"/>
            <Setter Property="Padding" Value="22"/>
        </Style>

        <Style x:Key="NavButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Foreground" Value="#ECF7FB"/>
            <Setter Property="Background" Value="#10202B"/>
            <Setter Property="BorderBrush" Value="#315063"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="AccentNavButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource NavButtonStyle}">
            <Setter Property="Foreground" Value="#07131F"/>
            <Setter Property="Background" Value="#F0B862"/>
            <Setter Property="BorderBrush" Value="#FFD166"/>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource NavButtonStyle}">
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0"/>
        </Style>

        <Style x:Key="AccentActionButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Foreground" Value="#07131F"/>
            <Setter Property="Background" Value="#F0B862"/>
            <Setter Property="BorderBrush" Value="#FFD166"/>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Height" Value="46"/>
            <Setter Property="Padding" Value="18,12"/>
            <Setter Property="Foreground" Value="#EDF7FB"/>
            <Setter Property="Background" Value="#101D27"/>
            <Setter Property="BorderBrush" Value="#315266"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                CornerRadius="14"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#162734"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#4B7084"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#19303E"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Background" Value="#3B0F14"/>
            <Setter Property="BorderBrush" Value="#9F3643"/>
            <Setter Property="Foreground" Value="#FFE4E7"/>
        </Style>

        <Style x:Key="GhostButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Background" Value="#0E1921"/>
            <Setter Property="Foreground" Value="#EAF4F8"/>
        </Style>

        <Style x:Key="CalendarNavButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource GhostButtonStyle}">
            <Setter Property="MinWidth" Value="88"/>
        </Style>

        <Style x:Key="FlatCardButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="InputBoxStyle" TargetType="{x:Type TextBox}">
            <Setter Property="Background" Value="#0D1822"/>
            <Setter Property="Foreground" Value="#F6FBFD"/>
            <Setter Property="BorderBrush" Value="#355569"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="CaretBrush" Value="#F6FBFD"/>
            <Setter Property="SelectionBrush" Value="{StaticResource TitanAccentBrush}"/>
            <Setter Property="SelectionOpacity" Value="0.35"/>
            <Setter Property="local:WheelScrollAssist.IsEnabled" Value="True"/>
        </Style>

        <Style x:Key="InputComboBoxStyle" TargetType="{x:Type ComboBox}">
            <Setter Property="Background" Value="#0D1822"/>
            <Setter Property="Foreground" Value="#F6FBFD"/>
            <Setter Property="BorderBrush" Value="#355569"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Height" Value="44"/>
        </Style>

        <Style x:Key="InputDatePickerStyle" TargetType="{x:Type DatePicker}">
            <Setter Property="Background" Value="#0D1822"/>
            <Setter Property="Foreground" Value="#F6FBFD"/>
            <Setter Property="BorderBrush" Value="#355569"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="44"/>
        </Style>

        <Style x:Key="CrmReadableInputBoxStyle" TargetType="{x:Type TextBox}" BasedOn="{StaticResource InputBoxStyle}">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#111111"/>
            <Setter Property="BorderBrush" Value="#C9D4DB"/>
            <Setter Property="CaretBrush" Value="#111111"/>
        </Style>

        <Style x:Key="CrmReadableComboBoxItemStyle" TargetType="{x:Type ComboBoxItem}">
            <Setter Property="Foreground" Value="#111111"/>
            <Setter Property="Background" Value="#FFFFFF"/>
        </Style>

        <Style x:Key="CrmReadableComboBoxStyle" TargetType="{x:Type ComboBox}" BasedOn="{StaticResource InputComboBoxStyle}">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#111111"/>
            <Setter Property="BorderBrush" Value="#C9D4DB"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource CrmReadableComboBoxItemStyle}"/>
        </Style>

        <Style x:Key="CalendarReadableTextBoxStyle" TargetType="{x:Type TextBox}" BasedOn="{StaticResource TitanInputTextBoxStyle}">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#0B1320"/>
            <Setter Property="BorderBrush" Value="#C9D4DB"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="CaretBrush" Value="#0B1320"/>
            <Setter Property="SelectionBrush" Value="#CFEFEA"/>
            <Setter Property="SelectionOpacity" Value="0.85"/>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="Background" Value="#F2FFFC"/>
                    <Setter Property="Foreground" Value="#07131F"/>
                    <Setter Property="BorderBrush" Value="#36BBA9"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LargeTextBoxStyle" TargetType="{x:Type TextBox}" BasedOn="{StaticResource CalendarReadableTextBoxStyle}">
            <Setter Property="Height" Value="108"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="AcceptsReturn" Value="True"/>
            <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="VerticalContentAlignment" Value="Top"/>
            <Setter Property="Padding" Value="14,12"/>
        </Style>

        <Style x:Key="CalendarReadablePasswordBoxStyle" TargetType="{x:Type PasswordBox}" BasedOn="{StaticResource TitanInputPasswordBoxStyle}">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#0B1320"/>
            <Setter Property="BorderBrush" Value="#C9D4DB"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="SelectionBrush" Value="#CFEFEA"/>
            <Setter Property="SelectionOpacity" Value="0.85"/>
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="Background" Value="#F2FFFC"/>
                    <Setter Property="Foreground" Value="#07131F"/>
                    <Setter Property="BorderBrush" Value="#36BBA9"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="TitanReadableDatePickerTextBoxStyle" TargetType="{x:Type DatePickerTextBox}">
            <Setter Property="Foreground" Value="#111111"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#C9D4DB"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CaretBrush" Value="#111111"/>
            <Setter Property="SelectionBrush" Value="{StaticResource TitanAccentBrush}"/>
            <Setter Property="SelectionOpacity" Value="0.35"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="CrmReadableDatePickerTextBoxStyle" TargetType="{x:Type DatePickerTextBox}" BasedOn="{StaticResource TitanReadableDatePickerTextBoxStyle}"/>

        <Style x:Key="TitanReadablePopupCalendarButtonStyle" TargetType="{x:Type CalendarButton}">
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Foreground" Value="#0F1720"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CalendarButton">
                        <Border x:Name="MonthChrome"
                                Padding="10,8"
                                CornerRadius="12"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MonthChrome" Property="Background" Value="#EEF4F7"/>
                                <Setter TargetName="MonthChrome" Property="BorderBrush" Value="#D4E0E7"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="MonthChrome" Property="Background" Value="#E3EDF3"/>
                            </Trigger>
                            <Trigger Property="HasSelectedDays" Value="True">
                                <Setter TargetName="MonthChrome" Property="Background" Value="#E7F8F5"/>
                                <Setter TargetName="MonthChrome" Property="BorderBrush" Value="#70E1D1"/>
                            </Trigger>
                            <Trigger Property="IsInactive" Value="True">
                                <Setter TargetName="MonthChrome" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CrmReadablePopupCalendarButtonStyle" TargetType="{x:Type CalendarButton}" BasedOn="{StaticResource TitanReadablePopupCalendarButtonStyle}"/>

        <Style x:Key="TitanReadablePopupCalendarDayButtonStyle" TargetType="{x:Type CalendarDayButton}">
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Foreground" Value="#0F1720"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CalendarDayButton">
                        <Border x:Name="DayChrome"
                                Margin="2"
                                CornerRadius="12"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1">
                            <Grid>
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                                <Border x:Name="TodayRing"
                                        Margin="4"
                                        CornerRadius="9"
                                        BorderBrush="#70E1D1"
                                        BorderThickness="0"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsInactive" Value="True">
                                <Setter TargetName="DayChrome" Property="Opacity" Value="0.5"/>
                            </Trigger>
                            <Trigger Property="IsBlackedOut" Value="True">
                                <Setter TargetName="DayChrome" Property="Opacity" Value="0.3"/>
                                <Setter TargetName="DayChrome" Property="Background" Value="#EDF2F6"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="DayChrome" Property="Background" Value="#EEF4F7"/>
                                <Setter TargetName="DayChrome" Property="BorderBrush" Value="#D4E0E7"/>
                            </Trigger>
                            <Trigger Property="IsToday" Value="True">
                                <Setter TargetName="TodayRing" Property="BorderThickness" Value="1.5"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="#082531"/>
                                <Setter TargetName="DayChrome" Property="Background" Value="#70E1D1"/>
                                <Setter TargetName="DayChrome" Property="BorderBrush" Value="#36BBA9"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="DayChrome" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CrmReadablePopupCalendarDayButtonStyle" TargetType="{x:Type CalendarDayButton}" BasedOn="{StaticResource TitanReadablePopupCalendarDayButtonStyle}"/>

        <Style x:Key="TitanReadablePopupCalendarItemStyle" TargetType="{x:Type CalendarItem}">
            <Setter Property="Background" Value="#F8FBFD"/>
            <Setter Property="BorderBrush" Value="#D8E3EA"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style x:Key="CrmReadablePopupCalendarItemStyle" TargetType="{x:Type CalendarItem}" BasedOn="{StaticResource TitanReadablePopupCalendarItemStyle}"/>
        <Style x:Key="TitanReadablePopupCalendarStyle" TargetType="{x:Type Calendar}">
            <Setter Property="Background" Value="#F8FBFD"/>
            <Setter Property="BorderBrush" Value="#D8E3EA"/>
            <Setter Property="Foreground" Value="#0F1720"/>
            <Setter Property="CalendarDayButtonStyle" Value="{StaticResource TitanReadablePopupCalendarDayButtonStyle}"/>
            <Setter Property="CalendarButtonStyle" Value="{StaticResource TitanReadablePopupCalendarButtonStyle}"/>
            <Setter Property="CalendarItemStyle" Value="{StaticResource TitanReadablePopupCalendarItemStyle}"/>
            <Style.Resources>
                <Style TargetType="{x:Type Button}">
                    <Setter Property="Foreground" Value="#0F1720"/>
                    <Setter Property="Background" Value="#EEF4F7"/>
                    <Setter Property="BorderBrush" Value="#D7E3EA"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="Padding" Value="10,6"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="ButtonChrome"
                                        CornerRadius="12"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="ButtonChrome" Property="Background" Value="#E6EFF5"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="ButtonChrome" Property="Background" Value="#DCE7EF"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>

                <Style TargetType="{x:Type TextBlock}">
                    <Setter Property="Foreground" Value="#607886"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </Style>
            </Style.Resources>
        </Style>

        <Style x:Key="CrmReadablePopupCalendarStyle" TargetType="{x:Type Calendar}" BasedOn="{StaticResource TitanReadablePopupCalendarStyle}"/>

        <Style x:Key="TitanReadableDatePickerStyle" TargetType="{x:Type DatePicker}" BasedOn="{StaticResource InputDatePickerStyle}">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#111111"/>
            <Setter Property="BorderBrush" Value="#C9D4DB"/>
            <Setter Property="TextElement.Foreground" Value="#111111"/>
            <Setter Property="CalendarStyle" Value="{StaticResource TitanReadablePopupCalendarStyle}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePicker">
                        <Grid SnapsToDevicePixels="True">
                            <Border x:Name="PickerChrome"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="16">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="54"/>
                                    </Grid.ColumnDefinitions>

                                    <DatePickerTextBox x:Name="PART_TextBox"
                                                       Grid.Column="0"
                                                       Margin="14,0,0,0"
                                                       Background="Transparent"
                                                       BorderThickness="0"
                                                       HorizontalContentAlignment="Stretch"
                                                       VerticalContentAlignment="Center"/>

                                    <Button x:Name="PART_Button"
                                            Grid.Column="1"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Cursor="Hand"
                                            Focusable="False">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="DropChrome"
                                                        BorderBrush="#D9E3EA"
                                                        BorderThickness="1,0,0,0"
                                                        Background="#F3F7FA"
                                                        CornerRadius="0,16,16,0">
                                                    <Viewbox Width="18" Height="18" Stretch="Uniform">
                                                        <Path x:Name="DropGlyph"
                                                              Fill="#355569"
                                                              Data="M7,1H5V3H3C1.895,3 1,3.895 1,5V13C1,14.105 1.895,15 3,15H13C14.105,15 15,14.105 15,13V5C15,3.895 14.105,3 13,3H11V1H9V3H7V1ZM3,5H13V7H3V5ZM3,9H6V11H3V9ZM7,9H10V11H7V9ZM11,9H13V11H11V9Z"/>
                                                    </Viewbox>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="DropChrome" Property="Background" Value="#EAF3F7"/>
                                                        <Setter TargetName="DropGlyph" Property="Fill" Value="#173746"/>
                                                    </Trigger>
                                                    <Trigger Property="IsPressed" Value="True">
                                                        <Setter TargetName="DropChrome" Property="Background" Value="#DDEAF0"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </Grid>
                            </Border>

                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   Placement="Bottom"
                                   PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                   PopupAnimation="Fade"
                                   StaysOpen="False">
                                <Border Margin="0,10,0,0"
                                        Padding="16"
                                        Background="#F8FBFD"
                                        BorderBrush="#D8E3EA"
                                        BorderThickness="1"
                                        CornerRadius="20">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="22"
                                                          ShadowDepth="6"
                                                          Color="#2B1B2430"
                                                          Opacity="0.22"/>
                                    </Border.Effect>
                                    <Calendar x:Name="PART_Calendar"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              Style="{TemplateBinding CalendarStyle}"/>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="PickerChrome" Property="Background" Value="#FAFCFD"/>
                                <Setter TargetName="PickerChrome" Property="BorderBrush" Value="#70E1D1"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="PickerChrome" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CrmReadableDatePickerStyle" TargetType="{x:Type DatePicker}" BasedOn="{StaticResource TitanReadableDatePickerStyle}"/>
        <Style x:Key="TitanDataGridBaseStyle" TargetType="{x:Type DataGrid}">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="AlternationCount" Value="2"/>
            <Setter Property="ScrollViewer.CanContentScroll" Value="False"/>
            <Setter Property="local:WheelScrollAssist.IsEnabled" Value="True"/>
        </Style>

        <Style x:Key="TitanReadableDataGridCellStyle" TargetType="{x:Type DataGridCell}">
            <Setter Property="Foreground" Value="#111111"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="TextBlock.Foreground" Value="#111111"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#DCEAF5"/>
                    <Setter Property="Foreground" Value="#111111"/>
                    <Setter Property="TextBlock.Foreground" Value="#111111"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TitanReadableDataGridRowStyle" TargetType="{x:Type DataGridRow}">
            <Setter Property="Foreground" Value="#111111"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#DCEAF5"/>
                    <Setter Property="Foreground" Value="#111111"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TitanReadableDataGridHeaderStyle" TargetType="{x:Type DataGridColumnHeader}">
            <Setter Property="Background" Value="#EEF3F7"/>
            <Setter Property="Foreground" Value="#111111"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#D4DEE6"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="TitanReadableDataGridStyle" TargetType="{x:Type DataGrid}" BasedOn="{StaticResource TitanDataGridBaseStyle}">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#111111"/>
            <Setter Property="BorderBrush" Value="#D4DEE6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="RowBackground" Value="#FFFFFF"/>
            <Setter Property="AlternatingRowBackground" Value="#F6F9FB"/>
            <Setter Property="CellStyle" Value="{StaticResource TitanReadableDataGridCellStyle}"/>
            <Setter Property="RowStyle" Value="{StaticResource TitanReadableDataGridRowStyle}"/>
            <Setter Property="ColumnHeaderStyle" Value="{StaticResource TitanReadableDataGridHeaderStyle}"/>
            <Setter Property="SelectionMode" Value="Single"/>
        </Style>

        <Style x:Key="CrmReadableDataGridCellStyle" TargetType="{x:Type DataGridCell}" BasedOn="{StaticResource TitanReadableDataGridCellStyle}"/>
        <Style x:Key="CrmReadableDataGridRowStyle" TargetType="{x:Type DataGridRow}" BasedOn="{StaticResource TitanReadableDataGridRowStyle}"/>
        <Style x:Key="CrmReadableDataGridHeaderStyle" TargetType="{x:Type DataGridColumnHeader}" BasedOn="{StaticResource TitanReadableDataGridHeaderStyle}"/>
        <Style x:Key="CrmReadableDataGridStyle" TargetType="{x:Type DataGrid}" BasedOn="{StaticResource TitanReadableDataGridStyle}"/>

        <Style x:Key="CalendarReadableDataGridCellStyle" TargetType="{x:Type DataGridCell}" BasedOn="{StaticResource TitanReadableDataGridCellStyle}"/>
        <Style x:Key="CalendarReadableDataGridRowStyle" TargetType="{x:Type DataGridRow}" BasedOn="{StaticResource TitanReadableDataGridRowStyle}"/>
        <Style x:Key="CalendarReadableDataGridHeaderStyle" TargetType="{x:Type DataGridColumnHeader}" BasedOn="{StaticResource TitanReadableDataGridHeaderStyle}"/>
        <Style x:Key="CalendarReadableDataGridStyle" TargetType="{x:Type DataGrid}" BasedOn="{StaticResource TitanReadableDataGridStyle}"/>

        <Style x:Key="TitanDarkDataGridCellStyle" TargetType="{x:Type DataGridCell}">
            <Setter Property="Foreground" Value="#F3F9FC"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="TextBlock.Foreground" Value="#F3F9FC"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#264355"/>
                    <Setter Property="Foreground" Value="#F8FBFD"/>
                    <Setter Property="TextBlock.Foreground" Value="#F8FBFD"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TitanDarkDataGridRowStyle" TargetType="{x:Type DataGridRow}">
            <Setter Property="Foreground" Value="#F3F9FC"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1D3341"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#264355"/>
                    <Setter Property="Foreground" Value="#F8FBFD"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TitanDarkDataGridHeaderStyle" TargetType="{x:Type DataGridColumnHeader}">
            <Setter Property="Background" Value="#172734"/>
            <Setter Property="Foreground" Value="#9FB5C1"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#294960"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="TitanDarkDataGridBaseStyle" TargetType="{x:Type DataGrid}" BasedOn="{StaticResource TitanDataGridBaseStyle}">
            <Setter Property="Background" Value="#00000000"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#F3F9FC"/>
            <Setter Property="CellStyle" Value="{StaticResource TitanDarkDataGridCellStyle}"/>
            <Setter Property="RowStyle" Value="{StaticResource TitanDarkDataGridRowStyle}"/>
            <Setter Property="ColumnHeaderStyle" Value="{StaticResource TitanDarkDataGridHeaderStyle}"/>
            <Setter Property="SelectionMode" Value="Single"/>
        </Style>

        <Style x:Key="TitanDashboardDarkDataGridStyle" TargetType="{x:Type DataGrid}" BasedOn="{StaticResource TitanDarkDataGridBaseStyle}">
            <Setter Property="RowBackground" Value="#12000000"/>
            <Setter Property="AlternatingRowBackground" Value="#1B000000"/>
        </Style>

        <Style x:Key="TitanModuleDarkDataGridStyle" TargetType="{x:Type DataGrid}" BasedOn="{StaticResource TitanDarkDataGridBaseStyle}">
            <Setter Property="RowBackground" Value="#11000000"/>
            <Setter Property="AlternatingRowBackground" Value="#16000000"/>
        </Style>
        <Style TargetType="{x:Type Window}">
            <Setter Property="Icon" Value="{StaticResource TitanWindowIcon}"/>
            <Setter Property="UseLayoutRounding" Value="True"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="FontFamily" Value="{StaticResource TitanShellFontFamily}"/>
        </Style>
    </Application.Resources>
</Application>








