<local:SnapWindow x:Class="Label_CRM_demo.MainWindow"
                  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                  xmlns:local="clr-namespace:Label_CRM_demo"
                  Title="Titan Login"
                  Width="1180"
                  Height="760"
                  MinWidth="880"
                  MinHeight="620"
                  ResizeMode="CanMinimize"
                  WindowStyle="SingleBorderWindow"
                  SizeToContent="Manual"
                  WindowStartupLocation="CenterScreen"
                  WindowState="Maximized"
                  Background="#050816"
                  FontFamily="Segoe UI"
                  Icon="Assets/Titan.ico"
                  UseLayoutRounding="True"
                  SnapsToDevicePixels="True">
    <Grid x:Name="ShellRoot">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#050816" Offset="0.0"/>
                <GradientStop Color="#0B1020" Offset="0.45"/>
                <GradientStop Color="#18284B" Offset="1.0"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Canvas IsHitTestVisible="False">
            <Ellipse Width="520" Height="520" Opacity="0.22">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#70E1D1" Offset="0.0"/>
                        <GradientStop Color="#0070E1D1" Offset="1.0"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
                <Ellipse.Effect>
                    <BlurEffect Radius="150"/>
                </Ellipse.Effect>
                <Ellipse.RenderTransform>
                    <TranslateTransform X="-140" Y="180"/>
                </Ellipse.RenderTransform>
            </Ellipse>

            <Ellipse Width="420" Height="420" Opacity="0.18">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#F59E0B" Offset="0.0"/>
                        <GradientStop Color="#00F59E0B" Offset="1.0"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
                <Ellipse.Effect>
                    <BlurEffect Radius="120"/>
                </Ellipse.Effect>
                <Ellipse.RenderTransform>
                    <TranslateTransform X="980" Y="10"/>
                </Ellipse.RenderTransform>
            </Ellipse>
        </Canvas>

        <Grid Margin="24">
            <ScrollViewer x:Name="ShellScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          CanContentScroll="False">
                <Border CornerRadius="34"
                        Padding="36"
                        Background="#1708111A"
                        BorderBrush="#263B4D"
                        BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="42" ShadowDepth="0" Color="#AA000000" Opacity="0.32"/>
                    </Border.Effect>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Border Padding="18,14"
                                CornerRadius="24"
                                Background="#AA0C1822"
                                BorderBrush="#2B4A61"
                                BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Grid Width="42" Height="42" Margin="0,0,12,0">
                                        <Border CornerRadius="14" Background="#F0B862" BorderBrush="#FFD166" BorderThickness="1"/>
                                        <Border Margin="4" CornerRadius="11" Background="#10212F" BorderBrush="#315165" BorderThickness="1"/>
                                        <Canvas Width="42" Height="42">
                                            <Path Fill="#70E1D1" Data="M9,16 L21,9 L33,16 L21,23 Z"/>
                                            <Rectangle Width="6" Height="18" RadiusX="3" RadiusY="3" Fill="#F8FAFC" Canvas.Left="18" Canvas.Top="14"/>
                                            <Path Fill="#F7C86D" Data="M11,29 L21,24 L31,29 L21,34 Z"/>
                                        </Canvas>
                                    </Grid>

                                    <StackPanel>
                                        <TextBlock Text="Titan"
                                                   Foreground="#F6FBFD"
                                                   FontSize="26"
                                                   FontWeight="Bold"/>
                                        <TextBlock Text="Secure desktop workspace"
                                                   Foreground="#8CCFC7"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"/>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <Border Width="26"
                                            Height="4"
                                            Margin="0,0,12,0"
                                            CornerRadius="2"
                                            Background="#F0B862"/>
                                    <TextBlock Text="Immersive sign-in"
                                               Style="{StaticResource TitanEyebrowTextStyle}"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Grid x:Name="ContentGrid" Grid.Row="1" Margin="0,30,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition x:Name="ContentBottomRow" Height="0"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition x:Name="HeroColumn" Width="1.18*"/>
                                <ColumnDefinition x:Name="LoginColumn" Width="0.92*"/>
                            </Grid.ColumnDefinitions>

                            <Grid x:Name="HeroSection" Grid.Row="0" Grid.Column="0" Margin="10,0,36,0">
                                <StackPanel x:Name="HeroPanel" VerticalAlignment="Center">
                                    <Grid x:Name="LogoMark" Width="172" Height="172" Margin="0,0,0,22" HorizontalAlignment="Left">
                                        <Grid.Effect>
                                            <DropShadowEffect BlurRadius="36" ShadowDepth="0" Color="#AA000000" Opacity="0.55"/>
                                        </Grid.Effect>

                                        <Border CornerRadius="44" BorderBrush="#FFD57A" BorderThickness="1.2">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#F3C76A" Offset="0.0"/>
                                                    <GradientStop Color="#E98A38" Offset="1.0"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                        </Border>

                                        <Border Margin="8" CornerRadius="36" Background="#0E1B27" BorderBrush="#335166" BorderThickness="1"/>
                                        <Ellipse Width="124" Height="124" Stroke="#55FFFFFF" StrokeThickness="2" Opacity="0.45"/>

                                        <Canvas Width="172" Height="172">
                                            <Path Fill="#70E1D1" Data="M30,55 L86,24 L142,55 L86,86 Z"/>
                                            <Rectangle Width="20" Height="66" RadiusX="8" RadiusY="8" Fill="#F7FBFD" Canvas.Left="76" Canvas.Top="46"/>
                                            <Path Fill="#F7C86D" Data="M42,114 L86,90 L130,114 L86,138 Z"/>
                                            <Ellipse Width="16" Height="16" Fill="#F7FBFD" Canvas.Left="110" Canvas.Top="34"/>
                                        </Canvas>
                                    </Grid>

                                    <StackPanel x:Name="HeroCopyPanel" MaxWidth="620">
                                        <StackPanel Orientation="Horizontal"
                                                    HorizontalAlignment="Left">
                                            <Border Width="28"
                                                    Height="4"
                                                    Margin="0,0,12,0"
                                                    CornerRadius="2"
                                                    Background="#70E1D1"
                                                    VerticalAlignment="Center"/>
                                            <TextBlock Text="Local artist operations"
                                                       Style="{StaticResource TitanEyebrowTextStyle}"/>
                                        </StackPanel>

                                        <TextBlock x:Name="HeroTitleText"
                                                   Text="Titan"
                                                   Margin="0,24,0,4"
                                                   FontSize="52"
                                                   FontWeight="Bold"
                                                   Foreground="#F8FAFC"/>

                                        <TextBlock x:Name="HeroSubtitleText"
                                                   Text="Artist CRM workspace"
                                                   Foreground="#7DD7CB"
                                                   FontSize="22"
                                                   FontWeight="SemiBold"/>

                                        <TextBlock x:Name="HeroDescriptionText"
                                                   Text="A polished local CRM workspace with encrypted sign-in, cleaner window orchestration, and a full-screen layout that stays sharp from launch."
                                                   Margin="0,18,0,0"
                                                   TextWrapping="Wrap"
                                                   Foreground="#CBD5E1"
                                                   FontSize="18"
                                                   LineHeight="27"/>
                                    </StackPanel>

                                    <Border x:Name="NotesCard"
                                            Margin="0,32,0,0"
                                            Padding="22"
                                            MaxWidth="620"
                                            Background="#16000000"
                                            BorderBrush="#223047"
                                            BorderThickness="1"
                                            CornerRadius="22">
                                        <Grid x:Name="NotesGrid">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition x:Name="NotesBottomRow" Height="0"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition x:Name="NotesLeftColumn" Width="*"/>
                                                <ColumnDefinition x:Name="NotesRightColumn" Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel x:Name="ChangesPanel" Grid.Row="0" Grid.Column="0" Margin="0,0,12,0">
                                                <TextBlock Text="Platform updates"
                                                           Foreground="#F8FAFC"
                                                           FontWeight="SemiBold"
                                                           FontSize="15"/>
                                                <TextBlock Margin="0,12,0,0"
                                                           Text="- The shell now stays in full-screen mode while still keeping standard minimize and close controls available."
                                                           Foreground="#94A3B8"
                                                           TextWrapping="Wrap"/>
                                                <TextBlock Margin="0,8,0,0"
                                                           Text="- The workspace opens maximized immediately, so the interface feels finished from the first second."
                                                           Foreground="#94A3B8"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>

                                            <StackPanel x:Name="SecurityPanel" Grid.Row="0" Grid.Column="1" Margin="12,0,0,0">
                                                <TextBlock Text="Security posture"
                                                           Foreground="#F8FAFC"
                                                           FontWeight="SemiBold"
                                                           FontSize="15"/>
                                                <TextBlock Margin="0,12,0,0"
                                                           Text="- A credential vault is created on first launch for the current Windows account."
                                                           Foreground="#94A3B8"
                                                           TextWrapping="Wrap"/>
                                                <TextBlock Margin="0,8,0,0"
                                                           Text="- Passwords stay hashed and the local store remains encrypted on disk."
                                                           Foreground="#94A3B8"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <Grid x:Name="LoginSection" Grid.Row="0" Grid.Column="1">
                                <Border x:Name="LoginCard"
                                        MinWidth="0"
                                        MaxWidth="560"
                                        Padding="32"
                                        Background="#CC0F172A"
                                        BorderBrush="#334155"
                                        BorderThickness="1"
                                        CornerRadius="26"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Center">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Border HorizontalAlignment="Left"
                                                Padding="12,6"
                                                CornerRadius="12"
                                                Background="#15334450"
                                                BorderBrush="#3D6478"
                                                BorderThickness="1">
                                            <TextBlock x:Name="AuthBadgeText"
                                                       Text="Encrypted local sign-in"
                                                       Foreground="#E2EDF2"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"/>
                                        </Border>

                                        <TextBlock x:Name="AuthTitleText"
                                                   Grid.Row="1"
                                                   Text="Open Workspace"
                                                   Margin="0,18,0,0"
                                                   Foreground="#F8FAFC"
                                                   FontSize="32"
                                                   FontWeight="Bold"/>

                                        <TextBlock x:Name="AuthDescriptionText"
                                                   Grid.Row="2"
                                                   Margin="0,10,0,0"
                                                   Text="Sign in with your local account to open the Titan dashboard and launch focused workspace windows without losing your place."
                                                   TextWrapping="Wrap"
                                                   Foreground="#94A3B8"
                                                   FontSize="15"
                                                   LineHeight="23"/>

                                        <Grid Grid.Row="3" Margin="0,24,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <Button x:Name="SignInTabButton"
                                                    Height="42"
                                                    Click="ShowSignIn_Click"
                                                    Content="Sign In"
                                                    Background="#1D4ED8"
                                                    Foreground="White"
                                                    BorderBrush="#3B82F6"
                                                    BorderThickness="1"
                                                    FontWeight="SemiBold"/>

                                            <Button x:Name="SignUpTabButton"
                                                    Grid.Column="1"
                                                    Margin="10,0,0,0"
                                                    Height="42"
                                                    Click="ShowSignUp_Click"
                                                    Content="Sign Up"
                                                    Background="#101928"
                                                    Foreground="#CBD5E1"
                                                    BorderBrush="#2A3A66"
                                                    BorderThickness="1"
                                                    FontWeight="SemiBold"/>
                                        </Grid>

                                        <StackPanel x:Name="SignInPanel" Grid.Row="4" Margin="0,22,0,0">
                                            <TextBlock Text="Email or Username"
                                                       Foreground="#CBD5E1"
                                                       FontWeight="SemiBold"/>
                                            <TextBox x:Name="UsernameBox"
                                                     Margin="0,8,0,0"
                                                     Height="42"
                                                     Padding="12,7"
                                                     Background="#0B1226"
                                                     Foreground="#F8FAFC"
                                                     BorderBrush="#2A3A66"
                                                     BorderThickness="1"
                                                     FontSize="15"/>

                                            <TextBlock Margin="0,18,0,8"
                                                       Text="Password"
                                                       Foreground="#CBD5E1"
                                                       FontWeight="SemiBold"/>
                                            <PasswordBox x:Name="PasswordBox"
                                                         Height="42"
                                                         Padding="12,7"
                                                         Background="#0B1226"
                                                         Foreground="#F8FAFC"
                                                         BorderBrush="#2A3A66"
                                                         BorderThickness="1"
                                                         FontSize="15"/>

                                            <TextBlock x:Name="StatusText"
                                                       Margin="0,18,0,0"
                                                       Foreground="#FCA5A5"
                                                       TextWrapping="Wrap"/>

                                            <Button Content="Open Workspace"
                                                    Margin="0,22,0,0"
                                                    Height="46"
                                                    IsDefault="True"
                                                    Click="Submit_Click"
                                                    Background="#1D4ED8"
                                                    Foreground="White"
                                                    BorderBrush="#3B82F6"
                                                    BorderThickness="1"
                                                    FontWeight="SemiBold"/>
                                        </StackPanel>

                                        <StackPanel x:Name="SignUpPanel" Grid.Row="4" Margin="0,22,0,0" Visibility="Collapsed">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <TextBlock Text="First Name"
                                                           Margin="0,0,10,0"
                                                           Foreground="#CBD5E1"
                                                           FontWeight="SemiBold"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="Last Name"
                                                           Margin="10,0,0,0"
                                                           Foreground="#CBD5E1"
                                                           FontWeight="SemiBold"/>

                                                <TextBox x:Name="FirstNameBox"
                                                         Grid.Row="1"
                                                         Margin="0,8,10,0"
                                                         Height="42"
                                                         Padding="12,7"
                                                         Background="#0B1226"
                                                         Foreground="#F8FAFC"
                                                         BorderBrush="#2A3A66"
                                                         BorderThickness="1"
                                                         FontSize="15"/>
                                                <TextBox x:Name="LastNameBox"
                                                         Grid.Row="1"
                                                         Grid.Column="1"
                                                         Margin="10,8,0,0"
                                                         Height="42"
                                                         Padding="12,7"
                                                         Background="#0B1226"
                                                         Foreground="#F8FAFC"
                                                         BorderBrush="#2A3A66"
                                                         BorderThickness="1"
                                                         FontSize="15"/>
                                            </Grid>

                                            <TextBlock Margin="0,18,0,8"
                                                       Text="Phone Number"
                                                       Foreground="#CBD5E1"
                                                       FontWeight="SemiBold"/>
                                            <TextBox x:Name="PhoneNumberBox"
                                                     Height="42"
                                                     Padding="12,7"
                                                     Background="#0B1226"
                                                     Foreground="#F8FAFC"
                                                     BorderBrush="#2A3A66"
                                                     BorderThickness="1"
                                                     FontSize="15"/>

                                            <TextBlock Margin="0,18,0,8"
                                                       Text="Email"
                                                       Foreground="#CBD5E1"
                                                       FontWeight="SemiBold"/>
                                            <TextBox x:Name="EmailBox"
                                                     Height="42"
                                                     Padding="12,7"
                                                     Background="#0B1226"
                                                     Foreground="#F8FAFC"
                                                     BorderBrush="#2A3A66"
                                                     BorderThickness="1"
                                                     FontSize="15"/>

                                            <TextBlock Margin="0,18,0,8"
                                                       Text="Password"
                                                       Foreground="#CBD5E1"
                                                       FontWeight="SemiBold"/>
                                            <PasswordBox x:Name="SignUpPasswordBox"
                                                         Height="42"
                                                         Padding="12,7"
                                                         Background="#0B1226"
                                                         Foreground="#F8FAFC"
                                                         BorderBrush="#2A3A66"
                                                         BorderThickness="1"
                                                         FontSize="15"/>

                                            <TextBlock Margin="0,18,0,8"
                                                       Text="Confirm Password"
                                                       Foreground="#CBD5E1"
                                                       FontWeight="SemiBold"/>
                                            <PasswordBox x:Name="ConfirmPasswordBox"
                                                         Height="42"
                                                         Padding="12,7"
                                                         Background="#0B1226"
                                                         Foreground="#F8FAFC"
                                                         BorderBrush="#2A3A66"
                                                         BorderThickness="1"
                                                         FontSize="15"/>

                                            <Border Margin="0,18,0,0"
                                                    Padding="12"
                                                    Background="#14000000"
                                                    BorderBrush="#223047"
                                                    BorderThickness="1"
                                                    CornerRadius="14">
                                                <StackPanel>
                                                    <TextBlock Text="Testing Note"
                                                               Foreground="#F8FAFC"
                                                               FontWeight="SemiBold"/>
                                                    <TextBlock Margin="0,6,0,0"
                                                               Text="This test account flow writes into the same encrypted local store already used by the app, so you can validate the experience before wiring SQL."
                                                               TextWrapping="Wrap"
                                                               Foreground="#94A3B8"
                                                               FontSize="12"/>
                                                </StackPanel>
                                            </Border>

                                            <TextBlock x:Name="SignUpStatusText"
                                                       Margin="0,18,0,0"
                                                       Foreground="#FCA5A5"
                                                       TextWrapping="Wrap"/>

                                            <Button Content="Create Account"
                                                    Margin="0,22,0,0"
                                                    Height="46"
                                                    Click="CreateAccount_Click"
                                                    Background="#0F766E"
                                                    Foreground="White"
                                                    BorderBrush="#14B8A6"
                                                    BorderThickness="1"
                                                    FontWeight="SemiBold"/>
                                        </StackPanel>

                                        <Border Grid.Row="5"
                                                Margin="0,20,0,0"
                                                Padding="12"
                                                Background="#14000000"
                                                BorderBrush="#223047"
                                                BorderThickness="1"
                                                CornerRadius="14">
                                            <StackPanel>
                                                <TextBlock Text="Credential storage"
                                                           Foreground="#F8FAFC"
                                                           FontWeight="SemiBold"/>
                                                <TextBlock x:Name="StoragePathText"
                                                           Margin="0,6,0,0"
                                                           TextWrapping="Wrap"
                                                           Foreground="#94A3B8"
                                                           FontSize="12"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>
            </ScrollViewer>

            <Grid x:Name="StartupOverlay"
                  Panel.ZIndex="20"
                  Background="#DD07131F">
                <Border x:Name="StartupPanel"
                        Width="400"
                        Padding="30"
                        CornerRadius="28"
                        BorderBrush="#2E5166"
                        BorderThickness="1"
                        Background="#E10E1B27"
                        Opacity="0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <StackPanel HorizontalAlignment="Center">
                        <Grid x:Name="StartupLogo" Width="128" Height="128" Margin="0,0,0,18" HorizontalAlignment="Center">
                            <Grid.Effect>
                                <DropShadowEffect BlurRadius="34" ShadowDepth="0" Color="#AA000000" Opacity="0.55"/>
                            </Grid.Effect>

                            <Border CornerRadius="34" BorderBrush="#FFD57A" BorderThickness="1.2">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#F3C76A" Offset="0.0"/>
                                        <GradientStop Color="#E98A38" Offset="1.0"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>

                            <Border Margin="6" CornerRadius="28" Background="#0E1B27" BorderBrush="#335166" BorderThickness="1"/>
                            <Ellipse Width="92" Height="92" Stroke="#55FFFFFF" StrokeThickness="2" Opacity="0.45"/>

                            <Canvas Width="128" Height="128">
                                <Path Fill="#70E1D1" Data="M23,41 L64,18 L105,41 L64,64 Z"/>
                                <Rectangle Width="16" Height="50" RadiusX="7" RadiusY="7" Fill="#F7FBFD" Canvas.Left="56" Canvas.Top="35"/>
                                <Path Fill="#F7C86D" Data="M31,89 L64,71 L97,89 L64,108 Z"/>
                                <Ellipse Width="14" Height="14" Fill="#F7FBFD" Canvas.Left="82" Canvas.Top="26"/>
                            </Canvas>
                        </Grid>

                        <TextBlock Text="Titan"
                                   Foreground="#F8FAFC"
                                   FontSize="34"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Artist CRM workspace"
                                   Foreground="#7DD7CB"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Margin="0,14,0,0"
                                   Text="Opening your local workspace"
                                   Foreground="#B9CDD7"
                                   FontSize="14"
                                   HorizontalAlignment="Center"/>

                        <Border Margin="0,18,0,0"
                                Width="240"
                                Height="6"
                                CornerRadius="12"
                                Background="#223847">
                            <Border x:Name="StartupPulse"
                                    Width="240"
                                    Height="6"
                                    HorizontalAlignment="Left"
                                    Background="#70E1D1"
                                    CornerRadius="12"
                                    RenderTransformOrigin="0,0.5">
                                <Border.RenderTransform>
                                    <ScaleTransform ScaleX="0.12"/>
                                </Border.RenderTransform>
                            </Border>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</local:SnapWindow>




