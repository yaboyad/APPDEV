<Window x:Class="Label_CRM_demo.Window2"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Titan Dashboard"
        MinHeight="760"
        MinWidth="1240"
        WindowState="Maximized"
        Background="#07131F"
        FontFamily="Segoe UI"
        Loaded="Window_Loaded"
        Icon="Assets/Titan.ico">
    <Window.Resources>
        <LinearGradientBrush x:Key="ShellBackground" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#07131F" Offset="0.0"/>
            <GradientStop Color="#0B1824" Offset="0.38"/>
            <GradientStop Color="#14313F" Offset="1.0"/>
        </LinearGradientBrush>

        <Style x:Key="GlassCard" TargetType="Border">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#D9172531" Offset="0.0"/>
                        <GradientStop Color="#C90E1821" Offset="1.0"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush" Value="#2B4859"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="22"/>
            <Setter Property="Padding" Value="22"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="28" ShadowDepth="0" Color="#96000000" Opacity="0.34"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#EDF7FB"/>
            <Setter Property="Background" Value="#101D27"/>
            <Setter Property="BorderBrush" Value="#2B4758"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="18,14"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                CornerRadius="18"
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <ContentPresenter VerticalAlignment="Center"/>

                                <Path x:Name="Chevron"
                                      Grid.Column="1"
                                      Margin="16,0,0,0"
                                      Width="10"
                                      Height="10"
                                      Stretch="Uniform"
                                      Data="M2,1 L7,5 L2,9"
                                      Stroke="{TemplateBinding Foreground}"
                                      StrokeThickness="1.6"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Opacity="0.62"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#162734"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#4B7084"/>
                                <Setter TargetName="Chevron" Property="Opacity" Value="1"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#19303E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentButtonStyle" TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
            <Setter Property="Foreground" Value="#07131F"/>
            <Setter Property="Background" Value="#F0B862"/>
            <Setter Property="BorderBrush" Value="#FFD166"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#00000000"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="AlternationCount" Value="2"/>
            <Setter Property="RowBackground" Value="#11000000"/>
            <Setter Property="AlternatingRowBackground" Value="#18000000"/>
            <Setter Property="Foreground" Value="#F3F9FC"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#172734"/>
            <Setter Property="Foreground" Value="#9FB5C1"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#294960"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource ShellBackground}">
        <Canvas IsHitTestVisible="False">
            <Ellipse Width="520" Height="520" Opacity="0.24">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#4FD1C5" Offset="0.0"/>
                        <GradientStop Color="#004FD1C5" Offset="1.0"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
                <Ellipse.Effect>
                    <BlurEffect Radius="120"/>
                </Ellipse.Effect>
                <Ellipse.RenderTransform>
                    <TranslateTransform X="-160" Y="120"/>
                </Ellipse.RenderTransform>
                <Ellipse.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" From="-160" To="-20" Duration="0:0:12"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="120" To="20" Duration="0:0:9"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Ellipse.Triggers>
            </Ellipse>

            <Ellipse Width="480" Height="480" Opacity="0.2">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#F59E0B" Offset="0.0"/>
                        <GradientStop Color="#00F59E0B" Offset="1.0"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
                <Ellipse.Effect>
                    <BlurEffect Radius="130"/>
                </Ellipse.Effect>
                <Ellipse.RenderTransform>
                    <TranslateTransform X="980" Y="-90"/>
                </Ellipse.RenderTransform>
                <Ellipse.Triggers>
                    <EventTrigger RoutedEvent="Loaded">
                        <BeginStoryboard>
                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" From="980" To="860" Duration="0:0:11"/>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="-90" To="40" Duration="0:0:13"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Ellipse.Triggers>
            </Ellipse>
        </Canvas>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Margin="18,18,18,0"
                    Padding="20,16"
                    CornerRadius="22"
                    Background="#B10B1620"
                    BorderBrush="#2B4A5A"
                    BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Grid Width="42" Height="42" Margin="0,0,12,0">
                            <Border CornerRadius="14" Background="#F0B862" BorderBrush="#FFD166" BorderThickness="1"/>
                            <Border Margin="4" CornerRadius="11" Background="#10212F" BorderBrush="#315165" BorderThickness="1"/>
                            <Canvas Width="42" Height="42">
                                <Path Fill="#70E1D1" Data="M9,16 L21,9 L33,16 L21,23 Z"/>
                                <Rectangle Width="6" Height="18" RadiusX="3" RadiusY="3" Fill="#F8FAFC" Canvas.Left="18" Canvas.Top="14"/>
                                <Path Fill="#F7C86D" Data="M11,29 L21,24 L31,29 L21,34 Z"/>
                            </Canvas>
                        </Grid>

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Titan"
                                       Foreground="#F6FBFD"
                                       FontSize="28"
                                       FontWeight="Bold"/>
                            <TextBlock Text="Artist CRM workspace"
                                       Foreground="#8CCFC7"
                                       FontSize="12"
                                       FontWeight="SemiBold"/>
                        </StackPanel>

                        <Border Width="1" Height="20" Margin="18,0,16,0" Background="#315164"/>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="26" Height="4" Margin="0,0,12,0" CornerRadius="2" Background="#70E1D1"/>
                            <TextBlock Text="Central dashboard"
                                       Style="{StaticResource TitanEyebrowTextStyle}"/>
                        </StackPanel>

                        <Border Width="1" Height="20" Margin="16,0,14,0" Background="#315164"/>

                        <TextBlock x:Name="ClockText"
                                   Foreground="#D7E5EC"
                                   FontWeight="SemiBold"
                                   FontSize="14"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <StackPanel Margin="0,0,16,0" VerticalAlignment="Center">
                            <TextBlock Text="Signed in"
                                       Style="{StaticResource TitanEyebrowTextStyle}"
                                       HorizontalAlignment="Right"/>
                            <TextBlock x:Name="UserNameText"
                                       Foreground="#F6FBFD"
                                       FontWeight="SemiBold"
                                       FontSize="15"
                                       HorizontalAlignment="Right"/>
                        </StackPanel>

                        <Button x:Name="LogoutButton"
                                Content="Log Out"
                                Click="Logout_Click"
                                Style="{StaticResource AccentButtonStyle}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border x:Name="SidebarPanel" Grid.Column="0" Style="{StaticResource GlassCard}" Margin="0,0,20,0">
                    <StackPanel>
                        <TextBlock Text="Workspace hub"
                                   Style="{StaticResource TitanSectionTitleTextStyle}"/>
                        <TextBlock Margin="0,8,0,18"
                                   Text="Keep your overview anchored here while focused windows open alongside it for billing, contracts, scheduling, and communication."
                                   Style="{StaticResource TitanMutedBodyTextStyle}"/>

                        <Button x:Name="OverviewButton" Click="Nav_Overview_Click" Style="{StaticResource NavButtonStyle}">
                            <TextBlock Text="Overview" FontWeight="SemiBold"/>
                        </Button>
                        <Button x:Name="AccountButton" Click="Nav_Account_Click" Style="{StaticResource NavButtonStyle}">
                            <TextBlock Text="Account workspace" FontWeight="SemiBold"/>
                        </Button>
                        <Button x:Name="PaymentsButton" Click="Nav_Payments_Click" Style="{StaticResource NavButtonStyle}">
                            <TextBlock Text="Payments workspace" FontWeight="SemiBold"/>
                        </Button>
                        <Button x:Name="ContractsButton" Click="Nav_Contracts_Click" Style="{StaticResource NavButtonStyle}">
                            <TextBlock Text="Contracts workspace" FontWeight="SemiBold"/>
                        </Button>
                        <Button x:Name="CalendarButton" Click="Nav_Calendar_Click" Style="{StaticResource NavButtonStyle}">
                            <TextBlock Text="Calendar workspace" FontWeight="SemiBold"/>
                        </Button>
                        <Button x:Name="SmsButton" Click="Nav_SMSManager_Click" Style="{StaticResource NavButtonStyle}">
                            <TextBlock Text="SMS manager" FontWeight="SemiBold"/>
                        </Button>
                        <Button x:Name="EmailButton" Click="Nav_EmailManager_Click" Style="{StaticResource NavButtonStyle}">
                            <TextBlock Text="Email manager" FontWeight="SemiBold"/>
                        </Button>

                        <Border x:Name="StoreCard"
                                Margin="0,18,0,0"
                                Padding="18"
                                CornerRadius="18"
                                Background="#101A23"
                                BorderBrush="#315063"
                                BorderThickness="1">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="24" Height="4" Margin="0,0,10,0" CornerRadius="2" Background="#F0B862" VerticalAlignment="Center"/>
                                    <TextBlock Text="Protected local store"
                                               Style="{StaticResource TitanEyebrowTextStyle}"/>
                                </StackPanel>
                                <TextBlock x:Name="StorageText"
                                           Margin="0,12,0,0"
                                           Foreground="#A8BFCA"
                                           FontSize="12"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <ScrollViewer Grid.Column="1" x:Name="DashboardScrollViewer" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.35*"/>
                                <ColumnDefinition Width="0.85*"/>
                            </Grid.ColumnDefinitions>

                            <Border x:Name="HeroCard" Style="{StaticResource GlassCard}" Margin="0,0,18,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                        <Border Width="28" Height="4" Margin="0,0,12,0" CornerRadius="2" Background="#70E1D1" VerticalAlignment="Center"/>
                                        <TextBlock Text="Live control center"
                                                   Style="{StaticResource TitanEyebrowTextStyle}"/>
                                    </StackPanel>

                                    <TextBlock x:Name="WelcomeText"
                                               Grid.Row="1"
                                               Margin="0,20,0,0"
                                               Foreground="#F6FBFD"
                                               FontSize="38"
                                               FontWeight="Bold"
                                               TextWrapping="Wrap"/>

                                    <TextBlock Grid.Row="2"
                                               Margin="0,14,0,0"
                                               Text="Track the day from here, then launch focused workspaces for payments, contracts, scheduling, and communications without losing context."
                                               Foreground="#BAD0DA"
                                               FontSize="16"
                                               TextWrapping="Wrap"
                                               LineHeight="25"/>
                                </Grid>
                            </Border>

                            <Border x:Name="LaunchCard" Grid.Column="1" Style="{StaticResource GlassCard}">
                                <StackPanel>
                                    <TextBlock Text="Quick launch"
                                               Style="{StaticResource TitanSectionTitleTextStyle}"/>
                                    <TextBlock Margin="0,8,0,16"
                                               Text="Open the workspaces you touch most and keep the dashboard right where it is."
                                               Style="{StaticResource TitanMutedBodyTextStyle}"/>

                                    <Button x:Name="OpenPaymentsButton"
                                            Content="Launch payments"
                                            Click="AddPayment_Click"
                                            Style="{StaticResource AccentButtonStyle}"/>
                                    <Button x:Name="OpenContractsButton"
                                            Content="Launch contracts"
                                            Click="CreateContract_Click"
                                            Style="{StaticResource NavButtonStyle}"/>
                                    <Button x:Name="OpenSmsButton"
                                            Content="Launch SMS manager"
                                            Click="NewContact_Click"
                                            Style="{StaticResource NavButtonStyle}"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <UniformGrid Margin="0,18,0,0" Columns="4">
                            <Border x:Name="AccountCard" Style="{StaticResource GlassCard}" Margin="0,0,14,14">
                                <StackPanel>
                                    <TextBlock Text="Account status" Style="{StaticResource TitanMetricLabelTextStyle}"/>
                                    <TextBlock x:Name="AccountStatusText" Margin="0,10,0,0" Foreground="#F6FBFD" FontSize="28" FontWeight="Bold"/>
                                    <TextBlock Margin="0,10,0,0" Text="Protected local access" Style="{StaticResource TitanMutedBodyTextStyle}"/>
                                </StackPanel>
                            </Border>

                            <Border x:Name="PaymentMetricCard" Style="{StaticResource GlassCard}" Margin="0,0,14,14">
                                <StackPanel>
                                    <TextBlock Text="Next payment" Style="{StaticResource TitanMetricLabelTextStyle}"/>
                                    <TextBlock x:Name="NextPaymentText" Margin="0,10,0,0" Foreground="#F6FBFD" FontSize="28" FontWeight="Bold"/>
                                    <TextBlock x:Name="NextPaymentDateText" Margin="0,10,0,0" Style="{StaticResource TitanMutedBodyTextStyle}"/>
                                </StackPanel>
                            </Border>

                            <Border x:Name="RevenueCard" Style="{StaticResource GlassCard}" Margin="0,0,14,14">
                                <StackPanel>
                                    <TextBlock Text="Revenue (MTD)" Style="{StaticResource TitanMetricLabelTextStyle}"/>
                                    <TextBlock x:Name="RevenueText" Margin="0,10,0,0" Foreground="#F6FBFD" FontSize="28" FontWeight="Bold"/>
                                    <TextBlock Margin="0,10,0,0" Text="Current month snapshot" Style="{StaticResource TitanMutedBodyTextStyle}"/>
                                </StackPanel>
                            </Border>

                            <Border x:Name="TasksCard" Style="{StaticResource GlassCard}" Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Text="Open tasks" Style="{StaticResource TitanMetricLabelTextStyle}"/>
                                    <TextBlock x:Name="TasksText" Margin="0,10,0,0" Foreground="#F6FBFD" FontSize="28" FontWeight="Bold"/>
                                    <TextBlock Margin="0,10,0,0" Text="Priority follow-ups this week" Style="{StaticResource TitanMutedBodyTextStyle}"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border x:Name="PaymentsSection" Grid.Column="0" Style="{StaticResource GlassCard}" Margin="0,0,14,0">
                                <StackPanel>
                                    <TextBlock Text="Recent payments"
                                               Style="{StaticResource TitanSectionTitleTextStyle}"/>
                                    <TextBlock Margin="0,8,0,14"
                                               Text="Your latest charge history, ready at a glance."
                                               Style="{StaticResource TitanMutedBodyTextStyle}"/>
                                    <DataGrid x:Name="PaymentsGrid">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Date" Binding="{Binding Date}" Width="*"/>
                                            <DataGridTextColumn Header="Amount" Binding="{Binding Amount}" Width="*"/>
                                            <DataGridTextColumn Header="Method" Binding="{Binding Method}" Width="*"/>
                                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Border>

                            <Border x:Name="CalendarSection" Grid.Column="1" Style="{StaticResource GlassCard}">
                                <StackPanel>
                                    <TextBlock Text="Upcoming calendar"
                                               Style="{StaticResource TitanSectionTitleTextStyle}"/>
                                    <TextBlock Margin="0,8,0,14"
                                               Text="Next calls, reminders, and billing checkpoints."
                                               Style="{StaticResource TitanMutedBodyTextStyle}"/>
                                    <DataGrid x:Name="CalendarGrid">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Date" Binding="{Binding Date}" Width="*"/>
                                            <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="2*"/>
                                            <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <Border x:Name="ActivitySection" Margin="0,18,0,0" Style="{StaticResource GlassCard}">
                            <StackPanel>
                                <TextBlock Text="Recent activity"
                                           Style="{StaticResource TitanSectionTitleTextStyle}"/>
                                <TextBlock Margin="0,8,0,14"
                                           Text="A clean pulse of what moved across the core workspaces."
                                           Style="{StaticResource TitanMutedBodyTextStyle}"/>
                                <DataGrid x:Name="ActivityGrid">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Workspace" Binding="{Binding Workspace}" Width="*"/>
                                        <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="2*"/>
                                        <DataGridTextColumn Header="Owner" Binding="{Binding Owner}" Width="*"/>
                                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <Border Grid.Row="2"
                    Margin="18,0,18,18"
                    Padding="14,12"
                    CornerRadius="18"
                    Background="#880C1822"
                    BorderBrush="#2B4A61"
                    BorderThickness="1">
                <TextBlock Text="Titan keeps your overview anchored while focused workspaces open beside it, so the main shell never drops out of view."
                           Foreground="#92AAB8"
                           HorizontalAlignment="Center"/>
            </Border>
        </Grid>
    </Grid>
</Window>
