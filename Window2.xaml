                    <Grid Margin="0,18,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="1.2*"/><ColumnDefinition Width="0.8*"/></Grid.ColumnDefinitions><Border x:Name="SupportSection" Margin="0,0,14,0" Style="{StaticResource CardStyle}"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><StackPanel><TextBlock Text="Support center" Foreground="#F6FBFD" FontSize="22" FontWeight="Bold"/><TextBlock x:Name="SupportIntroText" Margin="0,8,0,0" Foreground="#AFC4CF" TextWrapping="Wrap" Text="Send support requests or review the full inbox depending on your account tier."/></StackPanel><StackPanel x:Name="UserSupportFormPanel" Grid.Row="1" Margin="0,18,0,0"><Border Padding="16" CornerRadius="18" Background="#101A23" BorderBrush="#315063" BorderThickness="1"><StackPanel><TextBlock Text="User submission access" Foreground="#F0B862" FontWeight="SemiBold"/><TextBlock Margin="0,10,0,0" Foreground="#D8E7ED" TextWrapping="Wrap" Text="User accounts can only submit support requests. Saved submissions are reviewed from the master account inbox."/></StackPanel></Border><Border x:Name="SupportComposerCard" Margin="0,14,0,0" Padding="18" CornerRadius="18" Background="#101A23" BorderBrush="#315063" BorderThickness="1"><StackPanel><TextBlock Text="Send a message" Foreground="#F0B862" FontWeight="SemiBold"/><TextBox x:Name="SupportComposerTextBox" Margin="0,14,0,0" Height="120" AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top" VerticalScrollBarVisibility="Auto" Style="{StaticResource InputBoxStyle}"/><StackPanel Margin="0,14,0,0" Orientation="Horizontal"><Button x:Name="SendSupportButton" Width="150" Content="Send message" Click="SendSupportMessage_Click" Style="{StaticResource AccentActionButtonStyle}"/><Button x:Name="ClearSupportButton" Width="110" Margin="12,0,0,0" Content="Clear" Click="ClearSupportMessage_Click" Style="{StaticResource ActionButtonStyle}"/></StackPanel><TextBlock x:Name="SupportStatusText" Margin="0,14,0,0" Foreground="#A9C0CA" TextWrapping="Wrap"/></StackPanel></Border></StackPanel><StackPanel x:Name="MasterSupportInboxPanel" Grid.Row="1" Margin="0,18,0,0" Visibility="Collapsed"><DataGrid x:Name="SupportSubmissionsGrid" Height="250" SelectionChanged="SupportSubmissionsGrid_SelectionChanged" Style="{StaticResource TitanDashboardDarkDataGridStyle}"/><Border Margin="0,14,0,0" Padding="18" CornerRadius="18" Background="#101A23" BorderBrush="#315063" BorderThickness="1"><StackPanel><TextBlock x:Name="SelectedSupportSubmissionMetaText" Foreground="#F6FBFD" FontSize="16" FontWeight="Bold" TextWrapping="Wrap"/><TextBlock x:Name="SelectedSupportSubmissionBodyText" Margin="0,12,0,0" Foreground="#D8E7ED" TextWrapping="Wrap" LineHeight="22"/></StackPanel></Border></StackPanel></Grid></Border><Border x:Name="SupportSummaryCard" Grid.Column="1" Style="{StaticResource CardStyle}"><Grid><StackPanel x:Name="UserSupportSidebarPanel"><TextBlock Text="Submission helpers" Foreground="#F6FBFD" FontSize="22" FontWeight="Bold"/><TextBlock Margin="0,8,0,16" Foreground="#AFC4CF" TextWrapping="Wrap" Text="Pick a quick prompt or write your own note. Every request routes to the master support inbox."/><Button x:Name="BillingPromptButton" Margin="0,0,0,10" Content="Need billing help" Tag="I need help with billing, invoices, or a recent payment." Click="SupportQuickPrompt_Click" Style="{StaticResource ActionButtonStyle}"/><Button x:Name="AccessPromptButton" Margin="0,0,0,10" Content="Access issue" Tag="I cannot sign in or access the right account on this device." Click="SupportQuickPrompt_Click" Style="{StaticResource ActionButtonStyle}"/><Button x:Name="CalendarPromptButton" Margin="0,0,0,10" Content="Calendar conflict" Tag="I need help with a scheduled task, reminder, or calendar conflict." Click="SupportQuickPrompt_Click" Style="{StaticResource ActionButtonStyle}"/><Button x:Name="ContractsPromptButton" Margin="0,0,0,10" Content="Contract question" Tag="I need support with a contract, agreement, or split setup." Click="SupportQuickPrompt_Click" Style="{StaticResource ActionButtonStyle}"/><Button x:Name="LaunchPromptButton" Content="Urgent launch help" Tag="Urgent: I need help with a launch, post, or release workflow right now." Click="SupportQuickPrompt_Click" Style="{StaticResource AccentActionButtonStyle}"/></StackPanel><StackPanel x:Name="MasterSupportSidebarPanel" Visibility="Collapsed"><TextBlock x:Name="SupportCoverageText"/><TextBlock x:Name="SupportThreadStateText"/><TextBlock x:Name="SupportLastReplyText"/><TextBlock x:Name="SupportRoutingText"/><TextBlock x:Name="SupportMessageCountText"/><TextBlock x:Name="SupportStoragePathText"/></StackPanel></Grid></Border></Grid>

                    <Border x:Name="ActivitySection" Margin="0,18,0,0" Style="{StaticResource CardStyle}"><StackPanel><TextBlock Text="Recent activity" Foreground="#F6FBFD" FontSize="22" FontWeight="Bold"/><TextBlock Margin="0,8,0,14" Text="A clean pulse of what moved across the CRM workspaces, campaign lanes, and support inbox." Foreground="#AFC4CF" TextWrapping="Wrap"/><DataGrid x:Name="ActivityGrid" Style="{StaticResource TitanDashboardDarkDataGridStyle}"><DataGrid.Columns><DataGridTextColumn Header="Workspace" Binding="{Binding Workspace}" Width="*"/><DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="2*"/><DataGridTextColumn Header="Owner" Binding="{Binding Owner}" Width="*"/><DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*"/></DataGrid.Columns></DataGrid></StackPanel></Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Border Grid.Row="2" Margin="18,0,18,18" Padding="14,12" Style="{StaticResource CardStyle}"><TextBlock Text="Titan keeps your overview anchored while contacts, contracts, campaign calendars, outreach tracking, social data watchlists, and the support inbox stay available beside it." Foreground="#92AAB8" HorizontalAlignment="Center" TextWrapping="Wrap"/></Border>
    </Grid>
</Window>
