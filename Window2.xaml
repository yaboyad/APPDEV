                    <Grid Margin="0,18,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Border x:Name="TextCampaignsSection" Margin="0,0,14,0" Style="{StaticResource CardStyle}"><StackPanel><TextBlock Text="Text campaigns" Foreground="#F6FBFD" FontSize="22" FontWeight="Bold"/><TextBlock Margin="0,8,0,10" Foreground="#AFC4CF" TextWrapping="Wrap" Text="Queue text outreach, choose a send window, and let scheduled sends appear on the calendar automatically."/><TextBlock x:Name="TextCampaignStatusText" Foreground="#A9C0CA" TextWrapping="Wrap"/><Grid Margin="0,16,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><StackPanel Margin="0,0,10,0"><TextBlock Text="Campaign name" Foreground="#9FB7C3" FontWeight="SemiBold"/><TextBox x:Name="TextCampaignNameBox" Style="{StaticResource CrmReadableInputBoxStyle}" Margin="0,8,0,0"/><TextBlock Margin="0,16,0,0" Text="Audience or list" Foreground="#9FB7C3" FontWeight="SemiBold"/><TextBox x:Name="TextAudienceBox" Style="{StaticResource CrmReadableInputBoxStyle}" Margin="0,8,0,0"/><TextBlock Margin="0,16,0,0" Text="Send window" Foreground="#9FB7C3" FontWeight="SemiBold"/><ComboBox x:Name="TextSendWindowBox" Style="{StaticResource CrmReadableComboBoxStyle}" Margin="0,8,0,0" SelectedIndex="0"><ComboBoxItem Content="Morning"/><ComboBoxItem Content="Midday"/><ComboBoxItem Content="Afternoon"/><ComboBoxItem Content="Evening"/></ComboBox><CheckBox x:Name="TextAutomationCheckBox" Margin="0,18,0,0" IsChecked="True" Content="Automate this text campaign" Foreground="#D8E7ED"/></StackPanel><StackPanel Grid.Column="1" Margin="10,0,0,0"><TextBlock Text="Scheduled date" Foreground="#9FB7C3" FontWeight="SemiBold"/><DatePicker x:Name="TextScheduledDatePicker" Style="{StaticResource CrmReadableDatePickerStyle}" Margin="0,8,0,0"><DatePicker.Resources><Style TargetType="DatePickerTextBox" BasedOn="{StaticResource CrmReadableDatePickerTextBoxStyle}"/></DatePicker.Resources></DatePicker><TextBlock Margin="0,16,0,0" Text="Status" Foreground="#9FB7C3" FontWeight="SemiBold"/><ComboBox x:Name="TextCampaignStateBox" Style="{StaticResource CrmReadableComboBoxStyle}" Margin="0,8,0,0" SelectedIndex="0"><ComboBoxItem Content="Draft"/><ComboBoxItem Content="Scheduled"/><ComboBoxItem Content="Queued"/><ComboBoxItem Content="Sent"/><ComboBoxItem Content="Paused"/></ComboBox><TextBlock Margin="0,16,0,0" Text="Message" Foreground="#9FB7C3" FontWeight="SemiBold"/><TextBox x:Name="TextMessageBox" Height="92" AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top" VerticalScrollBarVisibility="Auto" Style="{StaticResource CrmReadableInputBoxStyle}" Margin="0,8,0,0"/><TextBlock Margin="0,16,0,0" Text="Notes" Foreground="#9FB7C3" FontWeight="SemiBold"/><TextBox x:Name="TextCampaignNotesBox" Height="72" AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top" VerticalScrollBarVisibility="Auto" Style="{StaticResource CrmReadableInputBoxStyle}" Margin="0,8,0,0"/></StackPanel></Grid><StackPanel Margin="0,16,0,0" Orientation="Horizontal"><Button x:Name="SaveTextCampaignButton" Width="156" Content="Save text campaign" Click="SaveTextCampaign_Click" Style="{StaticResource AccentActionButtonStyle}"/><Button x:Name="ResetTextCampaignButton" Width="116" Margin="10,0,0,0" Content="Clear" Click="ResetTextCampaign_Click" Style="{StaticResource ActionButtonStyle}"/></StackPanel><TextBlock Margin="0,18,0,14" Text="Select an existing text campaign below to edit it." Foreground="#AFC4CF" TextWrapping="Wrap"/><DataGrid x:Name="TextCampaignsGrid" Height="230" SelectionChanged="TextCampaignsGrid_SelectionChanged" Style="{StaticResource CrmReadableDataGridStyle}"><DataGrid.Columns><DataGridTextColumn Header="Campaign" Binding="{Binding CampaignName}" Width="1.2*"/><DataGridTextColumn Header="Audience" Binding="{Binding Audience}" Width="*"/><DataGridTextColumn Header="Window" Binding="{Binding SendWindow}" Width="*"/><DataGridTextColumn Header="Scheduled" Binding="{Binding ScheduledDate, StringFormat={}{0:MMM dd, yyyy}}" Width="*"/><DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*"/><DataGridCheckBoxColumn Header="Auto" Binding="{Binding AutomationEnabled}" Width="72"/></DataGrid.Columns></DataGrid></StackPanel></Border><Border x:Name="EmailCampaignsSection" Grid.Column="1" Style="{StaticResource CardStyle}"><StackPanel><TextBlock Text="Email campaigns" Foreground="#F6FBFD" FontSize="22" FontWeight="Bold"/><TextBlock Margin="0,8,0,10" Foreground="#AFC4CF" TextWrapping="Wrap" Text="Manage launch emails, subject lines, and scheduled sends without losing sight of the rest of the CRM."/><TextBlock x:Name="EmailCampaignStatusText" Foreground="#A9C0CA" TextWrapping="Wrap"/><Grid Margin="0,16,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><StackPanel Margin="0,0,10,0"><TextBlock Text="Campaign name" Foreground="#9FB7C3" FontWeight="SemiBold"/><TextBox x:Name="EmailCampaignNameBox" Style="{StaticResource CrmReadableInputBoxStyle}" Margin="0,8,0,0"/><TextBlock Margin="0,16,0,0" Text="Audience or list" Foreground="#9FB7C3" FontWeight="SemiBold"/><TextBox x:Name="EmailAudienceBox" Style="{StaticResource CrmReadableInputBoxStyle}" Margin="0,8,0,0"/><TextBlock Margin="0,16,0,0" Text="Subject line" Foreground="#9FB7C3" FontWeight="SemiBold"/><TextBox x:Name="EmailSubjectBox" Style="{StaticResource CrmReadableInputBoxStyle}" Margin="0,8,0,0"/><CheckBox x:Name="EmailAutomationCheckBox" Margin="0,18,0,0" IsChecked="True" Content="Automate this email campaign" Foreground="#D8E7ED"/></StackPanel><StackPanel Grid.Column="1" Margin="10,0,0,0"><TextBlock Text="Scheduled date" Foreground="#9FB7C3" FontWeight="SemiBold"/><DatePicker x:Name="EmailScheduledDatePicker" Style="{StaticResource CrmReadableDatePickerStyle}" Margin="0,8,0,0"><DatePicker.Resources><Style TargetType="DatePickerTextBox" BasedOn="{StaticResource CrmReadableDatePickerTextBoxStyle}"/></DatePicker.Resources></DatePicker><TextBlock Margin="0,16,0,0" Text="Send window" Foreground="#9FB7C3" FontWeight="SemiBold"/><ComboBox x:Name="EmailSendWindowBox" Style="{StaticResource CrmReadableComboBoxStyle}" Margin="0,8,0,0" SelectedIndex="0"><ComboBoxItem Content="Morning"/><ComboBoxItem Content="Midday"/><ComboBoxItem Content="Afternoon"/><ComboBoxItem Content="Evening"/></ComboBox><TextBlock Margin="0,16,0,0" Text="Status" Foreground="#9FB7C3" FontWeight="SemiBold"/><ComboBox x:Name="EmailCampaignStateBox" Style="{StaticResource CrmReadableComboBoxStyle}" Margin="0,8,0,0" SelectedIndex="0"><ComboBoxItem Content="Draft"/><ComboBoxItem Content="Scheduled"/><ComboBoxItem Content="Queued"/><ComboBoxItem Content="Sent"/><ComboBoxItem Content="Paused"/></ComboBox><TextBlock Margin="0,16,0,0" Text="Email copy" Foreground="#9FB7C3" FontWeight="SemiBold"/><TextBox x:Name="EmailMessageBox" Height="92" AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top" VerticalScrollBarVisibility="Auto" Style="{StaticResource CrmReadableInputBoxStyle}" Margin="0,8,0,0"/><TextBlock Margin="0,16,0,0" Text="Notes" Foreground="#9FB7C3" FontWeight="SemiBold"/><TextBox x:Name="EmailCampaignNotesBox" Height="72" AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top" VerticalScrollBarVisibility="Auto" Style="{StaticResource CrmReadableInputBoxStyle}" Margin="0,8,0,0"/></StackPanel></Grid><StackPanel Margin="0,16,0,0" Orientation="Horizontal"><Button x:Name="SaveEmailCampaignButton" Width="160" Content="Save email campaign" Click="SaveEmailCampaign_Click" Style="{StaticResource AccentActionButtonStyle}"/><Button x:Name="ResetEmailCampaignButton" Width="116" Margin="10,0,0,0" Content="Clear" Click="ResetEmailCampaign_Click" Style="{StaticResource ActionButtonStyle}"/></StackPanel><TextBlock Margin="0,18,0,14" Text="Select an existing email campaign below to edit it." Foreground="#AFC4CF" TextWrapping="Wrap"/><DataGrid x:Name="EmailCampaignsGrid" Height="230" SelectionChanged="EmailCampaignsGrid_SelectionChanged" Style="{StaticResource CrmReadableDataGridStyle}"><DataGrid.Columns><DataGridTextColumn Header="Campaign" Binding="{Binding CampaignName}" Width="1.1*"/><DataGridTextColumn Header="Audience" Binding="{Binding Audience}" Width="*"/><DataGridTextColumn Header="Subject" Binding="{Binding SubjectLine}" Width="1.2*"/><DataGridTextColumn Header="Scheduled" Binding="{Binding ScheduledDate, StringFormat={}{0:MMM dd, yyyy}}" Width="*"/><DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*"/><DataGridCheckBoxColumn Header="Auto" Binding="{Binding AutomationEnabled}" Width="72"/></DataGrid.Columns></DataGrid></StackPanel></Border></Grid>

                    <Border x:Name="OutreachTrackerSection" Margin="0,18,0,0" Style="{StaticResource CardStyle}"><StackPanel><TextBlock Text="Outreach tracker" Foreground="#F6FBFD" FontSize="22" FontWeight="Bold"/><TextBlock Margin="0,8,0,14" Foreground="#AFC4CF" TextWrapping="Wrap" Text="Track every scheduled text and email campaign in one place so your send plan, automation state, and next touch are easy to review."/><UniformGrid Columns="4"><Border Margin="0,0,10,12" Padding="14" CornerRadius="16" Background="#101A23" BorderBrush="#315063" BorderThickness="1"><StackPanel><TextBlock Text="Scheduled" Foreground="#9FB7C3" FontWeight="SemiBold"/><TextBlock x:Name="OutreachScheduledCountText" Margin="0,10,0,0" Foreground="#F6FBFD" FontSize="20" FontWeight="Bold"/></StackPanel></Border><Border Margin="0,0,10,12" Padding="14" CornerRadius="16" Background="#101A23" BorderBrush="#315063" BorderThickness="1"><StackPanel><TextBlock Text="Automated" Foreground="#9FB7C3" FontWeight="SemiBold"/><TextBlock x:Name="OutreachAutomationCountText" Margin="0,10,0,0" Foreground="#F6FBFD" FontSize="20" FontWeight="Bold"/></StackPanel></Border><Border Margin="0,0,10,12" Padding="14" CornerRadius="16" Background="#101A23" BorderBrush="#315063" BorderThickness="1"><StackPanel><TextBlock Text="Sent" Foreground="#9FB7C3" FontWeight="SemiBold"/><TextBlock x:Name="OutreachSentCountText" Margin="0,10,0,0" Foreground="#F6FBFD" FontSize="20" FontWeight="Bold"/></StackPanel></Border><Border Margin="0,0,0,12" Padding="14" CornerRadius="16" Background="#101A23" BorderBrush="#315063" BorderThickness="1"><StackPanel><TextBlock Text="Next send" Foreground="#9FB7C3" FontWeight="SemiBold"/><TextBlock x:Name="OutreachNextTouchText" Margin="0,10,0,0" Foreground="#F6FBFD" FontSize="20" FontWeight="Bold" TextWrapping="Wrap"/></StackPanel></Border></UniformGrid><DataGrid x:Name="OutreachGrid" Height="230" IsReadOnly="True" Style="{StaticResource TitanDashboardDarkDataGridStyle}"><DataGrid.Columns><DataGridTe