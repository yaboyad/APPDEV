<Window x:Class="Label_CRM_demo.Window2"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Label_CRM_demo"
        Title="Titan Dashboard"
        MinHeight="760"
        MinWidth="1180"
        WindowState="Maximized"
        Background="{StaticResource TitanWindowFallbackBrush}"
        FontFamily="Segoe UI"
        Loaded="Window_Loaded"
        Icon="Assets/Titan.ico">
    <Grid Background="{StaticResource TitanShellBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="18,18,18,0" Padding="18,14" Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Titan" Foreground="{StaticResource TitanTextPrimaryBrush}" FontSize="28" FontWeight="Bold"/>
                    <Border Width="1" Height="20" Margin="16,0,16,0" Background="{StaticResource TitanPanelBorderBrush}"/>
                    <TextBlock Text="Artist CRM workspace" Foreground="{StaticResource TitanAccentBrush}" FontWeight="SemiBold"/>
                    <Border Width="1" Height="20" Margin="16,0,16,0" Background="{StaticResource TitanPanelBorderBrush}"/>
                    <TextBlock Text="Central dashboard" Foreground="{StaticResource TitanTextSecondaryBrush}" FontWeight="SemiBold"/>
                    <Border Width="1" Height="20" Margin="16,0,16,0" Background="{StaticResource TitanPanelBorderBrush}"/>
                    <TextBlock x:Name="CurrentDateText" Foreground="{StaticResource TitanTextSecondaryBrush}" FontWeight="SemiBold"/>
                    <Border Width="1" Height="20" Margin="16,0,16,0" Background="{StaticResource TitanPanelBorderBrush}"/>
                    <TextBlock x:Name="ClockText" Foreground="{StaticResource TitanTextPrimaryBrush}" FontWeight="SemiBold"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="ThemeToggleButton" Content="Theme" Click="ThemeToggle_Click" Style="{StaticResource ThemeToggleButtonStyle}" Margin="0,0,14,0"/>
                    <StackPanel Margin="0,0,14,0" MaxWidth="260">
                        <TextBlock Text="Signed in" Foreground="#8CCFC7" FontSize="12" HorizontalAlignment="Right"/>
                        <TextBlock x:Name="UserNameText" Foreground="#F6FBFD" FontWeight="SemiBold" HorizontalAlignment="Right" TextWrapping="Wrap" TextAlignment="Right"/>
                    </StackPanel>
                    <Button x:Name="LogoutButton" Content="Log Out" Click="Logout_Click" Style="{StaticResource AccentNavButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="18">
            <Grid.ColumnDefinitions><ColumnDefinition Width="280"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>

            <Border x:Name="SidebarPanel" Grid.Column="0" Margin="0,0,18,0" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Workspace hub" Foreground="#F6FBFD" FontSize="22" FontWeight="Bold"/>
                    <TextBlock Margin="0,8,0,18" Text="Keep your overview anchored while contacts, campaigns, contracts, support, and platform data stay one click away." Foreground="#AFC4CF" TextWrapping="Wrap"/>
                    <Button x:Name="OverviewButton" Click="Nav_Overview_Click" Style="{StaticResource NavButtonStyle}" Content="Overview"/>
                    <Button x:Name="AccountButton" Click="Nav_Account_Click" Style="{StaticResource NavButtonStyle}" Content="Account workspace"/>
                    <Button x:Name="AccountsAdminButton" Click="Nav_AccountsAdmin_Click" Style="{StaticResource NavButtonStyle}" Content="All accounts manager" Visibility="Collapsed"/>
                    <Button x:Name="PaymentsButton" Click="Nav_Payments_Click" Style="{StaticResource NavButtonStyle}" Content="Payments workspace"/>
                    <Button x:Name="ContactsButton" Click="Nav_Contacts_Click" Style="{StaticResource NavButtonStyle}" Content="Contacts"/>
                    <Button x:Name="ContractsButton" Click="Nav_Contracts_Click" Style="{StaticResource NavButtonStyle}" Content="Contracts"/>
                    <Button x:Name="CalendarButton" Click="Nav_Calendar_Click" Style="{StaticResource NavButtonStyle}" Content="Calendar"/>
                    <Button x:Name="SmsButton" Click="Nav_TextCampaigns_Click" Style="{StaticResource NavButtonStyle}" Content="Text campaigns"/>
                    <Button x:Name="EmailButton" Click="Nav_EmailCampaigns_Click" Style="{StaticResource NavButtonStyle}" Content="Email campaigns"/>
                    <Button x:Name="DataButton" Click="Nav_Data_Click" Style="{StaticResource NavButtonStyle}" Content="Data watch"/>
                    <Button x:Name="OutreachButton" Click="Nav_Outreach_Click" Style="{StaticResource NavButtonStyle}" Content="Outreach tracker"/>
                    <Button x:Name="SupportButton" Click="Nav_Support_Click" Style="{StaticResource NavButtonStyle}" Content="Support center"/>
                    <Border x:Name="StoreCard" Margin="0,16,0,0" Padding="16" CornerRadius="18" Background="{StaticResource TitanPanelBrush}" BorderBrush="{StaticResource TitanPanelBorderBrush}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Local workspace stores" Foreground="{StaticResource TitanAccentWarmBrush}" FontSize="12" FontWeight="SemiBold"/>
                            <TextBlock x:Name="StorageText" Margin="0,10,0,0" Foreground="{StaticResource TitanTextSecondaryBrush}" FontSize="12" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <ScrollViewer Grid.Column="1" x:Name="DashboardScrollViewer" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="1.25*"/><ColumnDefinition Width="0.85*"/></Grid.ColumnDefinitions>
                        <Border x:Name="HeroCard" Margin="0,0,18,0" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Live control center" Foreground="{StaticResource TitanAccentBrush}" FontWeight="SemiBold"/>
                                <TextBlock x:Name="WelcomeText" Margin="0,18,0,0" Foreground="{StaticResource TitanTextPrimaryBrush}" FontSize="36" FontWeight="Bold" TextWrapping="Wrap"/>
                                <TextBlock Margin="0,14,0,0" Foreground="{StaticResource TitanTextSecondaryBrush}" TextWrapping="Wrap" LineHeight="24" Text="Track contacts, contracts, text campaigns, email campaigns, the calendar, and your outreach tracking from one place."/>
                            </StackPanel>
                        </Border>
                        <Border x:Name="LaunchCard" Grid.Column="1" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Quick launch" Foreground="{StaticResource TitanTextPrimaryBrush}" FontSize="22" FontWeight="Bold"/>
                                <TextBlock Margin="0,8,0,16" Foreground="{StaticResource TitanTextSecondaryBrush}" TextWrapping="Wrap" Text="Jump into payments, contacts, campaigns, data watch, and support without losing your place."/>
                                <Button x:Name="OpenPaymentsButton" Content="Launch payments" Click="AddPayment_Click" Style="{StaticResource AccentActionButtonStyle}"/>
                                <Button x:Name="OpenContractsButton" Margin="0,10,0,0" Content="Open contracts" Click="CreateContract_Click" Style="{StaticResource ActionButtonStyle}"/>
                                <Button x:Name="OpenContactsButton" Margin="0,10,0,0" Content="Open contacts" Click="OpenContactsDashboard_Click" Style="{StaticResource ActionButtonStyle}"/>
                                <Button x:Name="OpenSmsButton" Margin="0,10,0,0" Content="Open text campaigns" Click="OpenTextCampaigns_Click" Style="{StaticResource ActionButtonStyle}"/>
                                <Button x:Name="OpenEmailButton" Margin="0,10,0,0" Content="Open email campaigns" Click="OpenEmailCampaigns_Click" Style="{StaticResource ActionButtonStyle}"/>
                                <Button x:Name="OpenDataButton" Margin="0,10,0,0" Content="Open data watch" Click="OpenDataWatch_Click" Style="{StaticResource ActionButtonStyle}"/>
                                <Button x:Name="OpenSupportButton" Margin="0,10,0,0" Content="Open support center" Click="OpenSupportCenter_Click" Style="{StaticResource ActionButtonStyle}"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <UniformGrid Margin="0,18,0,0" Columns="4">
                        <Border x:Name="AccountCard" Margin="0,0,14,14" Style="{StaticResource CardStyle}"><StackPanel><TextBlock Text="Account status" Foreground="#9FB7C3" FontWeight="SemiBold"/><TextBlock x:Name="AccountStatusText" Margin="0,10,0,0" Foreground="#F6FBFD" FontSize="28" FontWeight="Bold"/></StackPanel></Border>
                        <Border x:Name="PaymentMetricCard" Margin="0,0,14,14" Style="{StaticResource CardStyle}"><StackPanel><TextBlock Text="Next payment" Foreground="#9FB7C3" FontWeight="SemiBold"/><TextBlock x:Name="NextPaymentText" Margin="0,10,0,0" Foreground="#F6FBFD" FontSize="28" FontWeight="Bold"/><TextBlock x:Name="NextPaymentDateText" Margin="0,10,0,0" Foreground="#AFC4CF"/></StackPanel></Border>
                        <Border x:Name="RevenueCard" Margin="0,0,14,14" Style="{StaticResource CardStyle}"><StackPanel><TextBlock Text="Active contracts" Foreground="#9FB7C3" FontWeight="SemiBold"/><TextBlock x:Name="RevenueText" Margin="0,10,0,0" Foreground="#F6FBFD" FontSize="28" FontWeight="Bold"/></StackPanel></Border>
                        <Border x:Name="TasksCard" Margin="0,0,0,14" Style="{StaticResource CardStyle}"><StackPanel><TextBlock Text="Outreach this week" Foreground="#9FB7C3" FontWeight="SemiBold"/><TextBlock x:Name="TasksText" Margin="0,10,0,0" Foreground="#F6FBFD" FontSize="28" FontWeight="Bold"/></StackPanel></Border>
                    </UniformGrid>                    <Grid x:Name="AccountsManagementHost" Margin="0,18,0,0" Visibility="Collapsed">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="1.2*"/><ColumnDefinition Width="0.8*"/></Grid.ColumnDefinitions>
                        <Border x:Name="AccountsManagementSection" Margin="0,0,14,0" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="All accounts manager" Foreground="#F6FBFD" FontSize="22" FontWeight="Bold"/>
                                <TextBlock x:Name="AccountsStatusText" Margin="0,8,0,10" Foreground="#AFC4CF" TextWrapping="Wrap" Text="Review access across every saved account, then ban or restore users from one place."/>
                                <Grid Margin="0,16,0,0">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="1.35*"/><ColumnDefinition Width="0.95*"/></Grid.ColumnDefinitions>
                                    <DataGrid x:Name="AccountsGrid" Height="220" AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True" SelectionChanged="AccountsGrid_SelectionChanged" Style="{StaticResource TitanDashboardDarkDataGridStyle}">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Account" Binding="{Binding DisplayName}" Width="1.15*"/>
                                            <DataGridTextColumn Header="Username" Binding="{Binding Username}" Width="*"/>
                                            <DataGridTextColumn Header="Tier" Binding="{Binding TierLabel}" Width="0.72*"/>
                                            <DataGridTextColumn Header="Contact" Binding="{Binding ContactLabel}" Width="1.2*"/>
                                            <DataGridTextColumn Header="Access" Binding="{Binding AccessStatus}" Width="0.72*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                    <Border Grid.Column="1" Margin="14,0,0,0" Padding="18" CornerRadius="18" Background="#101A23" BorderBrush="#315063" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="Selected account" Foreground="#9FB7C3" FontWeight="SemiBold"/>
                                            <TextBlock x:Name="SelectedAccountNameText" Margin="0,10,0,0" Foreground="#F6FBFD" FontSize="20" FontWeight="Bold" TextWrapping="Wrap"/>
                                            <TextBlock x:Name="SelectedAccountMetaText" Margin="0,10,0,0" Foreground="#D8E7ED" TextWrapping="Wrap"/>
                                            <TextBlock x:Name="SelectedAccountAccessText" Margin="0,12,0,0" Foreground="#8EE7AF" FontSize="16" FontWeight="Bold" TextWrapping="Wrap"/>
                                            <TextBlock x:Name="SelectedAccountNotesText" Margin="0,10,0,0" Foreground="#9FB7C3" TextWrapping="Wrap"/>
                                            <StackPanel Margin="0,18,0,0" Orientation="Horizontal"><Button x:Name="BanAccountButton" Width="118" Content="Ban account" Click="BanAccount_Click" Style="{StaticResource AccentActionButtonStyle}"/><Button x:Name="RestoreAccountButton" Width="126" Margin="10,0,0,0" Content="Restore access" Click="RestoreAccount_Click" Style="{StaticResource ActionButtonStyle}"/></StackPanel>
                                            <Button x:Name="RefreshAccountsButton" Margin="0,12,0,0" Content="Refresh accounts" Click="RefreshAccounts_Click" Style="{StaticResource ActionButtonStyle}"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>
                        <Border x:Name="AccountsSummaryCard" Grid.Column="1" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Account snapshot" Foreground="#F6FBFD" FontSize="22" FontWeight="Bold"/>
                                <TextBlock Margin="0,8,0,0" Foreground="#AFC4CF" TextWrapping="Wrap" Text="A quick read on who can sign in, who is blocked, and how many protected master accounts exist locally."/>
                                <TextBlock x:Name="ManagedAccountsCountText" Margin="0,14,0,0" Foreground="#F6FBFD" FontSize="18" FontWeight="Bold" Text="Accounts on this device: 0"/>
                                <TextBlock x:Name="ActiveAccountsCountText" Margin="0,10,0,0" Foreground="#F6FBFD" FontSize="18" FontWeight="Bold" Text="Active sign-ins: 0"/>
                                <TextBlock x:Name="BannedAccountsCountText" Margin="0,10,0,0" Foreground="#F6FBFD" FontSize="18" FontWeight="Bold" Text="Blocked accounts: 0"/>
                                <TextBlock x:Name="ProtectedAccountsCountText" Margin="0,10,0,0" Foreground="#F6FBFD" FontSize="18" FontWeight="Bold" Text="Protected master accounts: 0"/>
                                <Border Margin="0,16,0,0" Padding="14" CornerRadius="16" Background="#101A23" BorderBrush="#315063" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="Credential store" Foreground="#9FB7C3" FontWeight="SemiBold"/>
                                        <TextBlock x:Name="AccountsStorePathText" Margin="0,10,0,0" Foreground="#D8E7ED" FontSize="12" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>
                    <Grid Margin="0,18,0,0">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Border x:Name="PaymentsSection" Grid.Column="0" Margin="0,0,14,0" Style="{StaticResource CardStyle}"><StackPanel><TextBlock Text="Recent payments" Foreground="#F6FBFD" FontSize="22" FontWeight="Bold"/><TextBlock Margin="0,8,0,14" Text="Your latest charge history, ready at a glance." Foreground="#AFC4CF"/><DataGrid x:Name="PaymentsGrid" Style="{StaticResource TitanDashboardDarkDataGridStyle}"><DataGrid.Columns><DataGridTextColumn Header="Date" Binding="{Binding Date}" Width="*"/><DataGridTextColumn Header="Amount" Binding="{Binding Amount}" Width="*"/><DataGridTextColumn Header="Method" Binding="{Binding Method}" Width="*"/><DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*"/></DataGrid.Columns></DataGrid></StackPanel></Border>
                        <Border x:Name="CalendarSection" Grid.Column="1" Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Calendar overview" Style="{StaticResource TitanEyebrowTextStyle}"/><TextBlock Margin="0,14,0,0" Text="Upcoming calendar" Foreground="#F6FBFD" FontSize="24" FontWeight="Bold"/><TextBlock Margin="0,8,0,0" Text="Contact follow-ups, contract reminders, and scheduled campaigns now read like a real agenda." Foreground="#AFC4CF" TextWrapping="Wrap"/></StackPanel><StackPanel Grid.Column="1"><Border Padding="14,8" CornerRadius="12" Background="#10202B" BorderBrush="#315063" BorderThickness="1"><TextBlock Text="{Binding ElementName=CalendarGrid, Path=Items.Count, StringFormat={}{0} upcoming}" Foreground="#EAF4F8" FontSize="12" FontWeight="SemiBold"/></Border><Button Margin="0,12,0,0" Padding="18,10" Content="Open sync center" Click="OpenCalendarSyncCenter_Click" Style="{StaticResource TitanPrimaryButtonStyle}"/></StackPanel></Grid>
                                <Border Grid.Row="1" MinHeight="320" Margin="0,20,0,0" Padding="14" CornerRadius="20" Background="#F8FBFD" BorderBrush="#D7E2EA" BorderThickness="1"><ScrollViewer VerticalScrollBarVisibility="Auto" local:WheelScrollAssist.IsEnabled="True"><ItemsControl x:Name="CalendarGrid"><ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel><ItemsControl.ItemTemplate><DataTemplate><Border Margin="0,0,0,12" Padding="18" Background="#FFFFFF" BorderBrush="#D9E5EC" BorderThickness="1" CornerRadius="18"><StackPanel><TextBlock Text="{Binding Title}" Foreground="#0F1720" FontSize="17" FontWeight="Bold" TextWrapping="Wrap"/><TextBlock Margin="0,6,0,0" Foreground="#4F6673"><Run Text="{Binding Start, StringFormat={}{0:dddd, MMM d}}"/><Run Text=" at "/><Run Text="{Binding Start, StringFormat={}{0:h:mm tt}}"/></TextBlock><TextBlock Margin="0,4,0,0" Text="{Binding Category}" Foreground="#0D6156" FontWeight="SemiBold"/><TextBlock Margin="0,4,0,0" Text="{Binding SyncTargetsDisplay}" Foreground="#5D7280"/></StackPanel></Border></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></ScrollViewer></Border>
                            </Grid>
                        </Border>
                    </Grid>

                    <Grid Margin="0,18,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="1.2*"/><ColumnDefinition Width="0.8*"/></Grid.ColumnDefinitions><Border x:Name="DataSection" Margin="0,0,14,0" Style="{StaticResource CardStyle}"><StackPanel><TextBlock Text="Data watch" Foreground="#F6FBFD" FontSize="22" FontWeight="Bold"/><TextBlock Margin="0,8,0,14" Foreground="#AFC4CF" TextWrapping="Wrap" Text="Keep the most important social and audience APIs in one watchlist so campaign and release checks are always nearby."/><DataGrid x:Name="DataWatchGrid" Height="250" IsReadOnly="True" Style="{StaticResource TitanDashboardDarkDataGridStyle}"/></StackPanel></Border><Border x:Name="DataInsightCard" Grid.Column="1" Style="{StaticResource CardStyle}"><StackPanel><TextBlock Text="What to watch" Foreground="#F6FBFD" FontSize="22" FontWeight="Bold"/><TextBlock Margin="0,8,0,16" Foreground="#AFC4CF" TextWrapping="Wrap" Text="Audience health, momentum, and mention spikes tell you when outreach should accelerate."/><Button Margin="0,16,0,0" Content="Open data workspace" Click="OpenDataWatch_Click" Style="{StaticResource AccentActionButtonStyle}"/></StackPanel></Border></Grid>

                    <Grid Margin="0,18,0,0"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><Border x:Name="ContactsSection" Margin="0,0,0,18" Style="{StaticResource CardStyle}"><StackPanel><TextBlock Text="Contacts" Foreground="#F6FBFD" FontSize="22" FontWeight="Bold"/><TextBlock Margin="0,8,0,10" Foreground="#AFC4CF" TextWrapping="Wrap" Text="Add and edit contacts here, then use the follow-up date to feed the local calendar automatically."/><TextBlock x:Name="ContactStatusText" Foreground="#A9C0CA" TextWrapping="Wrap"/><Grid Margin="0,16,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><StackPanel Margin="0,0,10,0"><TextBlock Text="Full name" Foreground="#9FB7C3" FontWeight="SemiBold"/><TextBox x:Name="ContactNameBox" Style="{StaticResource CrmReadableInputBoxStyle}" Margin="0,8,0,0"/><TextBlock Margin="0,16,0,0" Text="Company" Foreground="#9FB7C3" FontWeight="SemiBold"/><TextBox x:Name="ContactCompanyBox" Style="{StaticResource CrmReadableInputBoxStyle}" Margin="0,8,0,0"/><TextBlock Margin="0,16,0,0" Text="Phone number" Foreground="#9FB7C3" FontWeight="SemiBold"/><TextBox x:Name="ContactPhoneBox" Style="{StaticResource CrmReadableInputBoxStyle}" Margin="0,8,0,0"/></StackPanel><StackPanel Grid.Column="1" Margin="10,0,0,0"><TextBlock Text="Email" Foreground="#9FB7C3" FontWeight="SemiBold"/><TextBox x:Name="ContactEmailBox" Style="{StaticResource CrmReadableInputBoxStyle}" Margin="0,8,0,0"/><TextBlock Margin="0,16,0,0" Text="Next follow-up" Foreground="#9FB7C3" FontWeight="SemiBold"/><DatePicker x:Name="ContactFollowUpPicker" Style="{StaticResource CrmReadableDatePickerStyle}" Margin="0,8,0,0"><DatePicker.Resources><Style TargetType="DatePickerTextBox" BasedOn="{StaticResource CrmReadableDatePickerTextBoxStyle}"/></DatePicker.Resources></DatePicker><TextBlock Margin="0,16,0,0" Text="Notes" Foreground="#9FB7C3" FontWeight="SemiBold"/><TextBox x:Name="ContactNotesBox" Height="92" AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top" VerticalScrollBarVisibility="Auto" Style="{StaticResource CrmReadableInputBoxStyle}" Margin="0,8,0,0"/></StackPanel></Grid><StackPanel Margin="0,16,0,0" Orientation="Horizontal"><Button x:Name="SaveContactButton" Width="138" Content="Save contact" Click="SaveContact_Click" Style="{StaticResource AccentActionButtonStyle}"/><Button x:Name="ResetContactButton" Width="116" Margin="10,0,0,0" Content="Clear" Click="ResetContact_Click" Style="{StaticResource ActionButtonStyle}"/></StackPanel><TextBlock Margin="0,18,0,14" Text="Select an existing contact below to edit it." Foreground="#AFC4CF" TextWrapping="Wrap"/><DataGrid x:Name="ContactsGrid" Height="240" SelectionChanged="ContactsGrid_SelectionChanged" Style="{StaticResource CrmReadableDataGridStyle}"><DataGrid.Columns><DataGridTextColumn Header="Name" Binding="{Binding FullName}" Width="1.2*"/><DataGridTextColumn Header="Company" Binding="{Binding Company}" Width="*"/><DataGridTextColumn Header="Phone" Binding="{Binding PhoneNumber}" Width="*"/><DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="1.2*"/><DataGridTextColumn Header="Follow-up" Binding="{Binding FollowUpDate, StringFormat={}{0:MMM dd, yyyy}}" Width="*"/></DataGrid.Columns></DataGrid></StackPanel></Border><Border x:Name="ContractsManagerSection" Grid.Row="1" Style="{StaticResource CardStyle}"><StackPanel><TextBlock Text="Contracts" Foreground="#F6FBFD" FontSize="22" FontWeight="Bold"/><TextBlock Margin="0,8,0,10" Foreground="#AFC4CF" TextWrapping="Wrap" Text="Store agreements locally, edit them in place, and send start dates and reminders into the calendar system."/><TextBlock x:Name="ContractStatusText" Foreground="#A9C0CA" TextWrapping="Wrap"/><Grid Margin="0,16,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><StackPanel Margin="0,0,10,0"><TextBlock Text="Contract title" Foreground="#9FB7C3" FontWeight="SemiBold"/><TextBox x:Name="ContractTitleBox" Style="{StaticResource CrmReadableInputBoxStyle}" Margin="0,8,0,0"/><TextBlock Margin="0,16,0,0" Text="Client" Foreground="#9FB7C3" FontWeight="SemiBold"/><TextBox x:Name="ContractClientBox" Style="{StaticResource CrmReadableInputBoxStyle}" Margin="0,8,0,0"/><TextBlock Margin="0,16,0,0" Text="Contract type" Foreground="#9FB7C3" FontWeight="SemiBold"/><ComboBox x:Name="ContractTypeBox" Style="{StaticResource CrmReadableComboBoxStyle}" Margin="0,8,0,0" SelectedIndex="0"><ComboBoxItem Content="Management"/><ComboBoxItem Content="Distribution"/><ComboBoxItem Content="Release"/><ComboBoxItem Content="Split Sheet"/><ComboBoxItem Content="Service Agreement"/><ComboBoxItem Content="Other"/></ComboBox></StackPanel><StackPanel Grid.Column="1" Margin="10,0,0,0"><TextBlock Text="Status" Foreground="#9FB7C3" FontWeight="SemiBold"/><ComboBox x:Name="ContractStateBox" Style="{StaticResource CrmReadableComboBoxStyle}" Margin="0,8,0,0" SelectedIndex="0"><ComboBoxItem Content="Draft"/><ComboBoxItem Content="Pending"/><ComboBoxItem Content="Active"/><ComboBoxItem Content="Expiring"/><ComboBoxItem Content="Closed"/></ComboBox><TextBlock Margin="0,16,0,0" Text="Start date" Foreground="#9FB7C3" FontWeight="SemiBold"/><DatePicker x:Name="ContractStartPicker" Style="{StaticResource CrmReadableDatePickerStyle}" Margin="0,8,0,0"><DatePicker.Resources><Style TargetType="DatePickerTextBox" BasedOn="{StaticResource CrmReadableDatePickerTextBoxStyle}"/></DatePicker.Resources></DatePicker><TextBlock Margin="0,16,0,0" Text="Reminder date" Foreground="#9FB7C3" FontWeight="SemiBold"/><DatePicker x:Name="ContractReminderPicker" Style="{StaticResource CrmReadableDatePickerStyle}" Margin="0,8,0,0"><DatePicker.Resources><Style TargetType="DatePickerTextBox" BasedOn="{StaticResource CrmReadableDatePickerTextBoxStyle}"/></DatePicker.Resources></DatePicker><TextBlock Margin="0,16,0,0" Text="Notes" Foreground="#9FB7C3" FontWeight="SemiBold"/><TextBox x:Name="ContractNotesBox" Height="92" AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top" VerticalScrollBarVisibility="Auto" Style="{StaticResource CrmReadableInputBoxStyle}" Margin="0,8,0,0"/></StackPanel></Grid><StackPanel Margin="0,16,0,0" Orientation="Horizontal"><Button x:Name="SaveContractButton" Width="138" Content="Save contract" Click="SaveContract_Click" Style="{StaticResource AccentActionButtonStyle}"/><Button x:Name="ResetContractButton" Width="116" Margin="10,0,0,0" Content="Clear" Click="ResetContract_Click" Style="{StaticResource ActionButtonStyle}"/></StackPanel><TextBlock Margin="0,18,0,14" Text="Select an existing contract below to edit it." Foreground="#AFC4CF" TextWrapping="Wrap"/><DataGrid x:Name="ContractsGrid" Height="240" SelectionChanged="ContractsGrid_SelectionChanged" Style="{StaticResource CrmReadableDataGridStyle}"><DataGrid.Columns><DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="1.25*"/><DataGridTextColumn Header="Client" Binding="{Binding ClientName}" Width="*"/><DataGridTextColumn Header="Type" Binding="{Binding ContractType}" Width="*"/><DataGridTextColumn Header="Start" Binding="{Binding StartDate, StringFormat={}{0:MMM dd, yyyy}}" Width="*"/><DataGridTextColumn Header="Reminder" Binding="{Binding ReminderDate, StringFormat={}{0:MMM dd, yyyy}}" Width="*"/><DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*"/></DataGrid.Columns></DataGrid></StackPanel></Border></Grid>

