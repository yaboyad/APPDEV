                    <Grid Margin="0,18,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="1.2*"/><ColumnDefinition Width="0.8*"/></Grid.ColumnDefinitions><Border x:Name="SupportSection" Margin="0,0,14,0" Style="{StaticResource CardStyle}"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><StackPanel><TextBlock Text="Support center" Foreground="#F6FBFD" FontSize="22" FontWeight="Bold"/><TextBlock x:Name="SupportIntroText" Margin="0,8,0,0" Foreground="#AFC4CF" TextWrapping="Wrap" Text="Send support requests or review the full inbox depending on your account tier."/></StackPanel><StackPanel x:Name="UserSupportFormPanel" Grid.Row="1" Margin="0,18,0,0"><Border Padding="16" CornerRadius="18" Background="#101A23" BorderBrush="#315063" BorderThickness="1"><StackPanel><TextBlock Text="User submission access" Foreground="#F0B862" FontWeight="SemiBold"/><TextBlock Margin="0,10,0,0" Foreground="#D8E7ED" TextWrapping="Wrap" Text="User accounts can only submit support requests. Saved submissions are reviewed from the master account inbox."/></StackPanel></Border><Border x:Name="SupportComposerCard" Margin="0,14,0,0" Padding="18" CornerRadius="18" Background="#101A23" BorderBrush="#315063" BorderThickness="1"><StackPanel><TextBlock Text="Send a message" Foreground="#F0B862" FontWeight="SemiBold"/><TextBox x:Name="SupportComposerTextBox" Margin="0,14,0,0" Height="120" AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top" VerticalScrollBarVisibility="Auto" Style="{StaticResource InputBoxStyle}"/><StackPanel Margin="0,14,0,0" Orientation="Horizontal"><Button x:Name="SendSupportButton" Width="150" Content="Send message" Click="SendSupportMessage_Click" Style="{StaticResource AccentActionButtonStyle}"/><Button x:Name="ClearSupportButton" Width="110" Margin="12,0,0,0" Content="Clear" Click="ClearSupportMessage_Click" Style="{StaticResource ActionButtonStyle}"/></StackPanel><TextBlock x:Name="SupportStatusTex