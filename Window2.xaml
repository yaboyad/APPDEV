<Window x:Class="Label_CRM_demo.Window2"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GHL Titan - Dashboard"
        Height="580" Width="1040"
        WindowStartupLocation="CenterScreen"
        Background="#FF0B1020"
        Loaded="Window_Loaded">

    <Window.Resources>

        <!-- Brushes -->
        <LinearGradientBrush x:Key="AppBg" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FF050816" Offset="0.0"/>
            <GradientStop Color="#FF0B1020" Offset="0.35"/>
            <GradientStop Color="#FF121B36" Offset="1.0"/>
        </LinearGradientBrush>

        <SolidColorBrush x:Key="CardBg" Color="#CC0F172A"/>
        <SolidColorBrush x:Key="CardBorder" Color="#334155"/>
        <SolidColorBrush x:Key="TextMain" Color="#E5E7EB"/>
        <SolidColorBrush x:Key="TextMuted" Color="#94A3B8"/>
        <SolidColorBrush x:Key="Accent" Color="#A78BFA"/>

        <!-- Buttons -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="Background" Value="#FF0B1226"/>
            <Setter Property="BorderBrush" Value="#223047"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10">
                            <ContentPresenter Margin="2"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF141B33"/>
                                <Setter Property="BorderBrush" Value="#3B82F6"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FF0E1630"/>
                                <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionButton" TargetType="Button" BasedOn="{StaticResource NavButton}">
            <Setter Property="Background" Value="#FF0F1A35"/>
            <Setter Property="BorderBrush" Value="#2A3A66"/>
            <Setter Property="Padding" Value="12,8"/>
        </Style>

        <!-- Card -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="14"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <!-- GroupBox -->
        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Padding" Value="10"/>
        </Style>

        <!-- DataGrid -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#00000000"/>
            <Setter Property="RowBackground" Value="#14000000"/>
            <Setter Property="AlternatingRowBackground" Value="#1A000000"/>
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="CanUserSortColumns" Value="True"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#22000000"/>
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#223047"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Tabs -->
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="#00000000"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd"
                                Background="#11000000"
                                BorderBrush="#223047"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#221A2B50"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Accent}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#22111A33"/>
                                <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid Background="{StaticResource AppBg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TOP BAR -->
        <Border Grid.Row="0" Padding="14" Background="#99050A14" BorderBrush="#223047" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="GHL Titan" Foreground="{StaticResource TextMain}" FontSize="22" FontWeight="Bold" Margin="0,0,14,0"/>
                    <Border Background="#221A2B50" BorderBrush="{StaticResource Accent}" BorderThickness="1" CornerRadius="999" Padding="10,4">
                        <TextBlock Text="Dashboard" Foreground="{StaticResource TextMain}" FontSize="12" FontWeight="SemiBold"/>
                    </Border>
                    <TextBlock Text="•" Foreground="{StaticResource TextMuted}" Margin="12,0,12,0" FontSize="16"/>
                    <TextBlock x:Name="ClockText" Text="--:--:--" Foreground="{StaticResource TextMain}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="UserNameText" Text="User: Demo" Foreground="{StaticResource TextMain}" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <Button Content="Log Out" Style="{StaticResource ActionButton}" Click="Logout_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- BODY -->
        <Grid Grid.Row="1" Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- SIDEBAR -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,14,0">
                <StackPanel>
                    <TextBlock Text="Navigation" Foreground="{StaticResource TextMain}" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

                    <Button Content="🏠 Overview" Style="{StaticResource NavButton}" Margin="0,0,0,10" Click="Nav_Overview_Click"/>
                    <Button Content="👤 Account" Style="{StaticResource NavButton}" Margin="0,0,0,10" Click="Nav_Account_Click"/>
                    <Button Content="💳 Payments" Style="{StaticResource NavButton}" Margin="0,0,0,10" Click="Nav_Payments_Click"/>
                    <Button Content="🧾 Contracts" Style="{StaticResource NavButton}" Margin="0,0,0,10" Click="Nav_Contracts_Click"/>
                    <Button Content="🗓️ Calendar" Style="{StaticResource NavButton}" Margin="0,0,0,10" Click="Nav_Calendar_Click"/>
                    <Button Content="💬 SMS Manager" Style="{StaticResource NavButton}" Margin="0,0,0,10" Click="Nav_SMSManager_Click"/>
                    <Button Content="✉️ Email Manager" Style="{StaticResource NavButton}" Margin="0,0,0,10" Click="Nav_EmailManager_Click"/>

                    <Separator Margin="0,14,0,14" Background="#223047"/>

                    <TextBlock Text="Quick Actions" Foreground="{StaticResource TextMain}" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                    <Button Content="➕ Add Payment" Style="{StaticResource ActionButton}" Margin="0,0,0,10" Click="AddPayment_Click"/>
                    <Button Content="✍️ Create Contract" Style="{StaticResource ActionButton}" Margin="0,0,0,10" Click="CreateContract_Click"/>
                    <Button Content="📇 New Outreach Contact" Style="{StaticResource ActionButton}" Click="NewContact_Click"/>

                    <Border Margin="0,16,0,0" Background="#16000000" BorderBrush="#223047" BorderThickness="1" CornerRadius="12" Padding="10">
                        <StackPanel>
                            <TextBlock Text="💡 Tip" Foreground="{StaticResource TextMain}" FontWeight="SemiBold"/>
                            <TextBlock Text="Keep it moving—log payments + schedule drops." Foreground="{StaticResource TextMuted}" TextWrapping="Wrap" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- MAIN -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- KPI CARDS -->
                <UniformGrid Grid.Row="0" Columns="4" Margin="0,0,0,14">
                    <Border Style="{StaticResource Card}" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="Account Status" Foreground="{StaticResource TextMuted}"/>
                            <TextBlock x:Name="AccountStatusText" Text="Active" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextMain}" Margin="0,6,0,0"/>
                            <TextBlock Text="Plan: Creator Pro" Foreground="{StaticResource TextMuted}" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="Next Payment" Foreground="{StaticResource TextMuted}"/>
                            <TextBlock x:Name="NextPaymentText" Text="$49.00" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextMain}" Margin="0,6,0,0"/>
                            <TextBlock x:Name="NextPaymentDateText" Text="Due: Mar 1" Foreground="{StaticResource TextMuted}" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="Revenue (MTD)" Foreground="{StaticResource TextMuted}"/>
                            <TextBlock x:Name="RevenueText" Text="$0" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextMain}" Margin="0,6,0,0"/>
                            <TextBlock Text="From content + sales" Foreground="{StaticResource TextMuted}" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="Tasks" Foreground="{StaticResource TextMuted}"/>
                            <TextBlock x:Name="TasksText" Text="3 Open" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextMain}" Margin="0,6,0,0"/>
                            <TextBlock Text="Keep momentum" Foreground="{StaticResource TextMuted}" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- TABS -->
                <TabControl Grid.Row="1" x:Name="MainTabs">

                    <!-- OVERVIEW -->
                    <TabItem Header="Overview">
                        <Grid Margin="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,12,0">
                                <GroupBox Header="Recent Payments" Margin="0">
                                    <DataGrid x:Name="PaymentsGrid" AutoGenerateColumns="False" CanUserAddRows="False" Margin="0,8,0,0">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Date" Binding="{Binding Date}" Width="*"/>
                                            <DataGridTextColumn Header="Amount" Binding="{Binding Amount}" Width="*"/>
                                            <DataGridTextColumn Header="Method" Binding="{Binding Method}" Width="*"/>
                                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </GroupBox>
                            </Border>

                            <Border Grid.Column="1" Style="{StaticResource Card}">
                                <GroupBox Header="Upcoming Calendar" Margin="0">
                                    <DataGrid x:Name="CalendarGrid" AutoGenerateColumns="False" CanUserAddRows="False" Margin="0,8,0,0">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Date" Binding="{Binding Date}" Width="*"/>
                                            <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="2*"/>
                                            <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </GroupBox>
                            </Border>
                        </Grid>
                    </TabItem>

                    <!-- ACCOUNT -->
                    <TabItem Header="Account">
                        <Grid Margin="12">
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="Account Details" Foreground="{StaticResource TextMain}" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                            <TextBlock Text="Display Name" Foreground="{StaticResource TextMuted}"/>
                                            <TextBlock x:Name="DisplayNameText" Text="Demo User" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextMain}" Margin="0,4,0,12"/>

                                            <TextBlock Text="Email" Foreground="{StaticResource TextMuted}"/>
                                            <TextBlock x:Name="EmailText" Text="demo@email.com" Foreground="{StaticResource TextMain}" Margin="0,4,0,12"/>

                                            <TextBlock Text="Plan" Foreground="{StaticResource TextMuted}"/>
                                            <TextBlock x:Name="PlanText" Text="Creator Pro" Foreground="{StaticResource TextMain}" Margin="0,4,0,0"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Status" Foreground="{StaticResource TextMuted}"/>
                                            <TextBlock x:Name="StatusText" Text="Active" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextMain}" Margin="0,4,0,12"/>

                                            <TextBlock Text="Member Since" Foreground="{StaticResource TextMuted}"/>
                                            <TextBlock x:Name="MemberSinceText" Text="2020" Foreground="{StaticResource TextMain}" Margin="0,4,0,12"/>

                                            <TextBlock Text="Notes" Foreground="{StaticResource TextMuted}"/>
                                            <TextBlock Text="(placeholder — add notes later)" Foreground="{StaticResource TextMain}" Opacity="0.9" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Grid>

                                    <Border Margin="0,14,0,0" Background="#14000000" BorderBrush="#223047" BorderThickness="1" CornerRadius="12" Padding="10">
                                        <StackPanel>
                                            <TextBlock Text="Security (Coming Soon)" Foreground="{StaticResource TextMain}" FontWeight="SemiBold"/>
                                            <TextBlock Text="Password + MFA + login roles later." Foreground="{StaticResource TextMuted}" Margin="0,6,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </TabItem>

                    <!-- PAYMENTS -->
                    <TabItem Header="Payments">
                        <Grid Margin="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Current Plan" Foreground="{StaticResource TextMuted}"/>
                                        <TextBlock Text="Creator Pro" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextMain}" Margin="0,4,0,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Next Charge" Foreground="{StaticResource TextMuted}"/>
                                        <TextBlock Text="$49.00" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextMain}" Margin="0,4,0,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Default Method" Foreground="{StaticResource TextMuted}"/>
                                        <TextBlock Text="Card (•••• 4242)" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextMain}" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Grid.Row="1" Style="{StaticResource Card}">
                                <GroupBox Header="Payment History" Margin="0">
                                    <DataGrid x:Name="PaymentHistoryGrid" AutoGenerateColumns="False" CanUserAddRows="False" Margin="0,8,0,0">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Invoice #" Binding="{Binding Invoice}" Width="*"/>
                                            <DataGridTextColumn Header="Date" Binding="{Binding Date}" Width="*"/>
                                            <DataGridTextColumn Header="Amount" Binding="{Binding Amount}" Width="*"/>
                                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </GroupBox>
                            </Border>
                        </Grid>
                    </TabItem>

                    <!-- CONTRACTS -->
                    <TabItem Header="Contracts">
                        <Grid Margin="12">
                            <Border Style="{StaticResource Card}">
                                <GroupBox Header="Active Contracts" Margin="0">
                                    <DataGrid x:Name="ContractsGrid" AutoGenerateColumns="False" CanUserAddRows="False" Margin="0,8,0,0">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Client" Binding="{Binding Client}" Width="2*"/>
                                            <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="*"/>
                                            <DataGridTextColumn Header="Start" Binding="{Binding Start}" Width="*"/>
                                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="*"/>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </GroupBox>
                            </Border>
                        </Grid>
                    </TabItem>

                    <!-- CALENDAR -->
                    <TabItem Header="Calendar">
                        <Grid Margin="12">
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="Schedule (Placeholder)" Foreground="{StaticResource TextMain}" FontWeight="Bold" FontSize="14"/>
                                    <TextBlock Text="Later: hook a real calendar (Google / SQL / control)." Foreground="{StaticResource TextMuted}" Margin="0,8,0,0"/>
                                    <TextBlock Text="For now the mini schedule is in Overview → Upcoming Calendar." Foreground="{StaticResource TextMuted}" Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </TabItem>

                    <!-- SMS -->
                    <TabItem Header="SMS Manager">
                        <Grid Margin="12">
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="SMS Manager" Foreground="{StaticResource TextMain}" FontWeight="Bold" FontSize="14"/>
                                    <TextBlock Text="Coming soon: templates, contact search, and send logs." Foreground="{StaticResource TextMuted}" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </TabItem>

                    <!-- EMAIL (fixed + clean) -->
                    <TabItem Header="Email Manager">
                        <Grid Margin="12">
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Text="Email Manager" Foreground="{StaticResource TextMain}" FontWeight="Bold" FontSize="14"/>
                                    <TextBlock Text="Store templates, schedule emails, and keep send logs (later: SMTP / API)."
                                               Foreground="{StaticResource TextMuted}" Margin="0,8,0,0" TextWrapping="Wrap"/>

                                    <Border Margin="0,14,0,0" Background="#14000000" BorderBrush="#223047" BorderThickness="1" CornerRadius="12" Padding="10">
                                        <StackPanel>
                                            <TextBlock Text="Planned Features" Foreground="{StaticResource TextMain}" FontWeight="SemiBold"/>
                                            <TextBlock Text="• Template library" Foreground="{StaticResource TextMuted}" Margin="0,6,0,0"/>
                                            <TextBlock Text="• Scheduled sends" Foreground="{StaticResource TextMuted}" Margin="0,4,0,0"/>
                                            <TextBlock Text="• Send history + status" Foreground="{StaticResource TextMuted}" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </TabItem>

                </TabControl>
            </Grid>
        </Grid>

        <!-- FOOTER -->
        <Border Grid.Row="2" Padding="10" Background="#77050A14" BorderBrush="#223047" BorderThickness="0,1,0,0">
            <TextBlock Text="Titan • Data + creativity finally in one place"
                       Foreground="{StaticResource TextMuted}"
                       HorizontalAlignment="Center"/>
        </Border>
    </Grid>
</Window>